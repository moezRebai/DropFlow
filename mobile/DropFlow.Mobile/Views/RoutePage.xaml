<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="DropFlow.Mobile.Views.RoutePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:DropFlow.Mobile.ViewModels"
    xmlns:models="clr-namespace:DropFlow.Mobile.Models"
    x:DataType="vm:RouteViewModel"
    BackgroundColor="{StaticResource PageBackground}">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" BackgroundColor="{StaticResource Primary}" Padding="16,44,16,16"
              ColumnDefinitions="*,Auto">

            <!-- Mode normal : nom du livreur -->
            <VerticalStackLayout Grid.Column="0" Spacing="2"
                                 IsVisible="{Binding ShowBackButton, Converter={StaticResource InvertBool}}">
                <Label Text="{Binding CurrentUser.FullName}" FontSize="18" FontAttributes="Bold"
                       TextColor="White" />
                <Label Text="{Binding CurrentUser.TenantName}" FontSize="13" TextColor="#B3E5FC" />
            </VerticalStackLayout>

            <!-- Mode back : flèche + référence tournée -->
            <HorizontalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center"
                                   IsVisible="{Binding ShowBackButton}">
                <Label Text="←" FontSize="26" TextColor="White" VerticalOptions="Center"
                       Padding="0,0,4,0">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                    </Label.GestureRecognizers>
                </Label>
                <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                    <Label Text="{Binding TodayRoute.Route.Reference}" FontSize="17"
                           FontAttributes="Bold" TextColor="White" />
                    <Label Text="{Binding TodayRoute.Route.Date, StringFormat='Tournée du {0:dd/MM/yyyy}'}"
                           FontSize="12" TextColor="#B3E5FC" />
                </VerticalStackLayout>
            </HorizontalStackLayout>

            <!-- Boutons actions (masqués en mode back) -->
            <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center"
                                   IsVisible="{Binding ShowBackButton, Converter={StaticResource InvertBool}}">

                <!-- Historique -->
                <Frame BackgroundColor="#33FFFFFF" BorderColor="#66FFFFFF"
                       CornerRadius="10" Padding="10,6" HasShadow="False">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToHistoryCommand}" />
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Path Data="M13,3C8.03,3 4,7.03 4,12H1L4.89,16L8.79,12H6A7,7 0 0,1 13,5A7,7 0 0,1 20,12A7,7 0 0,1 13,19C11.07,19 9.32,18.21 8.06,16.94L6.64,18.36C8.27,19.99 10.5,21 13,21A9,9 0 0,0 22,12A9,9 0 0,0 13,3M12,8V13L16.28,15.54L17,14.33L13.5,12.25V8H12Z"
                              Fill="White" WidthRequest="20" HeightRequest="20" Aspect="Uniform"
                              HorizontalOptions="Center" />
                        <Label Text="Historique" FontSize="9" TextColor="White"
                               FontAttributes="Bold" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Profil -->
                <Frame BackgroundColor="#33FFFFFF" BorderColor="#66FFFFFF"
                       CornerRadius="10" Padding="10,6" HasShadow="False">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToProfileCommand}" />
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Path Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"
                              Fill="White" WidthRequest="20" HeightRequest="20" Aspect="Uniform"
                              HorizontalOptions="Center" />
                        <Label Text="Profil" FontSize="9" TextColor="White"
                               FontAttributes="Bold" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Déconnexion -->
                <Frame BackgroundColor="#33E53935" BorderColor="#66EF9A9A"
                       CornerRadius="10" Padding="10,6" HasShadow="False">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding LogoutCommand}" />
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Path Data="M17,17V14H10V10H17V7L22,12L17,17M13,2A2,2 0 0,1 15,4V6H13V4H4V20H13V18H15V20A2,2 0 0,1 13,22H4A2,2 0 0,1 2,20V4A2,2 0 0,1 4,2H13Z"
                              Fill="#FFCDD2" WidthRequest="20" HeightRequest="20" Aspect="Uniform"
                              HorizontalOptions="Center" />
                        <Label Text="Sortir" FontSize="9" TextColor="#FFCDD2"
                               FontAttributes="Bold" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>

            </HorizontalStackLayout>
        </Grid>

        <!-- Offline banner -->
        <Frame Grid.Row="1" Style="{StaticResource OfflineBanner}" IsVisible="{Binding IsOffline}">
            <Label Text="Pas de connexion Internet" TextColor="White" FontAttributes="Bold" HorizontalOptions="Center" />
        </Frame>

        <!-- Content -->
        <RefreshView Grid.Row="2" Command="{Binding LoadRouteCommand}"
                     IsRefreshing="{Binding IsBusy}">
            <ScrollView>
                <VerticalStackLayout Padding="16" Spacing="8">

                    <!-- Error -->
                    <Frame IsVisible="{Binding HasError}" BackgroundColor="#FFEBEE" BorderColor="#EF9A9A" CornerRadius="8" Padding="12">
                        <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource Error}" FontSize="14" />
                    </Frame>

                    <!-- No route today -->
                    <VerticalStackLayout
                        IsVisible="{Binding TodayRoute.HasRoute, Converter={StaticResource InvertBool}}"
                        Spacing="16">

                        <!-- Message aucune tournée aujourd'hui -->
                        <VerticalStackLayout Spacing="8" Margin="0,40,0,0" HorizontalOptions="Center"
                                             IsVisible="{Binding HasUpcomingRoutes, Converter={StaticResource InvertBool}}">
                            <Path Data="M18,18.5A1.5,1.5 0 0,1 16.5,17A1.5,1.5 0 0,1 18,15.5A1.5,1.5 0 0,1 19.5,17A1.5,1.5 0 0,1 18,18.5M19.5,9.5L21.46,12H17V9.5M6,18.5A1.5,1.5 0 0,1 4.5,17A1.5,1.5 0 0,1 6,15.5A1.5,1.5 0 0,1 7.5,17A1.5,1.5 0 0,1 6,18.5M20,8H17V4H3C1.89,4 1,4.89 1,6V17H3A3,3 0 0,0 6,20A3,3 0 0,0 9,17H15A3,3 0 0,0 18,20A3,3 0 0,0 21,17H23V12L20,8Z"
                                  Fill="{StaticResource TextMuted}" WidthRequest="80" HeightRequest="80" Aspect="Uniform"
                                  HorizontalOptions="Center" />
                            <Label Text="{Binding TodayRoute.Message, FallbackValue='Aucune tournée prévue aujourd\'hui'}"
                                   FontSize="18" TextColor="{StaticResource TextSecondary}"
                                   HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                            <Button Text="Actualiser" Command="{Binding LoadRouteCommand}"
                                    Style="{StaticResource SecondaryButton}" HorizontalOptions="Center"
                                    WidthRequest="160" />
                        </VerticalStackLayout>

                        <!-- Liste tournées à venir -->
                        <VerticalStackLayout IsVisible="{Binding HasUpcomingRoutes}" Spacing="12" Margin="0,16,0,0">
                            <Label Text="Tournées à venir" FontSize="18" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <CollectionView ItemsSource="{Binding UpcomingRoutes}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:RouteSummaryItem">
                                        <Frame Style="{StaticResource Card}" Margin="0,0,0,8">
                                            <Frame.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RouteViewModel}}, Path=SelectUpcomingRouteCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </Frame.GestureRecognizers>
                                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                                <!-- Date badge -->
                                                <Frame Grid.Column="0" WidthRequest="56" CornerRadius="10"
                                                       BackgroundColor="{StaticResource Primary}" Padding="6,8"
                                                       HasShadow="False" HorizontalOptions="Center" VerticalOptions="Center">
                                                    <VerticalStackLayout Spacing="0">
                                                        <Label Text="{Binding Date, StringFormat='{0:dd}'}"
                                                               FontSize="20" FontAttributes="Bold"
                                                               TextColor="White" HorizontalOptions="Center" />
                                                        <Label Text="{Binding Date, StringFormat='{0:MMM}'}"
                                                               FontSize="11" TextColor="#B3E5FC"
                                                               HorizontalOptions="Center" />
                                                    </VerticalStackLayout>
                                                </Frame>
                                                <!-- Infos -->
                                                <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                                    <Label Text="{Binding Reference}" FontSize="16"
                                                           FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                                                    <Label TextColor="{StaticResource TextSecondary}" FontSize="13">
                                                        <Label.FormattedText>
                                                            <FormattedString>
                                                                <Span Text="{Binding TotalDeliveries}" FontAttributes="Bold" />
                                                                <Span Text=" livraisons · " />
                                                                <Span Text="{Binding StartTimeDisplay}" />
                                                                <Span Text=" · " />
                                                                <Span Text="{Binding VehicleName}" />
                                                            </FormattedString>
                                                        </Label.FormattedText>
                                                    </Label>
                                                </VerticalStackLayout>
                                                <!-- Chevron -->
                                                <Label Grid.Column="2" Text="›" FontSize="28"
                                                       TextColor="{StaticResource TextMuted}"
                                                       VerticalOptions="Center" />
                                            </Grid>
                                        </Frame>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>

                    </VerticalStackLayout>

                    <!-- Route content -->
                    <VerticalStackLayout IsVisible="{Binding TodayRoute.HasRoute}" Spacing="8">

                        <!-- Summary card -->
                        <Frame Style="{StaticResource Card}">
                            <VerticalStackLayout Spacing="8">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0" Text="{Binding TodayRoute.Route.Reference}"
                                           FontSize="18" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                                    <Frame Grid.Column="1" Padding="8,4" CornerRadius="16" HasShadow="False"
                                           BackgroundColor="{Binding TodayRoute.Route.Status, Converter={StaticResource StatusBackground}}">
                                        <Label Text="{Binding TodayRoute.Route.StatusDisplay}"
                                               TextColor="{Binding TodayRoute.Route.Status, Converter={StaticResource StatusColor}}"
                                               FontSize="13" FontAttributes="Bold" />
                                    </Frame>
                                </Grid>

                                <!-- Metrics -->
                                <Grid ColumnDefinitions="*,*,*" Margin="0,8,0,0">
                                    <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                                        <Label Text="{Binding TodayRoute.Route.TotalDeliveries}" FontSize="24"
                                               FontAttributes="Bold" TextColor="{StaticResource Primary}" HorizontalOptions="Center" />
                                        <Label Text="Livraisons" FontSize="12" TextColor="{StaticResource TextMuted}" HorizontalOptions="Center" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2">
                                        <Label Text="{Binding TodayRoute.Route.TotalDistanceKm, StringFormat='{0:F0} km'}"
                                               FontSize="24" FontAttributes="Bold" TextColor="{StaticResource Primary}" HorizontalOptions="Center" />
                                        <Label Text="Distance" FontSize="12" TextColor="{StaticResource TextMuted}" HorizontalOptions="Center" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                                        <Label Text="{Binding TodayRoute.Route.StartTime}" FontSize="24"
                                               FontAttributes="Bold" TextColor="{StaticResource Primary}" HorizontalOptions="Center" />
                                        <Label Text="Départ" FontSize="12" TextColor="{StaticResource TextMuted}" HorizontalOptions="Center" />
                                    </VerticalStackLayout>
                                </Grid>

                                <!-- Progress -->
                                <ProgressBar Progress="{Binding TodayRoute.Route.ProgressPercent}"
                                             ProgressColor="{StaticResource Success}" Margin="0,8,0,0" />
                                <Label FontSize="13" TextColor="{StaticResource TextSecondary}">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding TodayRoute.Route.DeliveredCount}" FontAttributes="Bold" />
                                            <Span Text=" / " />
                                            <Span Text="{Binding TodayRoute.Route.TotalDeliveries}" FontAttributes="Bold" />
                                            <Span Text=" livrées" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </VerticalStackLayout>
                        </Frame>

                        <!-- Start route button : toujours visible, grisé si tournée future -->
                        <Button Text="Démarrer la tournée"
                                Command="{Binding StartRouteCommand}"
                                Style="{StaticResource PrimaryButton}"
                                IsEnabled="{Binding CanStartRoute}"
                                Opacity="{Binding CanStartRoute, Converter={StaticResource BoolToOpacity}}" />

                        <!-- Deliveries list -->
                        <CollectionView ItemsSource="{Binding TodayRoute.Route.Deliveries}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:DeliveryListItem">
                                    <Frame Style="{StaticResource Card}" Margin="0,0,0,6">
                                        <Frame.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RouteViewModel}}, Path=NavigateToDeliveryCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Frame.GestureRecognizers>
                                        <Grid ColumnDefinitions="48,*,Auto" ColumnSpacing="12">
                                            <!-- Sequence circle -->
                                            <Frame Grid.Column="0" WidthRequest="40" HeightRequest="40"
                                                   CornerRadius="20" Padding="0" HasShadow="False"
                                                   BackgroundColor="{Binding Status, Converter={StaticResource StatusBackground}}"
                                                   HorizontalOptions="Center" VerticalOptions="Center">
                                                <Label Text="{Binding SequenceOrder}"
                                                       TextColor="{Binding Status, Converter={StaticResource StatusColor}}"
                                                       FontAttributes="Bold" FontSize="16"
                                                       HorizontalOptions="Center" VerticalOptions="Center" />
                                            </Frame>

                                            <!-- Info -->
                                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                                <Label Text="{Binding ClientName}" FontSize="16" FontAttributes="Bold"
                                                       TextColor="{StaticResource TextPrimary}" />
                                                <Label TextColor="{StaticResource TextSecondary}" FontSize="14">
                                                    <Label.FormattedText>
                                                        <FormattedString>
                                                            <Span Text="{Binding ZipCode}" />
                                                            <Span Text=" " />
                                                            <Span Text="{Binding City}" />
                                                            <Span Text=" · " />
                                                            <Span Text="{Binding TotalPackages}" />
                                                            <Span Text=" colis" />
                                                        </FormattedString>
                                                    </Label.FormattedText>
                                                </Label>
                                                <HorizontalStackLayout Spacing="8">
                                                    <Path Data="M22.7,19L13.6,9.9C14.5,7.6 14,4.9 12.1,3C10.1,1 7.1,0.6 4.7,1.7L9,6L6,9L1.6,4.7C0.4,7.1 0.9,10.1 2.9,12.1C4.8,14 7.5,14.5 9.8,13.6L18.9,22.7C19.3,23.1 19.9,23.1 20.3,22.7L22.6,20.4C23.1,20 23.1,19.3 22.7,19Z"
                                                          Fill="{StaticResource TextMuted}" WidthRequest="14" HeightRequest="14"
                                                          Aspect="Uniform" VerticalOptions="Center"
                                                          IsVisible="{Binding WithAssembly}" />
                                                    <Label Text="Montage" FontSize="13" TextColor="{StaticResource TextMuted}"
                                                           IsVisible="{Binding WithAssembly}" VerticalOptions="Center" />
                                                    <Path Data="M7,15H9C9,16.08 10.37,17 12,17C13.63,17 15,16.08 15,15C15,13.9 13.96,13.5 11.76,12.97C9.64,12.44 7,11.78 7,9C7,7.21 8.47,5.69 10.5,5.18V3H13.5V5.18C15.53,5.69 17,7.21 17,9H15C15,7.92 13.63,7 12,7C10.37,7 9,7.92 9,9C9,10.1 10.04,10.5 12.24,11.03C14.36,11.56 17,12.22 17,15C17,16.79 15.53,18.31 13.5,18.82V21H10.5V18.82C8.47,18.31 7,16.79 7,15Z"
                                                          Fill="{StaticResource Warning}" WidthRequest="14" HeightRequest="14"
                                                          Aspect="Uniform" VerticalOptions="Center"
                                                          IsVisible="{Binding HasClientPayment}" />
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>

                                            <!-- Status badge -->
                                            <Frame Grid.Column="2" Padding="8,4" CornerRadius="12" HasShadow="False"
                                                   BackgroundColor="{Binding Status, Converter={StaticResource StatusBackground}}"
                                                   VerticalOptions="Center">
                                                <Label Text="{Binding StatusDisplay}"
                                                       TextColor="{Binding Status, Converter={StaticResource StatusColor}}"
                                                       FontSize="12" FontAttributes="Bold" />
                                            </Frame>
                                        </Grid>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <!-- Complete route button (InProgress = 2) -->
                        <Button Text="Terminer la tournée"
                                Command="{Binding CompleteRouteCommand}"
                                Style="{StaticResource SuccessButton}"
                                Margin="0,8,0,24" />

                    </VerticalStackLayout>
                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>
    </Grid>

</ContentPage>

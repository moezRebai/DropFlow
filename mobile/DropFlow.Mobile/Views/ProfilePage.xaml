<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="DropFlow.Mobile.Views.ProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:DropFlow.Mobile.ViewModels"
    x:DataType="vm:ProfileViewModel"
    BackgroundColor="{StaticResource PageBackground}">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" BackgroundColor="{StaticResource Primary}" Padding="16,44,16,16"
              ColumnDefinitions="Auto,*">
            <Button Grid.Column="0" Text="←" Command="{Binding GoBackCommand}"
                    BackgroundColor="Transparent" TextColor="White" FontSize="22" Padding="0"
                    WidthRequest="44" />
            <Label Grid.Column="1" Text="Mon profil" FontSize="16" FontAttributes="Bold"
                   TextColor="White" VerticalOptions="Center" />
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16" Spacing="12">

                <!-- Avatar + name -->
                <Frame Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Frame WidthRequest="80" HeightRequest="80" CornerRadius="40"
                               BackgroundColor="{StaticResource Primary}" Padding="0"
                               HasShadow="False" HorizontalOptions="Center">
                            <Path Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"
                                  Fill="White" WidthRequest="44" HeightRequest="44" Aspect="Uniform"
                                  HorizontalOptions="Center" VerticalOptions="Center" />
                        </Frame>
                        <Label Text="{Binding User.FullName}" FontSize="20" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" HorizontalOptions="Center" />
                        <Frame Padding="12,4" CornerRadius="16" HasShadow="False"
                               BackgroundColor="{StaticResource Primary}" HorizontalOptions="Center">
                            <Label Text="Livreur" TextColor="White" FontSize="13" FontAttributes="Bold" />
                        </Frame>
                    </VerticalStackLayout>
                </Frame>

                <!-- Infos -->
                <Frame Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Informations" Style="{StaticResource SectionTitle}" />

                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="12">
                            <Path Grid.Row="0" Grid.Column="0"
                                  Data="M20,8L12,13L4,8V6L12,11L20,6M20,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6C22,4.89 21.1,4 20,4Z"
                                  Fill="{StaticResource Primary}" WidthRequest="22" HeightRequest="22"
                                  Aspect="Uniform" VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="2">
                                <Label Text="Email" FontSize="12" TextColor="{StaticResource TextMuted}" />
                                <Label Text="{Binding User.Email}" FontSize="15" TextColor="{StaticResource TextPrimary}" />
                            </VerticalStackLayout>

                            <Path Grid.Row="1" Grid.Column="0"
                                  Data="M5,3H19A2,2 0 0,1 21,5V19A2,2 0 0,1 19,21H5A2,2 0 0,1 3,19V5A2,2 0 0,1 5,3M7,7V9H9V7H7M11,7V9H13V7H11M15,7V9H17V7H15M7,11V13H9V11H7M11,11V13H13V11H11M15,11V13H17V11H15M7,15V17H9V15H7M11,15V17H13V15H11M15,15V17H17V15H15Z"
                                  Fill="{StaticResource Primary}" WidthRequest="22" HeightRequest="22"
                                  Aspect="Uniform" VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="2">
                                <Label Text="Entreprise" FontSize="12" TextColor="{StaticResource TextMuted}" />
                                <Label Text="{Binding User.TenantName}" FontSize="15" TextColor="{StaticResource TextPrimary}" />
                            </VerticalStackLayout>

                            <Path Grid.Row="2" Grid.Column="0"
                                  Data="M12.65,10C11.83,7.67 9.61,6 7,6A6,6 0 0,0 1,12A6,6 0 0,0 7,18C9.61,18 11.83,16.33 12.65,14H17V18H21V14H23V10H12.65M7,14A2,2 0 0,1 5,12A2,2 0 0,1 7,10A2,2 0 0,1 9,12A2,2 0 0,1 7,14Z"
                                  Fill="{StaticResource Primary}" WidthRequest="22" HeightRequest="22"
                                  Aspect="Uniform" VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Row="2" Grid.Column="1" Spacing="2">
                                <Label Text="Rôle" FontSize="12" TextColor="{StaticResource TextMuted}" />
                                <Label Text="{Binding User.Role}" FontSize="15" TextColor="{StaticResource TextPrimary}" />
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- Stats -->
                <Frame Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Statistiques" Style="{StaticResource SectionTitle}" />

                        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                           Color="{StaticResource Primary}" HorizontalOptions="Center" />

                        <Grid ColumnDefinitions="*,*" IsVisible="{Binding IsBusy, Converter={StaticResource InvertBool}}">
                            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="4">
                                <Label Text="{Binding TotalDelivered}" FontSize="32" FontAttributes="Bold"
                                       TextColor="{StaticResource Success}" HorizontalOptions="Center" />
                                <Label Text="Livrées" FontSize="13" TextColor="{StaticResource TextMuted}"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="4">
                                <Label Text="{Binding TotalCanceled}" FontSize="32" FontAttributes="Bold"
                                       TextColor="{StaticResource TextMuted}" HorizontalOptions="Center" />
                                <Label Text="Annulées" FontSize="13" TextColor="{StaticResource TextMuted}"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- Logout -->
                <Button Text="Se déconnecter" Command="{Binding LogoutCommand}"
                        Style="{StaticResource DangerButton}" Margin="0,8,0,24" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>

<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Brand -->
    <Color x:Key="Primary">#1565C0</Color>
    <Color x:Key="PrimaryDark">#0D47A1</Color>
    <Color x:Key="PrimaryLight">#42A5F5</Color>
    <Color x:Key="Accent">#00BCD4</Color>

    <!-- Backgrounds -->
    <Color x:Key="PageBackground">#F5F5F5</Color>
    <Color x:Key="CardBackground">#FFFFFF</Color>

    <!-- Text -->
    <Color x:Key="TextPrimary">#212121</Color>
    <Color x:Key="TextSecondary">#757575</Color>
    <Color x:Key="TextMuted">#9E9E9E</Color>

    <!-- Semantic -->
    <Color x:Key="Success">#4CAF50</Color>
    <Color x:Key="Warning">#FF9800</Color>
    <Color x:Key="Error">#F44336</Color>
    <Color x:Key="Info">#2196F3</Color>

    <!-- Delivery Status -->
    <Color x:Key="StatusToBePlanned">#42A5F5</Color>
    <Color x:Key="StatusConfirmed">#FFA726</Color>
    <Color x:Key="StatusInProgress">#AB47BC</Color>
    <Color x:Key="StatusDelivered">#66BB6A</Color>
    <Color x:Key="StatusCanceled">#BDBDBD</Color>

</ResourceDictionary>

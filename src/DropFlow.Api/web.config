<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- Remove WebDAV which intercepts PUT and DELETE -->
    <modules>
      <remove name="WebDAVModule" />
    </modules>
    <handlers>
      <remove name="WebDAV" />
    </handlers>

    <!-- Explicitly allow PUT, DELETE, PATCH through IIS Request Filtering -->
    <security>
      <requestFiltering>
        <verbs>
          <add verb="PUT" allowed="true" />
          <add verb="DELETE" allowed="true" />
          <add verb="PATCH" allowed="true" />
        </verbs>
      </requestFiltering>
    </security>

  </system.webServer>
</configuration>

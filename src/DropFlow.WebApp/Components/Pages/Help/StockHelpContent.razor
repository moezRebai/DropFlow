<MudStack Spacing="4">
    <MudText Typo="Typo.body1">
        Gérez votre catalogue produits et suivez vos stocks en temps réel pour éviter les ruptures.
    </MudText>

    <MudExpansionPanels MultiExpansion="true">
        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.QuestionMark" Color="Color.Primary" />
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                        Comment ajouter un nouveau produit ?
                    </MudText>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudStack Spacing="2" Class="pa-4">
                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Module <strong>Stock → Nouveau produit</strong>
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Renseignez le nom et la description
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Ajoutez un code SKU et code-barres (optionnel)
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Définissez les prix d'achat et de vente
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Configurez le stock initial et le stock minimum
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Ajoutez une photo (recommandé)
                        </MudListItem>
                    </MudList>

                    <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                        💡 Le <strong>stock minimum</strong> déclenche automatiquement une alerte quand il est atteint.
                    </MudAlert>
                </MudStack>
            </ChildContent>
        </MudExpansionPanel>

        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.QuestionMark" Color="Color.Primary" />
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                        Comment enregistrer un mouvement de stock ?
                    </MudText>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudStack Spacing="2" Class="pa-4">
                    <MudText Typo="Typo.body2">
                        Les mouvements de stock sont automatiques ou manuels :
                    </MudText>

                    <MudText Typo="Typo.body2" Class="mt-2">
                        <strong>Mouvements automatiques :</strong>
                    </MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.LocalShipping">
                            Sortie automatique à la création d'une livraison
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Undo">
                            Entrée automatique lors d'un retour client
                        </MudListItem>
                    </MudList>

                    <MudText Typo="Typo.body2" Class="mt-2">
                        <strong>Mouvements manuels :</strong>
                    </MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Module <strong>Stock → Mouvements → Nouveau</strong>
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Sélectionnez le produit
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Choisissez le type : Entrée, Sortie, Ajustement, Perte
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Indiquez la quantité et le motif
                        </MudListItem>
                    </MudList>

                    <MudSimpleTable Dense="true" Style="border: 1px solid #e2e8f0; border-radius: 8px;" Class="mt-3">
                        <thead>
                            <tr>
                                <th>Type</th>
                                <th>Quand l'utiliser</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><MudChip T="string" Size="Size.Small" Color="Color.Success">Entrée</MudChip></td>
                                <td>Réception marchandise, retour client</td>
                            </tr>
                            <tr>
                                <td><MudChip T="string" Size="Size.Small" Color="Color.Warning">Sortie</MudChip></td>
                                <td>Livraison, utilisation interne</td>
                            </tr>
                            <tr>
                                <td><MudChip T="string" Size="Size.Small" Color="Color.Info">Ajustement</MudChip></td>
                                <td>Correction après inventaire</td>
                            </tr>
                            <tr>
                                <td><MudChip T="string" Size="Size.Small" Color="Color.Error">Perte</MudChip></td>
                                <td>Produit endommagé, périmé</td>
                            </tr>
                        </tbody>
                    </MudSimpleTable>
                </MudStack>
            </ChildContent>
        </MudExpansionPanel>

        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.QuestionMark" Color="Color.Primary" />
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                        Comment gérer les alertes de stock ?
                    </MudText>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudStack Spacing="2" Class="pa-4">
                    <MudText Typo="Typo.body2">
                        DropFlow vous alerte automatiquement pour les situations critiques :
                    </MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconColor="Color.Error">
                            <strong>Rupture de stock :</strong> Quantité = 0
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconColor="Color.Warning">
                            <strong>Stock faible :</strong> Quantité @("<") Stock minimum
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconColor="Color.Warning">
                            <strong>Expiration proche :</strong> Péremption > 30 jours
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconColor="Color.Dark">
                            <strong>Produit expiré :</strong> Date de péremption dépassée
                        </MudListItem>
                    </MudList>

                    <MudText Typo="Typo.body2" Class="mt-2">
                        <strong>Consulter les alertes :</strong>
                    </MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.ArrowRight">
                            Badge notification sur l'icône module Stock
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.ArrowRight">
                            Module <strong>Stock → Alertes</strong>
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.ArrowRight">
                            Email récapitulatif quotidien (configurable)
                        </MudListItem>
                    </MudList>

                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">
                        ⚠️ Activez les notifications email dans <strong>Paramètres → Notifications</strong> 
                        pour ne jamais manquer une alerte stock.
                    </MudAlert>
                </MudStack>
            </ChildContent>
        </MudExpansionPanel>

        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.QuestionMark" Color="Color.Primary" />
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                        Comment réaliser un inventaire ?
                    </MudText>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudStack Spacing="2" Class="pa-4">
                    <MudText Typo="Typo.body2">
                        Réalisez des inventaires réguliers pour maintenir des stocks précis :
                    </MudText>

                    <MudText Typo="Typo.body2" Class="mt-2">
                        <strong>Étapes :</strong>
                    </MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                            <strong>1. Création :</strong> Stock → Inventaire → Nouveau
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                            <strong>2. Périmètre :</strong> Tous les produits ou par catégorie
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                            <strong>3. Comptage :</strong> Saisissez les quantités réelles
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                            <strong>4. Écarts :</strong> Le système calcule automatiquement les différences
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                            <strong>5. Validation :</strong> Justifiez les écarts importants
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                            <strong>6. Ajustements :</strong> Validez pour mettre à jour les stocks
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                            <strong>7. Rapport :</strong> Générez et téléchargez le rapport PDF
                        </MudListItem>
                    </MudList>

                    <MudCard Elevation="0" Style="background: #eff6ff; border: 1px solid #3b82f6; border-radius: 8px;" Class="mt-2">
                        <MudCardContent>
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.body2" Style="font-weight: 600;">
                                    💡 Astuce : Mode scan code-barres
                                </MudText>
                                <MudText Typo="Typo.caption">
                                    Utilisez un lecteur code-barres ou l'application mobile pour scanner 
                                    les produits et accélérer le comptage.
                                </MudText>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudStack>
            </ChildContent>
        </MudExpansionPanel>
    </MudExpansionPanels>

    <MudCard Elevation="0" Style="background: #fef3c7; border: 1px solid #f59e0b; border-radius: 8px;">
        <MudCardContent>
            <MudStack Spacing="2">
                <MudText Typo="Typo.h6" Style="font-weight: 600;">
                    ⚡ Bonnes pratiques Stock
                </MudText>
                <MudList T="string" Dense="true">
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                        Définissez des stocks minimums réalistes basés sur votre historique
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                        Réalisez un inventaire complet au moins une fois par trimestre
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                        Utilisez les catégories pour organiser efficacement votre catalogue
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                        Configurez les alertes email pour être notifié des ruptures
                    </MudListItem>
                </MudList>
            </MudStack>
        </MudCardContent>
    </MudCard>
</MudStack>


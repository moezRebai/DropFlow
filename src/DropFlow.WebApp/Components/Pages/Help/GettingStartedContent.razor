<MudStack Spacing="4">
    <!-- Introduction -->
    <MudAlert Severity="Severity.Success" Dense="true">
        <MudStack Spacing="1">
            <MudText Typo="Typo.body2" Style="font-weight: 600;">
                Bienvenue sur DropFlow ! 👋
            </MudText>
            <MudText Typo="Typo.body2">
                Ce guide vous aidera à démarrer rapidement et à configurer votre compte.
            </MudText>
        </MudStack>
    </MudAlert>

    <!-- Étapes -->
    <MudExpansionPanels MultiExpansion="true">
        <!-- Étape 1 -->
        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudAvatar Color="Color.Primary" Size="Size.Small">1</MudAvatar>
                    <MudText Typo="Typo.h6" Style="font-weight: 600;">
                        Configuration initiale du compte
                    </MudText>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudStack Spacing="2" Class="pa-4">
                    <MudText Typo="Typo.body1">
                        Commencez par configurer les informations de votre entreprise :
                    </MudText>
                    <MudList T="string" T="string" Dense="true">
                        <MudListItem T="string" T="string" Icon="@Icons.Material.Filled.ArrowRight">
                            Accédez à <strong>Paramètres → Général</strong>
                        </MudListItem>
                        <MudListItem T="string" T="string" Icon="@Icons.Material.Filled.ArrowRight">
                            Renseignez le nom de votre entreprise, SIRET, adresse
                        </MudListItem>
                        <MudListItem T="string" T="string" Icon="@Icons.Material.Filled.ArrowRight">
                            Ajoutez votre logo (recommandé : 200x200px, PNG)
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.ArrowRight">
                            Configurez vos coordonnées de contact
                        </MudListItem>
                    </MudList>
                    <MudButton Variant="Variant.Text" 
                               Color="Color.Primary" 
                               StartIcon="@Icons.Material.Filled.Settings"
                               Href="/settings">
                        Accéder aux paramètres
                    </MudButton>
                </MudStack>
            </ChildContent>
        </MudExpansionPanel>

        <!-- Étape 2 -->
        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudAvatar Color="Color.Primary" Size="Size.Small">2</MudAvatar>
                    <MudText Typo="Typo.h6" Style="font-weight: 600;">
                        Inviter votre équipe
                    </MudText>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudStack Spacing="2" Class="pa-4">
                    <MudText Typo="Typo.body1">
                        Collaborez avec votre équipe en invitant des utilisateurs :
                    </MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.ArrowRight">
                            Allez dans <strong>Paramètres → Utilisateurs</strong>
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.ArrowRight">
                            Cliquez sur "Inviter un utilisateur"
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.ArrowRight">
                            Choisissez le rôle approprié (Admin, Manager, Chauffeur, Comptable)
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.ArrowRight">
                            L'utilisateur recevra un email d'invitation
                        </MudListItem>
                    </MudList>
                    <MudAlert Severity="Severity.Info" Dense="true">
                        <strong>Rôles disponibles :</strong> Admin (accès complet), Manager (gestion quotidienne), 
                        Chauffeur (livraisons uniquement), Comptable (facturation)
                    </MudAlert>
                </MudStack>
            </ChildContent>
        </MudExpansionPanel>

        <!-- Étape 3 -->
        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudAvatar Color="Color.Primary" Size="Size.Small">3</MudAvatar>
                    <MudText Typo="Typo.h6" Style="font-weight: 600;">
                        Ajouter vos premiers clients
                    </MudText>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudStack Spacing="2" Class="pa-4">
                    <MudText Typo="Typo.body1">
                        Créez votre base de clients pour faciliter la création de livraisons :
                    </MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.ArrowRight">
                            Accédez au module <strong>Clients</strong>
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.ArrowRight">
                            Cliquez sur "Nouveau client"
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.ArrowRight">
                            Renseignez les coordonnées et adresses de livraison
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.ArrowRight">
                            Option : Importez une liste de clients depuis Excel
                        </MudListItem>
                    </MudList>
                    <MudButton Variant="Variant.Text" 
                               Color="Color.Primary" 
                               StartIcon="@Icons.Material.Filled.People"
                               Href="/clients">
                        Gérer les clients
                    </MudButton>
                </MudStack>
            </ChildContent>
        </MudExpansionPanel>

        <!-- Étape 4 -->
        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudAvatar Color="Color.Primary" Size="Size.Small">4</MudAvatar>
                    <MudText Typo="Typo.h6" Style="font-weight: 600;">
                        Créer votre première livraison
                    </MudText>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudStack Spacing="2" Class="pa-4">
                    <MudText Typo="Typo.body1">
                        Vous êtes prêt à créer votre première livraison :
                    </MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.ArrowRight">
                            Cliquez sur "Nouvelle livraison" depuis le tableau de bord
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.ArrowRight">
                            Sélectionnez le client et l'adresse de livraison
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.ArrowRight">
                            Choisissez la date et l'heure souhaitées
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.ArrowRight">
                            Assignez un chauffeur (optionnel)
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.ArrowRight">
                            Validez et suivez votre livraison depuis le tableau de bord
                        </MudListItem>
                    </MudList>
                    <MudButton Variant="Variant.Filled" 
                               Color="Color.Success" 
                               StartIcon="@Icons.Material.Filled.Add"
                               Href="/deliveries/create">
                        Créer une livraison
                    </MudButton>
                </MudStack>
            </ChildContent>
        </MudExpansionPanel>
    </MudExpansionPanels>

    <!-- Ressources supplémentaires -->
    <MudCard Elevation="0" Style="background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px;">
        <MudCardContent>
            <MudStack Spacing="2">
                <MudText Typo="Typo.h6" Style="font-weight: 600;">
                    📖 Ressources utiles
                </MudText>
                <MudList T="string" Dense="true">
                    <MudListItem T="string" Icon="@Icons.Material.Filled.VideoLibrary">
                        <MudLink Href="#" Color="Color.Primary">
                            Tutoriel vidéo : Configuration complète en 5 minutes
                        </MudLink>
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Article">
                        <MudLink Href="#" Color="Color.Primary">
                            Guide PDF : Les meilleures pratiques DropFlow
                        </MudLink>
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.QuestionAnswer">
                        <MudLink Href="#" Color="Color.Primary">
                            FAQ : Questions fréquentes des nouveaux utilisateurs
                        </MudLink>
                    </MudListItem>
                </MudList>
            </MudStack>
        </MudCardContent>
    </MudCard>
</MudStack>


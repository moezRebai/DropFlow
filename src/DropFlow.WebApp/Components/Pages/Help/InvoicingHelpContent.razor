<MudStack Spacing="4">
    <MudText Typo="Typo.body1">
        Le module Facturation vous permet de générer, envoyer et suivre vos factures automatiquement 
        depuis vos livraisons effectuées.
    </MudText>

    <MudExpansionPanels MultiExpansion="true">
        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.QuestionMark" Color="Color.Primary" />
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                        Comment générer une facture depuis des livraisons ?
                    </MudText>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudStack Spacing="2" Class="pa-4">
                    <MudText Typo="Typo.body2">
                        <strong>Méthode automatique (recommandée) :</strong>
                    </MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                            Accédez au module <strong>Livraisons</strong>
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                            Sélectionnez les livraisons à facturer (statut "Livré")
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                            Cliquez sur "Générer facture" dans les actions groupées
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                            La facture est créée automatiquement avec tous les détails
                        </MudListItem>
                    </MudList>

                    <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                        💡 Les prix des produits livrés sont automatiquement repris. 
                        La TVA est calculée selon le taux configuré.
                    </MudAlert>

                    <MudText Typo="Typo.body2" Class="mt-3">
                        <strong>Méthode manuelle :</strong>
                    </MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Module <strong>Factures → Nouvelle facture</strong>
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Sélectionnez le client
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Ajoutez les lignes manuellement
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Enregistrez comme brouillon ou envoyez directement
                        </MudListItem>
                    </MudList>
                </MudStack>
            </ChildContent>
        </MudExpansionPanel>

        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.QuestionMark" Color="Color.Primary" />
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                        Comment personnaliser mes factures ?
                    </MudText>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudStack Spacing="2" Class="pa-4">
                    <MudText Typo="Typo.body2">
                        Personnalisez l'apparence de vos factures dans les paramètres :
                    </MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Image">
                            <strong>Logo :</strong> Paramètres → Général → Logo entreprise
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Palette">
                            <strong>Couleurs :</strong> Paramètres → Facturation → Couleur principale
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Numbers">
                            <strong>Numérotation :</strong> Définissez le format (ex: FA-2025-001)
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Description">
                            <strong>Mentions légales :</strong> Ajoutez vos conditions de paiement
                        </MudListItem>
                    </MudList>

                    <MudCard Elevation="0" Style="background: #eff6ff; border: 1px solid #3b82f6; border-radius: 8px;" Class="mt-2">
                        <MudCardContent>
                            <MudText Typo="Typo.body2">
                                <strong>Exemple de numérotation :</strong>
                            </MudText>
                            <MudText Typo="Typo.caption">
                                Format : <code>FA-YYYY-XXX</code> → Génère FA-2025-001, FA-2025-002, etc.
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </MudStack>
            </ChildContent>
        </MudExpansionPanel>

        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.QuestionMark" Color="Color.Primary" />
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                        Comment envoyer mes factures par email ?
                    </MudText>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudStack Spacing="2" Class="pa-4">
                    <MudText Typo="Typo.body2">
                        <strong>Envoi individuel :</strong>
                    </MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Ouvrez la facture concernée
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Cliquez sur "Envoyer par email"
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Le PDF est automatiquement joint à l'email
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            L'envoi est enregistré dans l'historique
                        </MudListItem>
                    </MudList>

                    <MudText Typo="Typo.body2" Class="mt-3">
                        <strong>Envoi groupé :</strong>
                    </MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Dashboard → Bouton "Envoyer Factures"
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Sélectionnez les factures à envoyer
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Confirmez l'envoi groupé
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Toutes les factures sont envoyées en arrière-plan
                        </MudListItem>
                    </MudList>

                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">
                        ⚠️ Assurez-vous d'avoir configuré vos paramètres SMTP dans 
                        <strong>Paramètres → Notifications → Configuration Email</strong>
                    </MudAlert>
                </MudStack>
            </ChildContent>
        </MudExpansionPanel>

        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.QuestionMark" Color="Color.Primary" />
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                        Comment gérer les factures impayées ?
                    </MudText>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudStack Spacing="2" Class="pa-4">
                    <MudText Typo="Typo.body2">
                        DropFlow vous aide à suivre et relancer les factures impayées :
                    </MudText>

                    <MudText Typo="Typo.body2" Class="mt-2">
                        <strong>Suivi automatique :</strong>
                    </MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Notifications">
                            Le Dashboard affiche le nombre de factures en attente
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Warning">
                            Les factures passent en statut "En retard" après la date d'échéance
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Email">
                            Emails de relance automatiques (configurable)
                        </MudListItem>
                    </MudList>

                    <MudText Typo="Typo.body2" Class="mt-2">
                        <strong>Actions manuelles :</strong>
                    </MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Filtrez par statut "En attente" ou "En retard"
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Envoyez une relance personnalisée
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Marquez comme "Payée" une fois le paiement reçu
                        </MudListItem>
                    </MudList>

                    <MudSimpleTable Dense="true" Style="border: 1px solid #e2e8f0; border-radius: 8px;" Class="mt-3">
                        <thead>
                            <tr>
                                <th>Statut</th>
                                <th>Description</th>
                                <th>Couleur</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Brouillon</td>
                                <td>En cours de création</td>
                                <td><MudChip T="string" Size="Size.Small" Style="background: #f3f4f6; color: #4b5563;">Gris</MudChip></td>
                            </tr>
                            <tr>
                                <td>Envoyée</td>
                                <td>Facture envoyée au client</td>
                                <td><MudChip T="string" Size="Size.Small" Style="background: #dbeafe; color: #1e40af;">Bleu</MudChip></td>
                            </tr>
                            <tr>
                                <td>Payée</td>
                                <td>Paiement reçu</td>
                                <td><MudChip T="string" Size="Size.Small" Style="background: #d1fae5; color: #065f46;">Vert</MudChip></td>
                            </tr>
                            <tr>
                                <td>En retard</td>
                                <td>Date d'échéance dépassée</td>
                                <td><MudChip T="string" Size="Size.Small" Style="background: #fee2e2; color: #991b1b;">Rouge</MudChip></td>
                            </tr>
                        </tbody>
                    </MudSimpleTable>
                </MudStack>
            </ChildContent>
        </MudExpansionPanel>

        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.QuestionMark" Color="Color.Primary" />
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                        Comment exporter mes factures pour la comptabilité ?
                    </MudText>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudStack Spacing="2" Class="pa-4">
                    <MudText Typo="Typo.body2">
                        Exportez vos données de facturation pour votre logiciel comptable :
                    </MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.FileDownload">
                            Module <strong>Factures → Exporter</strong>
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.DateRange">
                            Sélectionnez la période (mois, trimestre, année)
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.TableChart">
                            Format disponibles : Excel, CSV, PDF
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Download">
                            Téléchargez le fichier généré
                        </MudListItem>
                    </MudList>

                    <MudCard Elevation="0" Style="background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px;" Class="mt-2">
                        <MudCardContent>
                            <MudText Typo="Typo.body2" Style="font-weight: 600;">
                                Données incluses dans l'export :
                            </MudText>
                            <MudText Typo="Typo.caption">
                                • Numéro de facture • Date d'émission • Client • Montant HT • TVA • Total TTC • Statut de paiement
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </MudStack>
            </ChildContent>
        </MudExpansionPanel>
    </MudExpansionPanels>

    <MudCard Elevation="0" Style="background: #fef3c7; border: 1px solid #f59e0b; border-radius: 8px;">
        <MudCardContent>
            <MudStack Spacing="2">
                <MudText Typo="Typo.h6" Style="font-weight: 600;">
                    ⚡ Bonnes pratiques
                </MudText>
                <MudList T="string" Dense="true">
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                        Générez vos factures dès la fin du mois pour un meilleur suivi
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                        Activez les relances automatiques pour éviter les oublis
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                        Vérifiez régulièrement le tableau de bord des factures en attente
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                        Personnalisez vos templates pour une image professionnelle
                    </MudListItem>
                </MudList>
            </MudStack>
        </MudCardContent>
    </MudCard>
</MudStack>


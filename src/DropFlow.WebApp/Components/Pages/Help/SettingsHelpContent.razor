<MudStack Spacing="4">
    <MudText Typo="Typo.body1">
        Configurez votre compte, gérez vos utilisateurs et personnalisez DropFlow selon vos besoins.
    </MudText>

    <MudExpansionPanels MultiExpansion="true">
        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.QuestionMark" Color="Color.Primary" />
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                        Comment inviter de nouveaux utilisateurs ?
                    </MudText>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudStack Spacing="2" Class="pa-4">
                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Paramètres → <strong>Utilisateurs</strong>
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Cliquez sur "Inviter un utilisateur"
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Saisissez l'email et choisissez le rôle
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Un email d'invitation est automatiquement envoyé
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            L'utilisateur crée son mot de passe via le lien reçu
                        </MudListItem>
                    </MudList>

                    <MudSimpleTable Dense="true" Style="border: 1px solid #e2e8f0; border-radius: 8px;" Class="mt-3">
                        <thead>
                            <tr>
                                <th>Rôle</th>
                                <th>Permissions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><MudChip T="string" Size="Size.Small" Color="Color.Error">Admin</MudChip></td>
                                <td>Accès complet, gestion utilisateurs et paramètres</td>
                            </tr>
                            <tr>
                                <td><MudChip T="string" Size="Size.Small" Color="Color.Primary">Manager</MudChip></td>
                                <td>Gestion livraisons, clients, stock, factures</td>
                            </tr>
                            <tr>
                                <td><MudChip T="string" Size="Size.Small" Color="Color.Success">Chauffeur</MudChip></td>
                                <td>Voir et mettre à jour ses livraisons uniquement</td>
                            </tr>
                            <tr>
                                <td><MudChip T="string" Size="Size.Small" Color="Color.Warning">Comptable</MudChip></td>
                                <td>Gestion factures et exports comptables</td>
                            </tr>
                            <tr>
                                <td><MudChip T="string" Size="Size.Small" Color="Color.Default">Lecture</MudChip></td>
                                <td>Consultation uniquement, aucune modification</td>
                            </tr>
                        </tbody>
                    </MudSimpleTable>

                    <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                        💡 Vous pouvez modifier le rôle d'un utilisateur à tout moment.
                    </MudAlert>
                </MudStack>
            </ChildContent>
        </MudExpansionPanel>

        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.QuestionMark" Color="Color.Primary" />
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                        Comment configurer l'envoi d'emails ?
                    </MudText>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudStack Spacing="2" Class="pa-4">
                    <MudText Typo="Typo.body2">
                        Configurez votre serveur SMTP pour envoyer factures et notifications :
                    </MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Paramètres → <strong>Notifications → Configuration Email</strong>
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Renseignez votre serveur SMTP (Gmail, Outlook, etc.)
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Port : 587 (TLS) ou 465 (SSL)
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Email et mot de passe d'application
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Testez la configuration avant de sauvegarder
                        </MudListItem>
                    </MudList>

                    <MudCard Elevation="0" Style="background: #eff6ff; border: 1px solid #3b82f6; border-radius: 8px;" Class="mt-2">
                        <MudCardContent>
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.body2" Style="font-weight: 600;">
                                    Exemple configuration Gmail :
                                </MudText>
                                <MudText Typo="Typo.caption">
                                    Serveur : smtp.gmail.com<br/>
                                    Port : 587<br/>
                                    Sécurité : TLS<br/>
                                    ⚠️ Utilisez un mot de passe d'application, pas votre mot de passe Gmail
                                </MudText>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudStack>
            </ChildContent>
        </MudExpansionPanel>

        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.QuestionMark" Color="Color.Primary" />
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                        Comment personnaliser mes factures ?
                    </MudText>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudStack Spacing="2" Class="pa-4">
                    <MudText Typo="Typo.body2">
                        Personnalisez l'apparence de vos factures :
                    </MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Image">
                            <strong>Logo :</strong> Paramètres → Général → Télécharger logo
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Business">
                            <strong>Informations société :</strong> Nom, SIRET, TVA, adresse
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Palette">
                            <strong>Couleur :</strong> Paramètres → Facturation → Couleur principale
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Numbers">
                            <strong>Numérotation :</strong> Définissez le format (FA-YYYY-XXX)
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Description">
                            <strong>Mentions légales :</strong> Conditions de paiement, CGV
                        </MudListItem>
                    </MudList>

                    <MudAlert Severity="Severity.Success" Dense="true" Class="mt-2">
                        ✨ Prévisualisez vos modifications en temps réel avant de sauvegarder.
                    </MudAlert>
                </MudStack>
            </ChildContent>
        </MudExpansionPanel>

        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.QuestionMark" Color="Color.Primary" />
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                        Comment gérer mon abonnement ?
                    </MudText>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudStack Spacing="2" Class="pa-4">
                    <MudText Typo="Typo.body2">
                        Gérez votre abonnement et votre facturation :
                    </MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Paramètres → <strong>Abonnement & Facturation</strong>
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Consultez votre plan actuel et les limites
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Changez de plan (upgrade/downgrade)
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Mettez à jour votre moyen de paiement
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">
                            Téléchargez vos factures d'abonnement
                        </MudListItem>
                    </MudList>

                    <MudSimpleTable Dense="true" Style="border: 1px solid #e2e8f0; border-radius: 8px;" Class="mt-3">
                        <thead>
                            <tr>
                                <th>Plan</th>
                                <th>Prix/mois</th>
                                <th>Livraisons</th>
                                <th>Utilisateurs</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Free</td>
                                <td>Gratuit</td>
                                <td>50</td>
                                <td>2</td>
                            </tr>
                            <tr>
                                <td>Starter</td>
                                <td>29€</td>
                                <td>500</td>
                                <td>5</td>
                            </tr>
                            <tr>
                                <td>Business</td>
                                <td>99€</td>
                                <td>2000</td>
                                <td>15</td>
                            </tr>
                            <tr>
                                <td>Enterprise</td>
                                <td>249€</td>
                                <td>Illimité</td>
                                <td>Illimité</td>
                            </tr>
                        </tbody>
                    </MudSimpleTable>

                    <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                        💡 Tous les plans incluent : support email, mises à jour automatiques, sauvegardes quotidiennes.
                    </MudAlert>
                </MudStack>
            </ChildContent>
        </MudExpansionPanel>

        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.QuestionMark" Color="Color.Primary" />
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                        Comment sécuriser mon compte avec la 2FA ?
                    </MudText>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudStack Spacing="2" Class="pa-4">
                    <MudText Typo="Typo.body2">
                        L'authentification à deux facteurs (2FA) renforce la sécurité :
                    </MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                            <strong>Étape 1 :</strong> Mon profil → Sécurité → Activer 2FA
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                            <strong>Étape 2 :</strong> Scannez le QR code avec une app (Google Authenticator, Authy)
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                            <strong>Étape 3 :</strong> Entrez le code à 6 chiffres pour confirmer
                        </MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                            <strong>Étape 4 :</strong> Sauvegardez les codes de récupération
                        </MudListItem>
                    </MudList>

                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">
                        ⚠️ <strong>Important :</strong> Conservez précieusement vos codes de récupération. 
                        Ils vous permettront d'accéder à votre compte si vous perdez votre téléphone.
                    </MudAlert>

                    <MudCard Elevation="0" Style="background: #d1fae5; border: 1px solid #10b981; border-radius: 8px;" Class="mt-2">
                        <MudCardContent>
                            <MudText Typo="Typo.body2">
                                <strong>✅ Recommandé pour :</strong>
                            </MudText>
                            <MudText Typo="Typo.caption">
                                • Administrateurs • Comptables • Toute personne ayant accès aux données financières
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </MudStack>
            </ChildContent>
        </MudExpansionPanel>
    </MudExpansionPanels>

    <MudCard Elevation="0" Style="background: #fef3c7; border: 1px solid #f59e0b; border-radius: 8px;">
        <MudCardContent>
            <MudStack Spacing="2">
                <MudText Typo="Typo.h6" Style="font-weight: 600;">
                    🔒 Sécurité & Bonnes Pratiques
                </MudText>
                <MudList T="string" Dense="true">
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                        Activez la 2FA pour tous les comptes administrateurs
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                        Utilisez des mots de passe forts et uniques
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                        Attribuez le niveau d'accès minimum nécessaire à chaque utilisateur
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                        Désactivez rapidement les comptes des utilisateurs qui quittent l'entreprise
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                        Consultez régulièrement les logs d'audit dans Paramètres → Activité
                    </MudListItem>
                </MudList>
            </MudStack>
        </MudCardContent>
    </MudCard>
</MudStack>


@page "/forgot-password"
@using DropFlow.Shared.Auth
@using DropFlow.WebApp.Interfaces
@inject IAuthService AuthService
@inject ISnackbar Snackbar

<PageTitle>Mot de passe oublié - DropFlow</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="min-height: 100vh;">
    <MudPaper Elevation="4" Class="pa-8" Style="width: 100%; max-width: 450px; border-radius: 16px;">
        
        @if (!_emailSent)
        {
            <!-- Formulaire de demande -->
            <div>
                <!-- Logo et titre -->
                <div class="d-flex flex-column align-center mb-6">
                    <MudIcon Icon="@Icons.Material.Filled.LockReset" 
                             Color="Color.Primary" 
                             Size="Size.Large" 
                             Style="font-size: 4rem;" />
                    <MudText Typo="Typo.h5" Class="mt-2" Style="font-weight: 600;">
                        Mot de passe oublié
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1 text-center">
                        Entrez votre email pour recevoir un lien de réinitialisation
                    </MudText>
                </div>

                <!-- Formulaire -->
                <EditForm Model="@_forgotPasswordDto" OnValidSubmit="HandleForgotPassword">
                    <DataAnnotationsValidator />

                    <!-- Email -->
                    <MudTextField @bind-Value="_forgotPasswordDto.Email"
                                  Label="Email"
                                  Variant="Variant.Outlined"
                                  InputType="InputType.Email"
                                  Required="true"
                                  RequiredError="L'email est requis"
                                  Validation="@(new Func<string, string>(ValidateEmail))"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Email"
                                  Class="mb-4" />

                    <!-- Message d'erreur -->
                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true" CloseIcon="@Icons.Material.Filled.Close" CloseIconClicked="() => _errorMessage = string.Empty">
                            @_errorMessage
                        </MudAlert>
                    }

                    <!-- Bouton envoi -->
                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               Size="Size.Large"
                               Disabled="@_isLoading"
                               Class="mb-4"
                               Style="border-radius: 8px; text-transform: none; font-weight: 600; height: 48px;">
                        @if (_isLoading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>Envoi en cours...</span>
                        }
                        else
                        {
                            <span>Envoyer le lien</span>
                        }
                    </MudButton>
                </EditForm>

                <!-- Divider -->
                <MudDivider Class="my-4" />

                <!-- Lien retour -->
                <div class="d-flex justify-center">
                    <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small" Class="mr-1" />
                    <MudLink Href="/login" Typo="Typo.body2" Style="font-weight: 600;">
                        Retour à la connexion
                    </MudLink>
                </div>
            </div>
        }
        else
        {
            <!-- Confirmation d'envoi -->
            <div class="d-flex flex-column align-center text-center">
                <MudIcon Icon="@Icons.Material.Filled.MarkEmailRead" 
                         Color="Color.Success" 
                         Size="Size.Large" 
                         Style="font-size: 5rem;" 
                         Class="mb-4" />
                
                <MudText Typo="Typo.h5" Style="font-weight: 600;" Class="mb-2">
                    Email envoyé !
                </MudText>
                
                <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4">
                    Si un compte existe avec l'adresse <strong>@_forgotPasswordDto.Email</strong>, 
                    vous recevrez un email avec un lien de réinitialisation dans quelques minutes.
                </MudText>

                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4" Style="text-align: left;">
                    <MudText Typo="Typo.body2">
                        💡 <strong>Conseil :</strong> Vérifiez vos spams si vous ne voyez pas l'email. 
                        Le lien expire dans 24 heures.
                    </MudText>
                </MudAlert>

                <MudStack Row="true" Spacing="2" Class="mt-4">
                    <MudButton Variant="Variant.Outlined" 
                               Color="Color.Primary"
                               Href="/login"
                               StartIcon="@Icons.Material.Filled.Login">
                        Retour à la connexion
                    </MudButton>
                    
                    <MudButton Variant="Variant.Text" 
                               Color="Color.Primary"
                               OnClick="ResetForm"
                               StartIcon="@Icons.Material.Filled.Refresh">
                        Renvoyer
                    </MudButton>
                </MudStack>
            </div>
        }
        
    </MudPaper>
</MudContainer>

@code {
    private readonly ForgotPasswordDto _forgotPasswordDto = new(string.Empty);
    private bool _isLoading;
    private bool _emailSent;
    private string _errorMessage = string.Empty;

    private static string ValidateEmail(string email)
    {
        if (string.IsNullOrWhiteSpace(email))
            return "L'email est requis";

        return !email.Contains("@") ? "Format d'email invalide" : string.Empty;
    }

    private async Task HandleForgotPassword()
    {
        _isLoading = true;
        _errorMessage = string.Empty;

        try
        {
            var response = await AuthService.ForgotPasswordAsync(_forgotPasswordDto);

            if (response.Success)
            {
                _emailSent = true;
                Snackbar.Add("Email de réinitialisation envoyé avec succès", Severity.Success);
            }
            else
            {
                _errorMessage = response.Message!;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Une erreur s'est produite : {ex.Message}";
            Console.WriteLine($"Erreur forgot password: {ex}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ResetForm()
    {
        _emailSent = false;
        _errorMessage = string.Empty;
        _forgotPasswordDto.Email = string.Empty;
    }
}

@page "/livraisons/{Id:int}"
@using DropFlow.Domain.Enums
@using DropFlow.Shared.Deliveries
@using DropFlow.WebApp.Models.Auth
@using Humanizer
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>Livraison @(_delivery?.Reference ?? "…") - DropFlow</PageTitle>

<AuthorizeView Roles="@Roles.ManagerOrAdmin" Context="auth">
    <Authorized>
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 mb-8">

            @if (_loading)
            {
                <MudStack AlignItems="AlignItems.Center" Class="py-16">
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large"/>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-3">Chargement...</MudText>
                </MudStack>
            }
            else if (_delivery == null)
            {
                <MudStack AlignItems="AlignItems.Center" Class="py-16" Spacing="3">
                    <MudIcon Icon="@Icons.Material.Outlined.SearchOff" Style="font-size:56px; color:#D1D5DB;"/>
                    <MudText Typo="Typo.h6" Color="Color.Secondary">Livraison introuvable</MudText>
                    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Outlined.ArrowBack"
                               OnClick="GoBack">Retour aux livraisons</MudButton>
                </MudStack>
            }
            else
            {
                <!-- En-tête -->
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start" Class="mb-4">
                    <div>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
                            <MudText Typo="Typo.h5" Class="font-weight-bold" Style="color:#1F2937;">
                                @_delivery.Reference
                            </MudText>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                     Style="@GetStatusStyle(_delivery.Status)">
                                @_delivery.Status.Humanize()
                            </MudChip>
                            @if (_delivery.WithAssembly)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined"
                                         Icon="@Icons.Material.Outlined.Build">
                                    Montage
                                </MudChip>
                            }
                        </MudStack>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            #@_delivery.SequentialNumber · Créée le @_delivery.CreatedDate.ToString("dd/MM/yyyy à HH:mm")
                            @if (!string.IsNullOrEmpty(_delivery.CreatedBy))
                            {
                                <text> par @_delivery.CreatedBy</text>
                            }
                        </MudText>
                    </div>
                    <MudStack Row="true" Spacing="2">
                        <MudButton Variant="Variant.Outlined"
                                   StartIcon="@Icons.Material.Outlined.Edit"
                                   Color="Color.Primary"
                                   OnClick="GoToEdit">
                            Modifier
                        </MudButton>
                        <MudButton Variant="Variant.Text"
                                   StartIcon="@Icons.Material.Outlined.ArrowBack"
                                   OnClick="GoBack">
                            Retour
                        </MudButton>
                    </MudStack>
                </MudStack>

                <MudGrid Spacing="3">

                    <!-- Colonne gauche -->
                    <MudItem xs="12" md="6">

                        <!-- Client -->
                        <MudPaper Elevation="0" Class="pa-4 mb-3 rounded-lg" Style="border:1px solid #E5E7EB;">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                                <MudIcon Icon="@Icons.Material.Outlined.Person" Color="Color.Primary"/>
                                <MudText Typo="Typo.subtitle1" Class="font-weight-bold">Client</MudText>
                            </MudStack>

                            <MudStack Spacing="2">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudAvatar Size="Size.Medium" Color="Color.Primary" Variant="Variant.Filled"
                                               Style="font-size:16px; font-weight:600;">
                                        @_delivery.ClientName.FirstOrDefault()
                                    </MudAvatar>
                                    <div>
                                        <MudText Typo="Typo.body1" Class="font-weight-bold">@_delivery.ClientName</MudText>
                                        @if (!string.IsNullOrEmpty(_delivery.ClientEmail))
                                        {
                                            <MudLink Href="@($"mailto:{_delivery.ClientEmail}")" Typo="Typo.caption">
                                                @_delivery.ClientEmail
                                            </MudLink>
                                        }
                                    </div>
                                </MudStack>

                                @if (!string.IsNullOrEmpty(_delivery.ClientPhone))
                                {
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Outlined.Phone" Size="Size.Small" Color="Color.Secondary"/>
                                        <MudLink Href="@($"tel:{_delivery.ClientPhone}")" Typo="Typo.body2">
                                            @_delivery.ClientPhone
                                        </MudLink>
                                    </MudStack>
                                }

                                <MudDivider/>

                                <MudStack Row="true" AlignItems="AlignItems.Start" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Outlined.LocationOn" Size="Size.Small" Color="Color.Secondary" Class="mt-1"/>
                                    <div>
                                        <MudText Typo="Typo.body2">@_delivery.Address</MudText>
                                        @if (!string.IsNullOrEmpty(_delivery.AddressComplement))
                                        {
                                            <MudText Typo="Typo.body2">@_delivery.AddressComplement</MudText>
                                        }
                                        <MudText Typo="Typo.body2">@_delivery.ZipCode @_delivery.City</MudText>
                                    </div>
                                </MudStack>
                            </MudStack>
                        </MudPaper>

                        <!-- Articles -->
                        <MudPaper Elevation="0" Class="pa-4 rounded-lg" Style="border:1px solid #E5E7EB;">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                                <MudIcon Icon="@Icons.Material.Outlined.Inventory2" Color="Color.Primary"/>
                                <MudText Typo="Typo.subtitle1" Class="font-weight-bold">
                                    Articles
                                </MudText>
                                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">
                                    @_delivery.TotalPackages colis
                                </MudChip>
                            </MudStack>

                            @if (_delivery.Items?.Any() == true)
                            {
                                <MudTable Items="_delivery.Items" Dense="true" Hover="true" Elevation="0"
                                          Style="border:1px solid #F3F4F6; border-radius:6px; overflow:hidden;">
                                    <HeaderContent>
                                        <MudTh>Désignation</MudTh>
                                        <MudTh Style="text-align:center;">Qté</MudTh>
                                        <MudTh>Réf.</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd>
                                            <MudText Typo="Typo.body2" Class="font-weight-medium">@context.Designation</MudText>
                                            @if (!string.IsNullOrEmpty(context.Information))
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Information</MudText>
                                            }
                                        </MudTd>
                                        <MudTd Style="text-align:center;">
                                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                                                @context.Quantity
                                            </MudChip>
                                        </MudTd>
                                        <MudTd>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @(string.IsNullOrEmpty(context.Reference) ? "—" : context.Reference)
                                            </MudText>
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Aucun article renseigné</MudText>
                            }
                        </MudPaper>

                    </MudItem>

                    <!-- Colonne droite -->
                    <MudItem xs="12" md="6">

                        <!-- Détails livraison -->
                        <MudPaper Elevation="0" Class="pa-4 mb-3 rounded-lg" Style="border:1px solid #E5E7EB;">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                                <MudIcon Icon="@Icons.Material.Outlined.LocalShipping" Color="Color.Primary"/>
                                <MudText Typo="Typo.subtitle1" Class="font-weight-bold">Détails</MudText>
                            </MudStack>

                            <MudStack Spacing="2">
                                <DetailRow Icon="@Icons.Material.Outlined.Store" Label="Enseigne" Value="@_delivery.StoreName"/>

                                @if (!string.IsNullOrEmpty(_delivery.FileNumber))
                                {
                                    <DetailRow Icon="@Icons.Material.Outlined.Tag" Label="N° dossier" Value="@_delivery.FileNumber"/>
                                }

                                @if (_delivery.ScheduledDate.HasValue)
                                {
                                    <DetailRow Icon="@Icons.Material.Outlined.CalendarToday"
                                               Label="Date prévue"
                                               Value="@_delivery.ScheduledDate.Value.ToString("dddd dd MMMM yyyy")"/>
                                }

                                @if (_delivery.TimeSlot != null)
                                {
                                    <DetailRow Icon="@Icons.Material.Outlined.Schedule"
                                               Label="Créneau"
                                               Value="@($"{_delivery.TimeSlot.Name} ({_delivery.TimeSlot.StartTime:hh\\:mm} – {_delivery.TimeSlot.EndTime:hh\\:mm})")"/>
                                }

                                @if (_delivery.EstimatedDurationMinutes.HasValue)
                                {
                                    <DetailRow Icon="@Icons.Material.Outlined.Timer"
                                               Label="Durée estimée"
                                               Value="@($"{_delivery.EstimatedDurationMinutes} min")"/>
                                }

                                <MudDivider/>

                                <MudStack Row="true" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Prix total</MudText>
                                    <MudText Typo="Typo.body1" Style="font-weight:700; color:#059669;">
                                        @_delivery.Price.ToString("C")
                                    </MudText>
                                </MudStack>

                                @if (_delivery.ClientPaymentAmount.HasValue && _delivery.ClientPaymentAmount > 0)
                                {
                                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Règlement client</MudText>
                                        <MudText Typo="Typo.body2">@_delivery.ClientPaymentAmount.Value.ToString("C")</MudText>
                                    </MudStack>
                                }

                                @if (_delivery.StorePaymentAmount.HasValue && _delivery.StorePaymentAmount > 0)
                                {
                                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Règlement enseigne</MudText>
                                        <MudText Typo="Typo.body2">@_delivery.StorePaymentAmount.Value.ToString("C")</MudText>
                                    </MudStack>
                                }
                            </MudStack>
                        </MudPaper>

                        <!-- Tournée -->
                        <MudPaper Elevation="0" Class="pa-4 mb-3 rounded-lg"
                                  Style="@(_delivery.RouteId.HasValue ? "border:1px solid #BFDBFE; background:#EFF6FF;" : "border:1px solid #E5E7EB;")">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                                <MudIcon Icon="@Icons.Material.Outlined.Route"
                                         Style="@(_delivery.RouteId.HasValue ? "color:#1D4ED8;" : "color:#9CA3AF;")"/>
                                <MudText Typo="Typo.subtitle1" Class="font-weight-bold">Tournée</MudText>
                            </MudStack>

                            @if (_delivery.RouteId.HasValue)
                            {
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                    <MudText Typo="Typo.body2" Style="color:#1D4ED8; font-weight:600;">
                                        @(_delivery.RouteReference ?? $"#{_delivery.RouteId}")
                                    </MudText>
                                    <MudButton Variant="Variant.Text" Size="Size.Small"
                                               EndIcon="@Icons.Material.Outlined.OpenInNew"
                                               OnClick="@(() => NavigationManager.NavigateTo($"/tournees/{_delivery.RouteId}"))">
                                        Voir la tournée
                                    </MudButton>
                                </MudStack>

                                @if (_delivery.EstimatedArrivalTime.HasValue)
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        Arrivée estimée : @_delivery.EstimatedArrivalTime.Value.ToString(@"hh\:mm")
                                    </MudText>
                                }
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Non assignée à une tournée</MudText>
                            }
                        </MudPaper>

                        <!-- Notes -->
                        @if (!string.IsNullOrWhiteSpace(_delivery.DeliveryNotes) || !string.IsNullOrWhiteSpace(_delivery.InternalNotes))
                        {
                            <MudPaper Elevation="0" Class="pa-4 rounded-lg" Style="border:1px solid #E5E7EB;">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                                    <MudIcon Icon="@Icons.Material.Outlined.Notes" Color="Color.Primary"/>
                                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold">Notes</MudText>
                                </MudStack>

                                @if (!string.IsNullOrWhiteSpace(_delivery.DeliveryNotes))
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Livreur</MudText>
                                    <MudPaper Elevation="0" Class="pa-3 mb-2 rounded"
                                              Style="background:#F9FAFB; border:1px solid #F3F4F6;">
                                        <MudText Typo="Typo.body2">@_delivery.DeliveryNotes</MudText>
                                    </MudPaper>
                                }

                                @if (!string.IsNullOrWhiteSpace(_delivery.InternalNotes))
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Interne</MudText>
                                    <MudPaper Elevation="0" Class="pa-3 rounded"
                                              Style="background:#FFFBEB; border:1px solid #FEF3C7;">
                                        <MudText Typo="Typo.body2">@_delivery.InternalNotes</MudText>
                                    </MudPaper>
                                }
                            </MudPaper>
                        }

                    </MudItem>

                </MudGrid>
            }

        </MudContainer>
    </Authorized>
    <NotAuthorized>
        <RedirectToAccessDenied/>
    </NotAuthorized>
</AuthorizeView>

@* Composant utilitaire local pour les lignes de détail *@
@code {
    private RenderFragment<(string Icon, string Label, string Value)> DetailRow =>
        item => __builder =>
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudIcon Icon="@item.Icon" Size="Size.Small" Color="Color.Secondary"/>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@item.Label</MudText>
                </MudStack>
                <MudText Typo="Typo.body2" Class="font-weight-medium">@item.Value</MudText>
            </MudStack>
        };
}

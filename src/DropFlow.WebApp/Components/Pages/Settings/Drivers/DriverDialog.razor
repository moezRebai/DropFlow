@using DropFlow.Shared.Drivers
@using DropFlow.Shared.Profil
@using DropFlow.WebApp.Interfaces
@inject IDriverService DriverService
@inject IUserManagementService UserManagementService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        @if (_loadingUsers)
        {
            <MudStack AlignItems="AlignItems.Center" Class="py-4">
                <MudProgressCircular Indeterminate="true" Color="Color.Info"/>
                <MudText Typo="Typo.body2">Chargement...</MudText>
            </MudStack>
        }
        else
        {
            <MudForm @ref="_form" @bind-IsValid="@_isValid">
                <MudStack Spacing="3">

                    <!-- Utilisateur (création uniquement) -->
                    @if (!_isEditMode)
                    {
                        <MudSelect T="string"
                                   @bind-Value="_model.UserId"
                                   Label="Utilisateur"
                                   Variant="Variant.Outlined"
                                   Required="true"
                                   RequiredError="L'utilisateur est obligatoire"
                                   AdornmentIcon="@Icons.Material.Filled.Person"
                                   Adornment="Adornment.Start"
                                   HelperText="Sélectionnez l'utilisateur à associer au livreur">
                            @foreach (var user in _availableUsers)
                            {
                                <MudSelectItem Value="@user.Id">
                                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                        <MudAvatar Size="Size.Small" Color="Color.Primary">
                                            @user.FirstName?.Substring(0, 1)@user.LastName?.Substring(0, 1)
                                        </MudAvatar>
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.body2" Style="font-weight: 500;">
                                                @user.FirstName @user.LastName
                                            </MudText>
                                            <MudText Typo="Typo.caption" Style="color: #94A3B8;">
                                                @user.Email
                                            </MudText>
                                        </MudStack>
                                    </MudStack>
                                </MudSelectItem>
                            }
                        </MudSelect>
                        
                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                            <MudText Typo="Typo.caption">
                                ℹ️ Le nom, prénom et coordonnées seront récupérés automatiquement depuis l'utilisateur sélectionné.
                            </MudText>
                        </MudAlert>
                    }
                    else
                    {
                        <!-- Affichage readonly en mode édition -->
                        <MudTextField Value="@_existingDriverDisplay"
                                      Label="Utilisateur"
                                      Variant="Variant.Outlined"
                                      ReadOnly="true"
                                      AdornmentIcon="@Icons.Material.Filled.Person"
                                      Adornment="Adornment.Start"
                                      HelperText="L'utilisateur associé ne peut pas être modifié"/>
                    }

                    <MudDivider Class="my-2"/>

                    <MudText Typo="Typo.subtitle2" Style="color: #64748b;">
                        <MudIcon Icon="@Icons.Material.Filled.Badge" Size="Size.Small" Class="mr-1"/>
                        Informations permis (optionnel)
                    </MudText>

                    <!-- Numéro de permis -->
                    <MudTextField @bind-Value="_model.LicenseNumber"
                                  Label="Numéro de permis"
                                  Variant="Variant.Outlined"
                                  MaxLength="50"
                                  Counter="50"
                                  Placeholder="Ex: 123456789012"
                                  AdornmentIcon="@Icons.Material.Filled.CreditCard"
                                  Adornment="Adornment.Start"
                                  HelperText="Numéro du permis de conduire (optionnel)"/>

                    <!-- Date d'expiration du permis -->
                    @* <MudDatePicker @bind-Date="_model.LicenseExpiryDate" *@
                    @*                Label="Date d'expiration" *@
                    @*                Variant="Variant.Outlined" *@
                    @*                Editable="true" *@
                    @*                DateFormat="dd/MM/yyyy" *@
                    @*                Placeholder="jj/mm/aaaa" *@
                    @*                AdornmentIcon="@Icons.Material.Filled.CalendarMonth" *@
                    @*                Adornment="Adornment.Start" *@
                    @*                MinDate="DateTime.Today" *@
                    @*                HelperText="Date d'expiration du permis (optionnel)"> *@
                    @*     <PickerActions> *@
                    @*         <MudButton Class="mr-auto align-self-start" OnClick="@(() => _model.LicenseExpiryDate = null)">Effacer</MudButton> *@
                    @*         <MudButton OnClick="@(() => ((MudDatePicker)context).Close(false))">Annuler</MudButton> *@
                    @*         <MudButton Color="Color.Primary" OnClick="@(() => ((MudDatePicker)context).Close())">Ok</MudButton> *@
                    @*     </PickerActions> *@
                    @* </MudDatePicker> *@

                    @if (_model.LicenseExpiryDate.HasValue)
                    {
                        var daysUntilExpiry = (_model.LicenseExpiryDate.Value - DateTime.Now).Days;
                        if (daysUntilExpiry <= 30)
                        {
                            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">
                                <MudText Typo="Typo.caption">
                                    ⚠️ Le permis expire dans @daysUntilExpiry jours (@_model.LicenseExpiryDate.Value.ToString("dd/MM/yyyy"))
                                </MudText>
                            </MudAlert>
                        }
                    }

                    <MudDivider Class="my-2"/>

                    <MudText Typo="Typo.subtitle2" Style="color: #64748b;">
                        <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Small" Class="mr-1"/>
                        Véhicule (optionnel)
                    </MudText>

                    <!-- Type de véhicule -->
                    <MudTextField @bind-Value="_model.VehicleType"
                                  Label="Type de véhicule"
                                  Variant="Variant.Outlined"
                                  MaxLength="50"
                                  Counter="50"
                                  Placeholder="Ex: Fourgon, Camionnette, Utilitaire..."
                                  AdornmentIcon="@Icons.Material.Filled.LocalShipping"
                                  Adornment="Adornment.Start"
                                  HelperText="Type de véhicule que peut conduire le livreur (optionnel)"/>

                </MudStack>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel"
                   Disabled="@(_saving || _loadingUsers)">
            Annuler
        </MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Info"
                   OnClick="Save"
                   Disabled="@(!_isValid || _saving || _loadingUsers)">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2"/>
                <span>Enregistrement...</span>
            }
            else
            {
                <span>Enregistrer</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public int? DriverId { get; set; }
    [Parameter] public DriverDto? ExistingDriver { get; set; }

    private MudForm _form = default!;
    private bool _isValid;
    private bool _saving;
    private bool _isEditMode;
    private bool _loadingUsers = true;

    private DriverModel _model = new();
    private List<UserProfileDto> _availableUsers = [];
    private string _existingDriverDisplay = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _isEditMode = DriverId.HasValue;

        // Charger les utilisateurs disponibles (seulement en mode création)
        if (!_isEditMode)
        {
            await LoadAvailableUsers();
        }
        else
        {
            _loadingUsers = false;
        }

        if (_isEditMode && ExistingDriver != null)
        {
            _model = new DriverModel
            {
                UserId = ExistingDriver.UserId,
                LicenseNumber = ExistingDriver.LicenseNumber,
                LicenseExpiryDate = ExistingDriver.LicenseExpiryDate
            };
            _existingDriverDisplay = $"{ExistingDriver.FullName} ({ExistingDriver.Email})";
        }
    }

    private async Task LoadAvailableUsers()
    {
        _loadingUsers = true;
        try
        {
            var allUsers = await UserManagementService.GetUsersAsync(
                includeDeactivated: false,
                includeDeleted: false);

            // Filtrer les utilisateurs qui n'ont pas encore de Driver
            var existingDrivers = await DriverService.GetAllAsync();
            var usersWithDrivers = existingDrivers.Select(d => d.UserId).ToHashSet();
            _availableUsers = allUsers.Where(u => !usersWithDrivers.Contains(u.Id)).ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur lors du chargement des utilisateurs : {ex.Message}", Severity.Error);
        }
        finally
        {
            _loadingUsers = false;
        }
    }

    private async Task Save()
    {
        await _form.Validate();
        if (!_isValid) return;

        // Validation : UserId requis en mode création
        if (!_isEditMode && string.IsNullOrWhiteSpace(_model.UserId))
        {
            Snackbar.Add("Vous devez sélectionner un utilisateur", Severity.Error);
            return;
        }

        _saving = true;

        try
        {
            if (_isEditMode && DriverId.HasValue)
            {
                // Modification
                var dto = new UpdateDriverDto
                {
                    LicenseNumber = _model.LicenseNumber,
                    LicenseExpiryDate = _model.LicenseExpiryDate,
                    VehicleType = _model.VehicleType
                };

                var result = await DriverService.UpdateAsync(DriverId.Value, dto);

                if (result.Succeeded)
                {
                    Snackbar.Add("Livreur modifié avec succès", Severity.Success);
                    MudDialog.Close(DialogResult.Ok(true));
                }
                else
                {
                    var errorMessage = result.Errors?.FirstOrDefault() ?? "Erreur lors de la modification";
                    Snackbar.Add(errorMessage, Severity.Error);
                }
            }
            else
            {
                // Création
                var dto = new CreateDriverDto
                {
                    UserId = _model.UserId,
                    LicenseNumber = _model.LicenseNumber,
                    LicenseExpiryDate = _model.LicenseExpiryDate,
                    VehicleType = _model.VehicleType
                };

                var result = await DriverService.CreateAsync(dto);

                if (result.Succeeded)
                {
                    Snackbar.Add("Livreur créé avec succès", Severity.Success);
                    MudDialog.Close(DialogResult.Ok(true));
                }
                else
                {
                    var errorMessage = result.Errors?.FirstOrDefault() ?? "Erreur lors de la création";
                    Snackbar.Add(errorMessage, Severity.Error);
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur : {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    // Model interne
    private class DriverModel
    {
        public string UserId { get; set; } = string.Empty;
        public string? LicenseNumber { get; set; }
        public DateTime? LicenseExpiryDate { get; set; }
        public string? VehicleType { get; set; }
    }
}

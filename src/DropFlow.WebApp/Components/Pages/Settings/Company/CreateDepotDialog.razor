@using DropFlow.Shared.Tenants.Depots
@using DropFlow.WebApp.Interfaces
@inject ITenantManagementService TenantService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="@_formValid">
            <MudGrid>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.Name" 
                                Label="Nom du dépôt"
                                Variant="Variant.Outlined"
                                Margin="Margin.Dense"
                                Required="true"
                                MaxLength="100"
                                HelperText="Ex: Dépôt Principal Paris" />
                </MudItem>
                
                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.FullAddress" 
                                Label="Adresse complète"
                                Variant="Variant.Outlined"
                                Margin="Margin.Dense"
                                Required="true"
                                MaxLength="500"
                                HelperText="Ex: 123 Rue de l'Entrepôt" />
                </MudItem>
                
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_model.ZipCode" 
                                Label="Code postal"
                                Variant="Variant.Outlined"
                                Margin="Margin.Dense"
                                MaxLength="10"
                                HelperText="Ex: 75015" />
                </MudItem>
                
                <MudItem xs="12" md="8">
                    <MudTextField @bind-Value="_model.City" 
                                  Label="Ville"
                                  Variant="Variant.Outlined"
                                Margin="Margin.Dense"
                                MaxLength="100"
                                HelperText="Ex: Paris" />
                </MudItem>
                
                <MudItem xs="12">
                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.subtitle2" Class="mb-2">
                        Coordonnées GPS (optionnel)
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
                        Pour l'optimisation des tournées. Vous pouvez les obtenir sur Google Maps.
                    </MudText>
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudNumericField @bind-Value="_model.Latitude" 
                                    Label="Latitude"
                                    Variant="Variant.Outlined"
                                    Margin="Margin.Dense"
                                    Min="-90"
                                    Max="90"
                                    Format="F8"
                                    HelperText="Entre -90 et 90" />
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudNumericField @bind-Value="_model.Longitude" 
                                    Label="Longitude"
                                    Variant="Variant.Outlined"
                                    Margin="Margin.Dense"
                                    Min="-180"
                                    Max="180"
                                    Format="F8"
                                    HelperText="Entre -180 et 180" />
                </MudItem>
                
                <MudItem xs="12">
                    <MudDivider Class="my-2" />
                </MudItem>
                
                @if (IsFirstDepot)
                {
                    <MudItem xs="12">
                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                            <MudText Typo="Typo.body2">
                                Ce sera votre premier dépôt et il sera automatiquement défini comme dépôt par défaut.
                            </MudText>
                        </MudAlert>
                    </MudItem>
                }
                else
                {
                    <MudItem xs="12">
                        <MudSwitch @bind-Value="_model.IsDefault" 
                                  Color="Color.Primary"
                                  Label="Définir comme dépôt par défaut" />
                    </MudItem>
                }
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Annuler</MudButton>
        <MudButton Variant="Variant.Filled" 
                  Color="Color.Primary"
                  OnClick="Submit"
                  Disabled="@(!_formValid || _saving)">
            @if (_saving)
            {
                <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2" />
                <span>Création...</span>
            }
            else
            {
                <span>Créer</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = null!;
    
    [Parameter]
    public bool IsFirstDepot { get; set; }

    private MudForm _form = null!;
    private bool _formValid;
    private bool _saving;
    
    private CreateTenantDepotDto _model = new()
    {
        IsActive = true,
        IsDefault = false
    };

    private async Task Submit()
    {
        _saving = true;
        StateHasChanged();

        try
        {
            var result = await TenantService.CreateDepotAsync(_model);

            if (result.Succeeded)
            {
                Snackbar.Add("Dépôt créé avec succès", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add($"Erreur : {result.Message}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur : {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}

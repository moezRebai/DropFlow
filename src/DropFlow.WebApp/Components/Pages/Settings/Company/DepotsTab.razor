@using DropFlow.Shared.Tenants.Depots
@using DropFlow.WebApp.Interfaces
@inject ITenantManagementService TenantService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudGrid>
    @* Actions Bar *@
    <MudItem xs="12">
        <div class="d-flex justify-space-between align-center mb-3">
            <MudText Typo="Typo.h6">
                Vos dépôts de livraison (@Depots.Count)
            </MudText>
            <MudButton Variant="Variant.Filled" 
                      Color="Color.Primary"
                      StartIcon="@Icons.Material.Filled.Add"
                      OnClick="OpenCreateDialog">
                Nouveau dépôt
            </MudButton>
        </div>
    </MudItem>

    @* Depots List *@
    @if (!Depots.Any())
    {
        <MudItem xs="12">
            <MudCard Outlined="true">
                <MudCardContent>
                    <div class="d-flex flex-column align-center justify-center pa-8">
                        <MudIcon Icon="@Icons.Material.Filled.Warehouse" 
                                Size="Size.Large" 
                                Color="Color.Secondary" 
                                Class="mb-4" />
                        <MudText Typo="Typo.h6" Class="mb-2">
                            Aucun dépôt configuré
                        </MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                            Ajoutez votre premier dépôt pour optimiser vos tournées de livraison
                        </MudText>
                        <MudButton Variant="Variant.Filled" 
                                  Color="Color.Primary"
                                  StartIcon="@Icons.Material.Filled.Add"
                                  OnClick="OpenCreateDialog">
                            Créer mon premier dépôt
                        </MudButton>
                    </div>
                </MudCardContent>
            </MudCard>
        </MudItem>
    }
    else
    {
        @foreach (var depot in Depots.OrderByDescending(d => d.IsDefault).ThenBy(d => d.Name))
        {
            <MudItem xs="12" md="6">
                <MudCard Outlined="true" Class="@(depot.IsDefault ? "mud-theme-primary" : "")">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <div class="d-flex align-center justify-space-between">
                                <div class="d-flex align-center gap-2">
                                    <MudIcon Icon="@Icons.Material.Filled.Warehouse" 
                                            Color="@(depot.IsDefault ? Color.Primary : Color.Default)" />
                                    <MudText Typo="Typo.h6">
                                        @depot.Name
                                    </MudText>
                                </div>
                                <div class="d-flex gap-2">
                                    @if (depot.IsDefault)
                                    {
                                        <MudChip T="string" Size="Size.Small" 
                                                Color="Color.Primary"
                                                Icon="@Icons.Material.Filled.Star">
                                            Par défaut
                                        </MudChip>
                                    }
                                    @if (!depot.IsActive)
                                    {
                                        <MudChip T="string" Size="Size.Small" 
                                                Color="Color.Default">
                                            Inactif
                                        </MudChip>
                                    }
                                </div>
                            </div>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body2" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small" Class="mr-1" />
                            @depot.FormattedAddress
                        </MudText>
                        
                        @if (depot.HasGpsCoordinates)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                <MudIcon Icon="@Icons.Material.Filled.GpsFixed" Size="Size.Small" Class="mr-1" />
                                GPS: @depot.Latitude?.ToString("F4"), @depot.Longitude?.ToString("F4")
                            </MudText>
                        }
                    </MudCardContent>
                    <MudCardActions>
                        @if (!depot.IsDefault && Depots.Count > 1)
                        {
                            <MudButton Variant="Variant.Text" 
                                      Color="Color.Primary"
                                      StartIcon="@Icons.Material.Filled.Star"
                                      OnClick="@(() => SetAsDefault(depot.Id))">
                                Définir par défaut
                            </MudButton>
                        }
                        
                        @if (depot.HasGpsCoordinates)
                        {
                            <MudButton Variant="Variant.Text" 
                                      StartIcon="@Icons.Material.Filled.Map"
                                      Href="@depot.GoogleMapsUrl"
                                      Target="_blank">
                                Carte
                            </MudButton>
                        }
                        
                        <MudSpacer />
                        
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                                      Color="Color.Primary"
                                      OnClick="@(() => OpenEditDialog(depot))" />
                        
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                      Color="Color.Error"
                                      OnClick="@(() => DeleteDepot(depot.Id))" />
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    }
</MudGrid>

@code {
    [Parameter, EditorRequired]
    public List<TenantDepotDto> Depots { get; set; } = new();
    
    [Parameter]
    public EventCallback OnDepotsChanged { get; set; }

    private async Task OpenCreateDialog()
    {
        var parameters = new DialogParameters<CreateDepotDialog>
        {
            { x => x.IsFirstDepot, !Depots.Any() }
        };

        var options = new DialogOptions 
        { 
            MaxWidth = MaxWidth.Medium, 
            FullWidth = true,
            CloseButton = true 
        };

        var dialog = await DialogService.ShowAsync<CreateDepotDialog>(
            "Nouveau dépôt", 
            parameters, 
            options);
        
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            await OnDepotsChanged.InvokeAsync();
        }
    }

    private async Task OpenEditDialog(TenantDepotDto depot)
    {
        var parameters = new DialogParameters<EditDepotDialog>
        {
            { x => x.DepotId, depot.Id }
        };

        var options = new DialogOptions 
        { 
            MaxWidth = MaxWidth.Medium, 
            FullWidth = true,
            CloseButton = true 
        };

        var dialog = await DialogService.ShowAsync<EditDepotDialog>(
            "Modifier le dépôt", 
            parameters, 
            options);
        
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            await OnDepotsChanged.InvokeAsync();
        }
    }

    private async Task SetAsDefault(int depotId)
    {
        var result = await TenantService.SetDefaultDepotAsync(depotId);

        if (result.Succeeded)
        {
            Snackbar.Add("Dépôt défini comme par défaut", Severity.Success);
            await OnDepotsChanged.InvokeAsync();
        }
        else
        {
            Snackbar.Add($"Erreur : {result.Message}", Severity.Error);
        }
    }

    private async Task ToggleStatus(int depotId)
    {
        var result = await TenantService.ToggleDepotStatusAsync(depotId);

        if (result.Succeeded)
        {
            Snackbar.Add("Statut du dépôt modifié", Severity.Success);
            await OnDepotsChanged.InvokeAsync();
        }
        else
        {
            Snackbar.Add($"Erreur : {result.Message}", Severity.Error);
        }
    }

    private async Task DeleteDepot(int depotId)
    {
        var depot = Depots.FirstOrDefault(d => d.Id == depotId);
        if (depot == null) return;

        bool? confirm = await DialogService.ShowMessageBox(
            "Confirmer la suppression",
            $"Êtes-vous sûr de vouloir supprimer le dépôt '{depot.Name}' ?",
            yesText: "Supprimer", 
            cancelText: "Annuler");

        if (confirm == true)
        {
            var result = await TenantService.DeleteDepotAsync(depotId);

            if (result.Succeeded)
            {
                Snackbar.Add("Dépôt supprimé", Severity.Success);
                await OnDepotsChanged.InvokeAsync();
            }
            else
            {
                Snackbar.Add($"Erreur : {result.Message}", Severity.Error);
            }
        }
    }
}

@using DropFlow.Shared.UserManagement
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" Model="@_request">
            <MudGrid>
                <!-- Email -->
                <MudItem xs="12">
                    <MudTextField @bind-Value="_request.Email"
                                  Label="Email"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  RequiredError="L'email est requis"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Email"
                                  HelperText="L'utilisateur recevra une invitation par email"
                                  Class="mb-4" />
                </MudItem>

                <!-- Rôle -->
                <MudItem xs="12">
                    <MudSelect @bind-Value="_request.Role"
                               Label="Rôle"
                               Variant="Variant.Outlined"
                               Required="true"
                               RequiredError="Le rôle est requis"
                               AnchorOrigin="Origin.BottomCenter"
                               Adornment="Adornment.Start"
                               AdornmentIcon="@Icons.Material.Filled.Badge">
                        <MudSelectItem Value="@("Manager")">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Primary" Size="Size.Small" />
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.body1">Manager</MudText>
                                    <MudText Typo="Typo.caption" Style="color: #64748b;">
                                        Gestion complète des livraisons et utilisateurs
                                    </MudText>
                                </MudStack>
                            </MudStack>
                        </MudSelectItem>
                        <MudSelectItem Value="@("Livreur")">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Color="Color.Info" Size="Size.Small" />
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.body1">Livreur</MudText>
                                    <MudText Typo="Typo.caption" Style="color: #64748b;">
                                        Effectue les livraisons sur le terrain
                                    </MudText>
                                </MudStack>
                            </MudStack>
                        </MudSelectItem>
                    </MudSelect>
                </MudItem>

                <!-- Info -->
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                        Un email d'invitation sera envoyé à cette adresse. L'utilisateur aura 72 heures pour créer son compte.
                    </MudAlert>
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">
            Annuler
        </MudButton>
        <MudButton OnClick="Submit" 
                   Variant="Variant.Filled" 
                   Color="Color.Primary"
                   Disabled="@_isSubmitting">
            @if (_isSubmitting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Envoi en cours...</span>
            }
            else
            {
                <span>Envoyer l'invitation</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance  MudDialog { get; set; } = null!;
    [Parameter] public EventCallback OnUserInvited { get; set; }

    private MudForm? _form;
    private bool _isSubmitting;
    private readonly InviteUserDto _request = new() { Role = "Livreur" };

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task Submit()
    {
        await _form!.Validate();
        if (!_form.IsValid)
        {
            Snackbar.Add("Veuillez corriger les erreurs", Severity.Warning);
            return;
        }

        _isSubmitting = true;

        try
        {
            // Retourner la requête au parent
            MudDialog.Close(DialogResult.Ok(_request));
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur Submit InviteUserDialog: {ex.Message}");
            Snackbar.Add("Erreur lors de l'envoi de l'invitation", Severity.Error);
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}

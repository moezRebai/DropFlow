@using DropFlow.Shared.TimeSlots
@using DropFlow.WebApp.Interfaces
@inject ITimeSlotService TimeSlotService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="@_isValid">
            <MudStack Spacing="3">
                
                <!-- Nom du créneau -->
                <MudTextField @bind-Value="_model.Name"
                              Label="Nom du créneau"
                              Variant="Variant.Outlined"
                              Required="true"
                              RequiredError="Le nom est obligatoire"
                              Placeholder="Ex: Matin, Après-midi, Soir..."
                              MaxLength="50"
                              Counter="50"
                              Immediate="true"
                              HelperText="Nom affiché au client (ex: 'Livraison Matin')"/>

                <!-- Heure de début -->
                <MudTimePicker @bind-Time="_model.StartTime"
                               Label="Heure de début"
                               Variant="Variant.Outlined"
                               Required="true"
                               RequiredError="L'heure de début est obligatoire"
                               AmPm="false"
                               TimeFormat="HH:mm"
                               HelperText="Début du créneau (ex: 08:00)"/>

                <!-- Heure de fin -->
                <MudTimePicker @bind-Time="_model.EndTime"
                               Label="Heure de fin"
                               Variant="Variant.Outlined"
                               Required="true"
                               RequiredError="L'heure de fin est obligatoire"
                               AmPm="false"
                               TimeFormat="HH:mm"
                               HelperText="Fin du créneau (ex: 12:00)"/>

                <!-- Aperçu -->
                @if (!string.IsNullOrWhiteSpace(_model.Name) && _model.StartTime.HasValue && _model.EndTime.HasValue)
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                        <MudText Typo="Typo.body2">
                            <strong>Aperçu :</strong> @_model.Name (@_model.StartTime.Value.ToString(@"hh\:mm") - @_model.EndTime.Value.ToString(@"hh\:mm"))
                        </MudText>
                    </MudAlert>
                }

            </MudStack>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" 
                   Disabled="_saving">
            Annuler
        </MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Tertiary"
                   OnClick="Save"
                   Disabled="@(!_isValid || _saving)">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2"/>
                <span>Enregistrement...</span>
            }
            else
            {
                <span>Enregistrer</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public int? TimeSlotId { get; set; }

    private MudForm _form = default!;
    private bool _isValid;
    private bool _saving;
    private TimeSlotModel _model = new();

    protected override async Task OnInitializedAsync()
    {
        if (TimeSlotId.HasValue)
        {
            await LoadTimeSlot();
        }
        else
        {
            // Valeurs par défaut pour création
            _model.StartTime = new TimeSpan(8, 0, 0);
            _model.EndTime = new TimeSpan(12, 0, 0);
        }
    }

    private async Task LoadTimeSlot()
    {
        try
        {
            var timeSlot = await TimeSlotService.GetByIdAsync(TimeSlotId!.Value);
            if (timeSlot != null)
            {
                _model = new TimeSlotModel
                {
                    Name = timeSlot.Name,
                    StartTime = timeSlot.StartTime,
                    EndTime = timeSlot.EndTime
                };
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur lors du chargement : {ex.Message}", Severity.Error);
        }
    }

    private async Task Save()
    {
        await _form.Validate();
        if (!_isValid) return;

        // Validation : EndTime > StartTime
        if (_model.EndTime <= _model.StartTime)
        {
            Snackbar.Add("L'heure de fin doit être après l'heure de début", Severity.Error);
            return;
        }

        _saving = true;

        try
        {
            if (TimeSlotId.HasValue)
            {
                // Modification
                var dto = new UpdateTimeSlotDto
                {
                    Name = _model.Name,
                    StartTime = _model.StartTime!.Value,
                    EndTime = _model.EndTime!.Value,
                    DisplayOrder = 0 // Sera géré automatiquement par le backend
                };

                var result = await TimeSlotService.UpdateAsync(TimeSlotId.Value, dto);

                if (result.Succeeded)
                {
                    Snackbar.Add("Créneau modifié avec succès", Severity.Success);
                    MudDialog.Close(DialogResult.Ok(true));
                }
                else
                {
                    var errorMessage = result.Errors?.FirstOrDefault() ?? "Erreur lors de la modification";
                    Snackbar.Add(errorMessage, Severity.Error);
                }
            }
            else
            {
                // Création
                var dto = new CreateTimeSlotDto
                {
                    Name = _model.Name,
                    StartTime = _model.StartTime!.Value,
                    EndTime = _model.EndTime!.Value
                };

                var result = await TimeSlotService.CreateAsync(dto);

                if (result.Succeeded)
                {
                    Snackbar.Add("Créneau créé avec succès", Severity.Success);
                    MudDialog.Close(DialogResult.Ok(true));
                }
                else
                {
                    var errorMessage = result.Errors?.FirstOrDefault() ?? "Erreur lors de la création";
                    Snackbar.Add(errorMessage, Severity.Error);
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur : {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    // Model interne
    private class TimeSlotModel
    {
        public string Name { get; set; } = string.Empty;
        public TimeSpan? StartTime { get; set; }
        public TimeSpan? EndTime { get; set; }
    }
}

@using System.Text.Json
@using DropFlow.Shared.Admin

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <!-- Informations Générales -->
            <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                <MudText Typo="Typo.h6" Class="mb-3">Informations Générales</MudText>
                <MudGrid Spacing="2">
                    <MudItem xs="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Date/Heure</MudText>
                        <MudText Typo="Typo.body1">@Log.Timestamp.ToString("dd/MM/yyyy à HH:mm:ss")</MudText>
                    </MudItem>
                    <MudItem xs="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Sévérité</MudText>
                        <MudChip T="string" Size="Size.Small" Color="@GetSeverityColor(Log.Severity)">
                            @Log.Severity
                        </MudChip>
                    </MudItem>
                    <MudItem xs="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Tenant</MudText>
                        <MudText Typo="Typo.body1">@Log.TenantName (@Log.TenantId)</MudText>
                    </MudItem>
                    <MudItem xs="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Action</MudText>
                        <MudText Typo="Typo.body1">@Log.Action</MudText>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <!-- Utilisateur -->
            <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                <MudText Typo="Typo.h6" Class="mb-3">Utilisateur</MudText>
                <MudGrid Spacing="2">
                    <MudItem xs="12">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Email</MudText>
                        <MudText Typo="Typo.body1">@Log.UserEmail</MudText>
                    </MudItem>
                    <MudItem xs="12">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">ID Utilisateur</MudText>
                        <MudText Typo="Typo.body2" Style="font-family: monospace;">@Log.UserId</MudText>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <!-- Entité Concernée -->
            <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                <MudText Typo="Typo.h6" Class="mb-3">Entité Concernée</MudText>
                <MudGrid Spacing="2">
                    <MudItem xs="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Type d'Entité</MudText>
                        <MudText Typo="Typo.body1">@Log.EntityName</MudText>
                    </MudItem>
                    <MudItem xs="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">ID Entité</MudText>
                        <MudText Typo="Typo.body1">@Log.EntityId</MudText>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <!-- Changements -->
            @if (!string.IsNullOrEmpty(Log.Changes))
            {
                <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                    <MudText Typo="Typo.h6" Class="mb-3">Détails des Changements</MudText>
                    <MudPaper Elevation="0" Class="pa-3" Style="background-color: #f5f5f5; font-family: monospace; white-space: pre-wrap; overflow-x: auto;">
                        @FormatJson(Log.Changes)
                    </MudPaper>
                </MudPaper>
            }
        </MudStack>
    </DialogContent>
    
    <DialogActions>
        <MudButton OnClick="Close" Variant="Variant.Filled" Color="Color.Primary">Fermer</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public AuditLogDto Log { get; set; } = null!;

    private void Close() => MudDialog.Close();

    private Color GetSeverityColor(string severity) => severity switch
    {
        "Info" => Color.Info,
        "Warning" => Color.Warning,
        "Error" => Color.Error,
        "Critical" => Color.Error,
        _ => Color.Default
    };

    private string FormatJson(string json)
    {
        try
        {
            var jsonElement = JsonSerializer.Deserialize<JsonElement>(json);
            return JsonSerializer.Serialize(jsonElement, new JsonSerializerOptions
            {
                WriteIndented = true
            });
        }
        catch
        {
            // Si ce n'est pas du JSON valide, retourner tel quel
            return json;
        }
    }
}

@* $1$ Components/Dashboard/NotificationsPopover.razor #1# *@
@* @using DropFlow.WebApp.Models.Dashboard *@
@* *@
@* <MudMenu AnchorOrigin="Origin.BottomRight" *@
@*          TransformOrigin="Origin.TopRight" *@
@*          PopoverClass="df-notifications-popover"> *@
@*     <ActivatorContent> *@
@*         <MudBadge Content="@Notifications.Count(n => !n.IsRead)" *@
@*                   Color="Color.Secondary" *@
@*                   Overlap="true" *@
@*                   Dot="true" *@
@*                   Visible="@(Notifications.Any(n => !n.IsRead))" *@
@*                   Class="mx-2"> *@
@*             <MudIconButton Icon="@Icons.Material.Outlined.Notifications"  *@
@*                           Color="Color.Inherit" /> *@
@*         </MudBadge> *@
@*     </ActivatorContent> *@
@*     <ChildContent> *@
@*         <!-- Header --> *@
@*         <div class="df-notification-header"> *@
@*             <MudText Typo="Typo.h6" Style="font-weight: 700; color: #0f172a;"> *@
@*                 Notifications *@
@*             </MudText> *@
@*             @if (Notifications.Any(n => !n.IsRead)) *@
@*             { *@
@*                 <MudChip T="string"  *@
@*                          Size="Size.Small"  *@
@*                          Color="Color.Secondary"  *@
@*                          Variant="Variant.Filled"> *@
@*                     @Notifications.Count(n => !n.IsRead) nouvelle(s) *@
@*                 </MudChip> *@
@*             } *@
@*         </div> *@
@* *@
@*         <!-- Liste notifications --> *@
@*         <div class="df-notification-list"> *@
@*             @if (Notifications.Any()) *@
@*             { *@
@*                 @foreach (var notification in Notifications.Take(10)) *@
@*                 { *@
@*                     <div class="df-notification-item @(notification.IsRead ? "" : "df-notification-item-unread")" *@
@*                          @onclick="() => OnNotificationClick(notification)"> *@
@*                         <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Start"> *@
@*                             <!-- Icône --> *@
@*                             <div class="df-notification-icon" style="background: @GetNotificationColor(notification.Type, true);"> *@
@*                                 <MudIcon Icon="@GetNotificationIcon(notification.Type)"  *@
@*                                         Size="Size.Small" *@
@*                                         Style="@($"color: {GetNotificationColor(notification.Type, false)};")" /> *@
@*                             </div> *@
@*                              *@
@*                             <!-- Contenu --> *@
@*                             <div class="df-notification-content"> *@
@*                                 <div class="df-notification-title"> *@
@*                                     @notification.Title *@
@*                                 </div> *@
@*                                 <div class="df-notification-message"> *@
@*                                     @notification.Message *@
@*                                 </div> *@
@*                                 <div class="df-notification-time"> *@
@*                                     @notification.TimeAgo *@
@*                                 </div> *@
@*                             </div> *@
@*                              *@
@*                             <!-- Badge non lu --> *@
@*                             @if (!notification.IsRead) *@
@*                             { *@
@*                                 <div style="width: 8px; height: 8px; background: #0ea5e9; border-radius: 50%; margin-top: 8px;"></div> *@
@*                             } *@
@*                         </MudStack> *@
@*                     </div> *@
@*                 } *@
@*             } *@
@*             else *@
@*             { *@
@*                 <div style="padding: 40px 20px; text-align: center;"> *@
@*                     <MudIcon Icon="@Icons.Material.Outlined.NotificationsNone"  *@
@*                             Size="Size.Large"  *@
@*                             Style="color: #cbd5e1; font-size: 48px;" /> *@
@*                     <MudText Typo="Typo.body2" Style="color: #94a3b8; margin-top: 12px;"> *@
@*                         Aucune notification *@
@*                     </MudText> *@
@*                 </div> *@
@*             } *@
@*         </div> *@
@* *@
@*         <!-- Footer --> *@
@*         @if (Notifications.Any()) *@
@*         { *@
@*             <div class="df-notification-footer"> *@
@*                 <MudButton Variant="Variant.Text"  *@
@*                           Color="Color.Primary"  *@
@*                           FullWidth="true" *@
@*                           OnClick="OnSeeAllClick"> *@
@*                     Voir toutes les notifications *@
@*                 </MudButton> *@
@*             </div> *@
@*         } *@
@*     </ChildContent> *@
@* </MudMenu> *@
@* *@
@* @code { *@
@*     [Parameter] *@
@*     public List<NotificationItemDto> Notifications { get; set; } = new(); *@
@*      *@
@*     [Parameter] *@
@*     public EventCallback<NotificationItemDto> OnNotificationClicked { get; set; } *@
@*      *@
@*     [Parameter] *@
@*     public EventCallback OnSeeAllClicked { get; set; } *@
@*      *@
@*     private async Task OnNotificationClick(NotificationItemDto notification) *@
@*     { *@
@*         // Marquer comme lu *@
@*         notification.IsRead = true; *@
@*          *@
@*         if (OnNotificationClicked.HasDelegate) *@
@*         { *@
@*             await OnNotificationClicked.InvokeAsync(notification); *@
@*         } *@
@*     } *@
@*      *@
@*     private async Task OnSeeAllClick() *@
@*     { *@
@*         if (OnSeeAllClicked.HasDelegate) *@
@*         { *@
@*             await OnSeeAllClicked.InvokeAsync(); *@
@*         } *@
@*     } *@
@*      *@
@*     private string GetNotificationIcon(string type) *@
@*     { *@
@*         return type switch *@
@*         { *@
@*             "Success" => Icons.Material.Filled.CheckCircle, *@
@*             "Warning" => Icons.Material.Filled.Warning, *@
@*             "Error" => Icons.Material.Filled.Error, *@
@*             "Info" => Icons.Material.Filled.Info, *@
@*             "Delivery" => Icons.Material.Filled.LocalShipping, *@
@*             "Route" => Icons.Material.Filled.Route, *@
@*             "Client" => Icons.Material.Filled.Person, *@
@*             "Invoice" => Icons.Material.Filled.Receipt, *@
@*             _ => Icons.Material.Filled.Notifications *@
@*         }; *@
@*     } *@
@*      *@
@*     private string GetNotificationColor(string type, bool isBackground) *@
@*     { *@
@*         var (bg, text) = type switch *@
@*         { *@
@*             "Success" => ("#dcfce7", "#15803d"), *@
@*             "Warning" => ("#fef3c7", "#b45309"), *@
@*             "Error" => ("#fee2e2", "#dc2626"), *@
@*             "Info" => ("#dbeafe", "#1e40af"), *@
@*             "Delivery" => ("#e0e7ff", "#4338ca"), *@
@*             "Route" => ("#fce7f3", "#be185d"), *@
@*             "Client" => ("#f3e8ff", "#7c3aed"), *@
@*             "Invoice" => ("#fef3c7", "#b45309"), *@
@*             _ => ("#f1f5f9", "#64748b") *@
@*         }; *@
@*          *@
@*         return isBackground ? bg : text; *@
@*     } *@
@*      *@
@*     /// <summary> *@
@*     /// DTO pour une notification *@
@*     /// </summary> *@
@*     public class NotificationItemDto *@
@*     { *@
@*         public long Id { get; set; } *@
@*         public string Type { get; set; } = "Info"; *@
@*         public string Title { get; set; } = string.Empty; *@
@*         public string Message { get; set; } = string.Empty; *@
@*         public DateTime Timestamp { get; set; } *@
@*         public bool IsRead { get; set; } *@
@*         public string? EntityName { get; set; } *@
@*         public int? EntityId { get; set; } *@
@*          *@
@*         public string TimeAgo *@
@*         { *@
@*             get *@
@*             { *@
@*                 var diff = DateTime.UtcNow - Timestamp; *@
@*                 if (diff.TotalMinutes < 1) return "À l'instant"; *@
@*                 if (diff.TotalMinutes < 60) return $"Il y a {(int)diff.TotalMinutes} min"; *@
@*                 if (diff.TotalHours < 24) return $"Il y a {(int)diff.TotalHours}h"; *@
@*                 return $"Il y a {(int)diff.TotalDays}j"; *@
@*             } *@
@*         } *@
@*     } *@
@* } *@

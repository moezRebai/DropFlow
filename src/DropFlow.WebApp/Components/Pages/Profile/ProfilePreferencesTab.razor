@inject ISnackbar Snackbar

<MudText Typo="Typo.h6" Class="mb-4">Préférences de notifications</MudText>

<MudGrid>
    <!-- Notifications Email -->
    <MudItem xs="12">
        <MudPaper Elevation="0" Class="pa-4" Style="border: 1px solid #e2e8f0; border-radius: 8px;">
            <MudStack Spacing="3">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <MudStack Spacing="0">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Email" Color="Color.Primary" />
                            <MudText Typo="Typo.h6">Notifications par email</MudText>
                        </MudStack>
                        <MudText Typo="Typo.body2" Style="color: #64748b;">
                            Recevez des notifications sur votre adresse email
                        </MudText>
                    </MudStack>
                    <MudSwitch @bind-Value="_emailNotificationsEnabled" 
                               Color="Color.Primary" 
                               OnChanged="SavePreferences" />
                </MudStack>

                @if (_emailNotificationsEnabled)
                {
                    <MudDivider />
                    
                    <MudStack Spacing="2" Class="ml-4">
                        <MudCheckBox @bind-Value="_emailNewDelivery" 
                                     Color="Color.Primary"
                                     OnChanged="SavePreferences">
                            Nouvelle livraison assignée
                        </MudCheckBox>
                        <MudCheckBox @bind-Value="_emailDeliveryCompleted" 
                                     Color="Color.Primary"
                                     OnChanged="SavePreferences">
                            Livraison terminée
                        </MudCheckBox>
                        <MudCheckBox @bind-Value="_emailInvoiceCreated" 
                                     Color="Color.Primary"
                                     OnChanged="SavePreferences">
                            Nouvelle facture créée
                        </MudCheckBox>
                        <MudCheckBox @bind-Value="_emailInvoicePaid" 
                                     Color="Color.Primary"
                                     OnChanged="SavePreferences">
                            Facture payée
                        </MudCheckBox>
                    </MudStack>
                }
            </MudStack>
        </MudPaper>
    </MudItem>

    <!-- Notifications SMS -->
    <MudItem xs="12">
        <MudPaper Elevation="0" Class="pa-4" Style="border: 1px solid #e2e8f0; border-radius: 8px;">
            <MudStack Spacing="3">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <MudStack Spacing="0">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Sms" Color="Color.Primary" />
                            <MudText Typo="Typo.h6">Notifications par SMS</MudText>
                        </MudStack>
                        <MudText Typo="Typo.body2" Style="color: #64748b;">
                            Recevez des alertes importantes par SMS
                        </MudText>
                    </MudStack>
                    <MudSwitch @bind-Value="_smsNotificationsEnabled" 
                               Color="Color.Primary"
                               OnChanged="SavePreferences" />
                </MudStack>

                @if (_smsNotificationsEnabled)
                {
                    <MudDivider />
                    
                    <MudStack Spacing="2" Class="ml-4">
                        <MudCheckBox @bind-Value="_smsUrgentDelivery" 
                                     Color="Color.Primary"
                                     OnChanged="SavePreferences">
                            Livraison urgente
                        </MudCheckBox>
                        <MudCheckBox @bind-Value="_smsDeliveryLate" 
                                     Color="Color.Primary"
                                     OnChanged="SavePreferences">
                            Retard de livraison
                        </MudCheckBox>
                    </MudStack>
                }
            </MudStack>
        </MudPaper>
    </MudItem>

    <!-- Notifications In-App -->
    <MudItem xs="12">
        <MudPaper Elevation="0" Class="pa-4" Style="border: 1px solid #e2e8f0; border-radius: 8px;">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <MudStack Spacing="0">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Notifications" Color="Color.Primary" />
                        <MudText Typo="Typo.h6">Notifications dans l'application</MudText>
                    </MudStack>
                    <MudText Typo="Typo.body2" Style="color: #64748b;">
                        Afficher les notifications dans l'interface
                    </MudText>
                </MudStack>
                <MudSwitch @bind-Value="_inAppNotificationsEnabled" 
                           Color="Color.Primary"
                           OnChanged="SavePreferences" />
            </MudStack>
        </MudPaper>
    </MudItem>

    <!-- Divider -->
    <MudItem xs="12">
        <MudDivider Class="my-4" />
    </MudItem>

    <!-- Apparence -->
    <MudItem xs="12">
        <MudText Typo="Typo.h6" Class="mb-4">Apparence</MudText>
    </MudItem>

    <MudItem xs="12">
        <MudPaper Elevation="0" Class="pa-4" Style="border: 1px solid #e2e8f0; border-radius: 8px;">
            <MudStack Spacing="3">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <MudStack Spacing="0">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.DarkMode" Color="Color.Primary" />
                            <MudText Typo="Typo.h6">Mode sombre</MudText>
                        </MudStack>
                        <MudText Typo="Typo.body2" Style="color: #64748b;">
                            Activer le thème sombre pour réduire la fatigue visuelle
                        </MudText>
                    </MudStack>
                    <MudSwitch @bind-Value="_darkModeEnabled" 
                               Color="Color.Primary"
                               OnChanged="ToggleDarkMode" />
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudItem>
</MudGrid>

@if (_isSaving)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mt-4" />
}

@code {
    [Parameter] public string UserId { get; set; } = string.Empty;

    private bool _isSaving = false;

    // Notifications Email
    private bool _emailNotificationsEnabled = true;
    private bool _emailNewDelivery = true;
    private bool _emailDeliveryCompleted = true;
    private bool _emailInvoiceCreated = true;
    private bool _emailInvoicePaid = false;

    // Notifications SMS
    private bool _smsNotificationsEnabled = false;
    private bool _smsUrgentDelivery = true;
    private bool _smsDeliveryLate = true;

    // Notifications In-App
    private bool _inAppNotificationsEnabled = true;

    // Apparence
    private bool _darkModeEnabled = false;

    protected override void OnInitialized()
    {
        LoadPreferences();
    }

    private void LoadPreferences()
    {
        // TODO: Charger les préférences depuis l'API
        // var prefs = await PreferencesService.GetUserPreferencesAsync(UserId);
        
        // Pour l'instant, valeurs par défaut
    }

    private async Task SavePreferences()
    {
        _isSaving = true;

        try
        {
            // TODO: Sauvegarder les préférences via l'API
            // await PreferencesService.UpdatePreferencesAsync(UserId, new UserPreferences
            // {
            //     EmailNotificationsEnabled = _emailNotificationsEnabled,
            //     ...
            // });

            // Simulation
            await Task.Delay(500);

            Snackbar.Add("Préférences enregistrées", Severity.Success);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur sauvegarde préférences: {ex.Message}");
            Snackbar.Add("Erreur lors de la sauvegarde", Severity.Error);
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private async Task ToggleDarkMode()
    {
        // TODO: Implémenter le changement de thème
        // MudThemeProvider peut être utilisé pour ça

        await SavePreferences();
        
        Snackbar.Add(
            _darkModeEnabled ? "Mode sombre activé" : "Mode clair activé", 
            Severity.Info
        );
    }
}

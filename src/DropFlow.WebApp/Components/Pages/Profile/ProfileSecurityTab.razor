@using System.Text.RegularExpressions
@inject ISnackbar Snackbar

<MudText Typo="Typo.h6" Class="mb-4">Changer le mot de passe</MudText>

<MudAlert Severity="Severity.Info" Class="mb-4" Dense="true">
    Pour des raisons de sécurité, vous devez saisir votre mot de passe actuel avant d'en définir un nouveau.
</MudAlert>

<MudForm @ref="_form">
    <MudGrid>
        <!-- Mot de passe actuel -->
        <MudItem xs="12">
            <MudTextField @bind-Value="_currentPassword"
                          Label="Mot de passe actuel"
                          Variant="Variant.Outlined"
                          InputType="@_currentPasswordInputType"
                          Required="true"
                          RequiredError="Le mot de passe actuel est requis"
                          Adornment="Adornment.End"
                          AdornmentIcon="@_currentPasswordIcon"
                          OnAdornmentClick="ToggleCurrentPasswordVisibility"
                          Class="mb-4" />
        </MudItem>

        <MudItem xs="12">
            <MudDivider Class="my-2" />
        </MudItem>

        <!-- Nouveau mot de passe -->
        <MudItem xs="12">
            <MudTextField @bind-Value="_newPassword"
                          Label="Nouveau mot de passe"
                          Variant="Variant.Outlined"
                          InputType="@_newPasswordInputType"
                          Required="true"
                          RequiredError="Le nouveau mot de passe est requis"
                          Adornment="Adornment.End"
                          AdornmentIcon="@_newPasswordIcon"
                          OnAdornmentClick="ToggleNewPasswordVisibility"
                          HelperText="Min. 8 caractères, 1 majuscule, 1 chiffre, 1 symbole"
                          Error="@(!string.IsNullOrEmpty(ValidatePassword(_newPassword)))"
                          ErrorText="@ValidatePassword(_newPassword)"
                          Class="mb-4" />
        </MudItem>

        <!-- Confirmation mot de passe -->
        <MudItem xs="12">
            <MudTextField @bind-Value="_confirmPassword"
                          Label="Confirmer le nouveau mot de passe"
                          Variant="Variant.Outlined"
                          InputType="@_confirmPasswordInputType"
                          Required="true"
                          RequiredError="La confirmation est requise"
                          Adornment="Adornment.End"
                          AdornmentIcon="@_confirmPasswordIcon"
                          OnAdornmentClick="ToggleConfirmPasswordVisibility"
                          Error="@(!string.IsNullOrEmpty(ValidateConfirmPassword(_confirmPassword)))"
                          ErrorText="@ValidateConfirmPassword(_confirmPassword)"
                          Class="mb-4" />
        </MudItem>

        <!-- Indicateur force du mot de passe -->
        @if (!string.IsNullOrWhiteSpace(_newPassword))
        {
            <MudItem xs="12">
                <MudPaper Elevation="0" Class="pa-3" Style="background-color: #f8fafc; border-radius: 8px;">
                    <MudText Typo="Typo.body2" Class="mb-2">Force du mot de passe:</MudText>
                    <MudProgressLinear Color="@GetPasswordStrengthColor()"
                                       Value="@GetPasswordStrength()"
                                       Size="Size.Medium"
                                       Rounded="true" />
                    <MudText Typo="Typo.caption" Class="mt-1">@GetPasswordStrengthText()</MudText>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>

    <!-- Boutons actions -->
    <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-6">
        <MudButton Variant="Variant.Text" 
                   OnClick="ResetForm"
                   Disabled="@_isSaving">
            Annuler
        </MudButton>
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary"
                   OnClick="ChangePassword"
                   Disabled="@(!IsFormValid() || _isSaving)">
            @if (_isSaving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Modification...</span>
            }
            else
            {
                <span>Changer le mot de passe</span>
            }
        </MudButton>
    </MudStack>
</MudForm>

@code {
    [Parameter] public string UserId { get; set; } = string.Empty;

    private MudForm? _form;
    private bool _isSaving = false;

    private string _currentPassword = string.Empty;
    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;

    private bool _isCurrentPasswordVisible = false;
    private bool _isNewPasswordVisible = false;
    private bool _isConfirmPasswordVisible = false;

    private InputType _currentPasswordInputType => _isCurrentPasswordVisible ? InputType.Text : InputType.Password;
    private string _currentPasswordIcon => _isCurrentPasswordVisible ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility;

    private InputType _newPasswordInputType => _isNewPasswordVisible ? InputType.Text : InputType.Password;
    private string _newPasswordIcon => _isNewPasswordVisible ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility;

    private InputType _confirmPasswordInputType => _isConfirmPasswordVisible ? InputType.Text : InputType.Password;
    private string _confirmPasswordIcon => _isConfirmPasswordVisible ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility;

    private void ToggleCurrentPasswordVisibility() => _isCurrentPasswordVisible = !_isCurrentPasswordVisible;
    private void ToggleNewPasswordVisibility() => _isNewPasswordVisible = !_isNewPasswordVisible;
    private void ToggleConfirmPasswordVisibility() => _isConfirmPasswordVisible = !_isConfirmPasswordVisible;

    private string ValidatePassword(string password)
    {
        if (string.IsNullOrWhiteSpace(password))
            return string.Empty; // Ne pas afficher d'erreur si vide

        if (password.Length < 8)
            return "Minimum 8 caractères";
        if (!Regex.IsMatch(password, @"[A-Z]"))
            return "Doit contenir au moins 1 majuscule";
        if (!Regex.IsMatch(password, @"[0-9]"))
            return "Doit contenir au moins 1 chiffre";
        if (!Regex.IsMatch(password, @"[!@#$%^&*(),.?""':{}|<>]"))
            return "Doit contenir au moins 1 symbole (!@#$%...)";
        
        return string.Empty;
    }

    private string ValidateConfirmPassword(string confirmPassword)
    {
        if (string.IsNullOrWhiteSpace(confirmPassword))
            return string.Empty;

        if (confirmPassword != _newPassword)
            return "Les mots de passe ne correspondent pas";
        
        return string.Empty;
    }

    private bool IsFormValid()
    {
        return !string.IsNullOrWhiteSpace(_currentPassword) &&
               !string.IsNullOrWhiteSpace(_newPassword) &&
               !string.IsNullOrWhiteSpace(_confirmPassword) &&
               string.IsNullOrEmpty(ValidatePassword(_newPassword)) &&
               string.IsNullOrEmpty(ValidateConfirmPassword(_confirmPassword));
    }

    private int GetPasswordStrength()
    {
        if (string.IsNullOrWhiteSpace(_newPassword)) return 0;

        var strength = 0;
        if (_newPassword.Length >= 8) strength += 25;
        if (Regex.IsMatch(_newPassword, @"[a-z]") && Regex.IsMatch(_newPassword, @"[A-Z]")) 
            strength += 25;
        if (Regex.IsMatch(_newPassword, @"[0-9]")) 
            strength += 25;
        if (Regex.IsMatch(_newPassword, @"[!@#$%^&*(),.?""':{}|<>]")) 
            strength += 25;

        return strength;
    }

    private Color GetPasswordStrengthColor()
    {
        var strength = GetPasswordStrength();
        if (strength < 50) return Color.Error;
        if (strength < 75) return Color.Warning;
        return Color.Success;
    }

    private string GetPasswordStrengthText()
    {
        var strength = GetPasswordStrength();
        if (strength < 50) return "Faible";
        if (strength < 75) return "Moyen";
        return "Fort";
    }

    private void ResetForm()
    {
        _currentPassword = string.Empty;
        _newPassword = string.Empty;
        _confirmPassword = string.Empty;

        Snackbar.Add("Formulaire réinitialisé", Severity.Info);
    }

    private async Task ChangePassword()
    {
        await _form!.Validate();
        if (!_form.IsValid || !IsFormValid())
        {
            Snackbar.Add("Veuillez corriger les erreurs", Severity.Warning);
            return;
        }

        _isSaving = true;

        try
        {
            // TODO: Appeler l'API pour changer le mot de passe
            // var result = await AuthService.ChangePasswordAsync(new ChangePasswordRequest
            // {
            //     UserId = UserId,
            //     CurrentPassword = _currentPassword,
            //     NewPassword = _newPassword
            // });

            // Simulation
            await Task.Delay(1500);

            Snackbar.Add("Mot de passe modifié avec succès", Severity.Success);
            
            // Réinitialiser le formulaire
            ResetForm();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur changement mot de passe: {ex.Message}");
            Snackbar.Add("Erreur lors du changement de mot de passe", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }
}

@page "/clients"
@using DropFlow.WebApp.Models.Auth
@using Microsoft.AspNetCore.Components.Authorization
<PageTitle>Clients - DropFlow</PageTitle>
<AuthorizeView Roles="@Roles.ManagerOrAdmin" Context="auth">
    <Authorized>
        <MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4">
            <MudPaper Elevation="0" Class="pa-4 mb-4" Style="border-left: 4px solid #2196F3; background: white;">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.h5" Style="font-weight: 600; color: #1F2937;">
                            <MudIcon Icon="@Icons.Material.Filled.People" Class="mr-2" Style="color: #2196F3;"/>
                            Clients
                        </MudText>
                        <MudText Typo="Typo.body2" Style="color: #6B7280;">
                            Gérez vos Clients
                        </MudText>
                    </MudStack>
                </MudStack>
            </MudPaper>

            <!-- Statistiques -->
            <MudGrid Class="mb-4">
                <MudItem xs="12" sm="4">
                    <MudPaper Elevation="2" Class="pa-4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <div>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Total Clients</MudText>
                                <MudText Typo="Typo.h4">@_totalClients</MudText>
                            </div>
                            <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Large" Color="Color.Primary"/>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" sm="4">
                    <MudPaper Elevation="2" Class="pa-4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <div>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Clients VIP</MudText>
                                <MudText Typo="Typo.h4">@_vipClients</MudText>
                            </div>
                            <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Large" Color="Color.Warning"/>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" sm="4">
                    <MudPaper Elevation="2" Class="pa-4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <div>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">CA Total</MudText>
                                <MudText Typo="Typo.h4">@_totalRevenue.ToString("N0") €</MudText>
                            </div>
                            <MudIcon Icon="@Icons.Material.Filled.Euro" Size="Size.Large" Color="Color.Success"/>
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <!-- Filtres et actions -->
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudGrid>
                    <MudItem xs="12" md="8">
                        <MudTextField @bind-Value="_searchTerm"
                                      Label="Rechercher"
                                      Placeholder="Nom, email, téléphone..."
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Search"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Normal"
                                      Immediate="true"
                                      DebounceInterval="300"
                                      OnDebounceIntervalElapsed="OnSearchChanged"/>
                    </MudItem>

                    <MudItem xs="12" md="4" Class="d-flex align-end">
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Refresh"
                                   OnClick="LoadClients"
                                   FullWidth="true"
                                   Class="mt-4">
                            Actualiser
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <!-- Table -->
            <MudTable @ref="_table"
                      ServerData="LoadServerData"
                      Hover="true"
                      Striped="true"
                      Loading="@_loading"
                      RowsPerPage="20"
                      LoadingProgressColor="Color.Primary"
                      Elevation="2">
                <HeaderContent>
                    <MudTh>Client</MudTh>
                    <MudTh>Email</MudTh>
                    <MudTh>Téléphone</MudTh>
                    <MudTh>Ville</MudTh>
                    <MudTh Style="text-align: center;">Livraisons</MudTh>
                    <MudTh Style="text-align: right;">CA Total</MudTh>
                    <MudTh Style="text-align: center;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Client">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2"
                                  Style="align-items: center; align-content: center; justify-content: center;">
                            @if (IsVip(context))
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Warning" Size="Size.Small"
                                         Title="Client VIP (≥3 livraisons)"/>
                            }
                            <MudText Typo="Typo.body2">
                                <strong>@context.DisplayName</strong>
                            </MudText>
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Email">
                        @if (!string.IsNullOrEmpty(context.Email))
                        {
                            <MudLink Href="@($"mailto:{context.Email}")">@context.Email</MudLink>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">-</MudText>
                        }
                    </MudTd>
                    <MudTd DataLabel="Téléphone">
                        <MudLink Href="@($"tel:{context.Phone}")">@context.Phone</MudLink>
                    </MudTd>
                    <MudTd DataLabel="Ville">
                        @{
                            var defaultAddress = context.Addresses?.FirstOrDefault(a => a.IsDefault);
                            if (defaultAddress != null)
                            {
                                <MudText Typo="Typo.body2">@defaultAddress.City</MudText>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary">-</MudText>
                            }
                        }
                    </MudTd>
                    <MudTd DataLabel="Livraisons" Style="text-align: center;">
                        🚚 <strong>@context.TotalDeliveries</strong>
                    </MudTd>
                    <MudTd DataLabel="CA Total" Style="text-align: right;">
                        <strong>@context.TotalRevenue.ToString("N2") €</strong>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: center;">
                        <MudStack Row="true" Justify="Justify.Center" Spacing="1">
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                           Color="Color.Info"
                                           Size="Size.Small"
                                           Title="Voir détails"
                                           OnClick="@(() => OpenDetailDialog(context.Id))"/>
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           Title="Modifier"
                                           OnClick="@(() => OpenEditDialog(context.Id))"/>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           Title="Supprimer"
                                           OnClick="@(() => DeleteClient(context.Id, context.DisplayName))"/>
                        </MudStack>
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText Typo="Typo.body1" Align="Align.Center" Class="py-8">
                        @if (string.IsNullOrWhiteSpace(_searchTerm))
                        {
                            <text>Aucun client trouvé</text>
                        }
                        else
                        {
                            <text>Aucun client ne correspond à votre recherche "@_searchTerm"</text>
                        }
                    </MudText>
                </NoRecordsContent>
                <LoadingContent>
                    <MudText Typo="Typo.body1" Align="Align.Center" Class="py-8">
                        Chargement des clients...
                    </MudText>
                </LoadingContent>
                <PagerContent>
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
                </PagerContent>
            </MudTable>

            <!-- Pagination manuelle (optionnelle si ServerData ne suffit pas) -->
            @if (_paginatedResult != null && _paginatedResult.TotalPages > 1)
            {
                <MudPaper Elevation="0" Class="d-flex justify-center mt-4">
                    <MudPagination Count="@_paginatedResult.TotalPages"
                                   Selected="@_currentPage"
                                   SelectedChanged="OnPageChanged"
                                   Color="Color.Primary"
                                   ShowFirstButton="true"
                                   ShowLastButton="true"/>
                </MudPaper>
            }
        </MudContainer>
    </Authorized>
    <NotAuthorized>
        <RedirectToAccessDenied/>
    </NotAuthorized>
</AuthorizeView>

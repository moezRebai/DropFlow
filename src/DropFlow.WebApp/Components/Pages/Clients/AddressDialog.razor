@using System.ComponentModel.DataAnnotations
@using DropFlow.Shared.Clients
@using DropFlow.WebApp.Interfaces
@using DropFlow.WebApp.Models.Deliveries
@implements IAsyncDisposable
@inject IClientService ClientService
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="@_isValid">
            <MudStack Spacing="3">
                <MudTextField @bind-Value="_model.Label"
                              Label="Libellé"
                              Placeholder="Domicile, Bureau, Entrepôt..."
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Label" />

                <MudTextField @bind-Value="_model.Address"
                              For="@(() => _model.Address)"
                              @ref="_addressField"
                              UserAttributes="@(new Dictionary<string, object> { 
                                  { "id", "address-field" },
                                  { "autocomplete", "new-password" }
                              })"
                              Label="Adresse"
                              Variant="Variant.Outlined"
                              Required="true"
                              RequiredError="L'adresse est obligatoire"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.LocationOn"
                              Placeholder="Commencez à saisir l'adresse..."
                              HelperText="Commencez à taper pour voir les suggestions" />

                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudTextField @bind-Value="_model.ZipCode"
                                      For="@(() => _model.ZipCode)"
                                      Label="Code postal"
                                      Variant="Variant.Outlined"
                                      Required="true"
                                      RequiredError="Le code postal est obligatoire" />
                    </MudItem>
                    <MudItem xs="12" md="8">
                        <MudTextField @bind-Value="_model.City"
                                      For="@(() => _model.City)"
                                      Label="Ville"
                                      Variant="Variant.Outlined"
                                      Required="true"
                                      RequiredError="La ville est obligatoire" />
                    </MudItem>
                </MudGrid>

                <MudTextField @bind-Value="_model.Complement"
                              Label="Complément d'adresse"
                              Placeholder="Bâtiment, étage, code d'accès..."
                              Variant="Variant.Outlined"
                              Lines="2"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Info" />
            </MudStack>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Annuler</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="Save"
                   Disabled="@(!_isValid || _saving)">
            @if (_saving)
            {
                <MudProgressCircular Indeterminate="true" Size="Size.Small" />
            }
            else
            {
                <text>@(IsEdit ? "Modifier" : "Ajouter")</text>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public int ClientId { get; set; }
    [Parameter] public int AddressId { get; set; }
    [Parameter] public bool IsEdit { get; set; }
    [Parameter] public ClientAddressDto? ExistingAddress { get; set; }

    private MudForm _form = default!;
    private MudTextField<string> _addressField = default!;
    private bool _isValid;
    private bool _saving;

    private AddressModel _model = new();
    private IJSObjectReference? _jsModule;

    protected override async Task OnInitializedAsync()
    {
        if (IsEdit && ExistingAddress != null)
        {
            // Pré-remplir avec l'adresse existante
            _model = new AddressModel
            {
                Label = ExistingAddress.Label,
                Address = ExistingAddress.Address,
                ZipCode = ExistingAddress.ZipCode,
                City = ExistingAddress.City,
                Complement = ExistingAddress.Complement
            };
        }
        else
        {
            _model.Label = "Principal";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await InitializeGoogleMapsAutocompleteAsync();
        }
    }

    /// <summary>
    /// Initialise l'autocomplete Google Maps
    /// </summary>
    private async Task InitializeGoogleMapsAutocompleteAsync()
    {
        try
        {
            // Attendre que Google Maps API soit chargée
            var maxRetries = 10;
            for (int i = 0; i < maxRetries; i++)
            {
                var isLoaded = await JSRuntime.InvokeAsync<bool>("eval", "typeof google !== 'undefined' && typeof google.maps !== 'undefined'");
                if (isLoaded) break;
                await Task.Delay(200);
            }

            // Charger le module JS
            _jsModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "/js/googleMapsAutocomplete.js");

            // Attendre que l'input soit rendu
            await Task.Delay(100);

            // Initialiser l'autocomplete
            await _jsModule.InvokeVoidAsync("initializeAutocomplete", 
                DotNetObjectReference.Create(this), 
                "address-field");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur initialisation Google Maps: {ex.Message}");
        }
    }

    /// <summary>
    /// Callback JS : reçoit l'adresse sélectionnée
    /// </summary>
    [JSInvokable]
    public Task OnAddressSelected(GooglePlaceResult place)
    {
        _model.Address = place.StreetAddress ?? place.FormattedAddress ?? String.Empty;
        _model.ZipCode = place.PostalCode ?? string.Empty;
        _model.City = place.City ?? string.Empty;

        StateHasChanged();
        return Task.CompletedTask;
    }

    /// <summary>
    /// Enregistre l'adresse
    /// </summary>
    private async Task Save()
    {
        await _form.Validate();

        if (!_isValid)
        {
            Snackbar.Add("Veuillez corriger les erreurs", Severity.Warning);
            return;
        }

        _saving = true;

        try
        {
            if (IsEdit)
            {
                // Mise à jour
                var updateDto = new UpdateClientAddressDto
                {
                    Label = _model.Label,
                    Address = _model.Address,
                    ZipCode = _model.ZipCode,
                    City = _model.City,
                    Complement = _model.Complement
                };

                var result = await ClientService.UpdateAddressAsync(ClientId, AddressId, updateDto);

                if (result.Succeeded)
                {
                    MudDialog.Close(DialogResult.Ok(true));
                }
                else
                {
                    var errorMessage = result.Errors?.FirstOrDefault() ?? "Erreur lors de la mise à jour";
                    Snackbar.Add(errorMessage, Severity.Error);
                }
            }
            else
            {
                // Création
                var createDto = new CreateClientAddressDto
                {
                    Label = _model.Label,
                    Address = _model.Address,
                    ZipCode = _model.ZipCode,
                    City = _model.City,
                    Complement = _model.Complement
                };

                var result = await ClientService.AddAddressAsync(ClientId, createDto);

                if (result.Succeeded)
                {
                    MudDialog.Close(DialogResult.Ok(true));
                }
                else
                {
                    var errorMessage = result.Errors?.FirstOrDefault() ?? "Erreur lors de l'ajout";
                    Snackbar.Add(errorMessage, Severity.Error);
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur : {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    /// <summary>
    /// Annule
    /// </summary>
    private void Cancel()
    {
        MudDialog.Cancel();
    }

    /// <summary>
    /// Dispose du module JS
    /// </summary>
    public async ValueTask DisposeAsync()
    {
        if (_jsModule != null)
        {
            await _jsModule.DisposeAsync();
        }
    }

    /// <summary>
    /// Modèle pour le formulaire d'adresse
    /// </summary>
    private class AddressModel
    {
        public string? Label { get; set; }
        
        [Required(ErrorMessage = "L'adresse est obligatoire")]
        public string Address { get; set; } = string.Empty;
        
        [Required(ErrorMessage = "Le code postal est obligatoire")]
        public string ZipCode { get; set; } = string.Empty;
        
        [Required(ErrorMessage = "La ville est obligatoire")]
        public string City { get; set; } = string.Empty;
        
        public string? Complement { get; set; }
    }
}

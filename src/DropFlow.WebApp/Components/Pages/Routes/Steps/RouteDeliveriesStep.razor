@using System.Globalization
@using DropFlow.Shared.Deliveries
@using DropFlow.WebApp.Interfaces
@using DropFlow.WebApp.Models.Routes
@inject IDeliveryService DeliveryService
@inject IDeliveryEventBus EventBus
@inject ISnackbar Snackbar
@inject ILogger<RouteDeliveriesStep> Logger
@implements IDisposable

<MudStack Spacing="3">

    <!-- Header with date context -->
    <MudPaper Elevation="0" Class="pa-3 rounded-lg" Style="background: var(--mud-palette-background-grey);">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Color="Color.Primary" />
                <MudText Typo="Typo.body2">
                    Sélectionnez les livraisons à inclure pour le
                    <strong>@State.Date?.ToString("dd/MM/yyyy", CultureInfo.GetCultureInfo("fr-FR"))</strong>
                </MudText>
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (_loading)
    {
        <MudPaper Elevation="1" Class="pa-6 rounded-lg d-flex flex-column align-center justify-center" Style="min-height: 200px;">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
            <MudText Typo="Typo.body2" Class="mt-4" Color="Color.Secondary">
                Chargement des livraisons disponibles...
            </MudText>
        </MudPaper>
    }
    else if (!_availableDeliveries.Any())
    {
        <MudPaper Elevation="1" Class="pa-8 rounded-lg d-flex flex-column align-center justify-center" Style="min-height: 280px;">
            <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Color="Color.Secondary" Style="font-size: 3.5rem;" />
            <MudText Typo="Typo.h6" Class="mt-3">Aucune livraison disponible</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">
                Aucune livraison n'est planifiée pour le @State.Date?.ToString("dd/MM/yyyy", CultureInfo.GetCultureInfo("fr-FR")).
            </MudText>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       Href="/livraisons/nouvelle"
                       Target="_blank"
                       Class="mt-4"
                       Size="Size.Small">
                Créer une livraison
            </MudButton>
        </MudPaper>
    }
    else
    {
        <!-- Statistics Cards -->
        <MudGrid Spacing="3">
            <MudItem xs="12" sm="6" md="6">
                <MudPaper Elevation="2" Class="pa-4 rounded-lg">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Disponibles</MudText>
                            <MudText Typo="Typo.h4" Color="Color.Primary">@_availableDeliveries.Count</MudText>
                        </MudStack>
                        <MudAvatar Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Large">
                            <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Large" Color="Color.Primary"/>
                        </MudAvatar>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6" md="6">
                <MudPaper Elevation="2" Class="pa-4 rounded-lg">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Sélectionnées</MudText>
                            <MudText Typo="Typo.h4" Color="Color.Success">@State.SelectedDeliveries.Count</MudText>
                        </MudStack>
                        <MudAvatar Color="Color.Success" Variant="Variant.Outlined" Size="Size.Large">
                            <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Large" Color="Color.Success" />
                        </MudAvatar>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <!-- Table with toolbar -->
        <MudPaper Elevation="2" Class="rounded-lg">
            <!-- Toolbar -->
            <MudToolBar Dense="true" Class="px-3" Style="background: var(--mud-palette-background-grey);">
                <MudIcon Icon="@Icons.Material.Filled.List" Class="mr-2" Size="Size.Small" />
                <MudText Typo="Typo.subtitle2">Liste des livraisons</MudText>
                <MudSpacer />
                <MudButton Size="Size.Small"
                           Variant="Variant.Text"
                           StartIcon="@Icons.Material.Filled.SelectAll"
                           OnClick="SelectAll"
                           Disabled="@(_loading || !_availableDeliveries.Any())">
                    Tout sélectionner
                </MudButton>
                <MudButton Size="Size.Small"
                           Variant="Variant.Text"
                           StartIcon="@Icons.Material.Filled.Deselect"
                           OnClick="DeselectAll"
                           Disabled="@(_loading || !State.SelectedDeliveries.Any())">
                    Tout désélectionner
                </MudButton>
                <MudTooltip Text="Recharger la liste depuis le serveur">
                    <MudIconButton Size="Size.Medium"
                                   Color="Color.Primary"
                                   Icon="@Icons.Material.Filled.Refresh"
                                   OnClick="RefreshDeliveries"
                                   Disabled="@_loading"/>
                </MudTooltip>
            </MudToolBar>

            <MudDivider />

            <!-- Search -->
            <div class="px-3 py-2">
                <MudTextField @bind-Value="_searchText"
                              Placeholder="Rechercher par client, adresse ou référence..."
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Clearable="true"
                              Immediate="true"
                              Variant="Variant.Text"
                              Margin="Margin.Dense"
                              FullWidth="true" />
            </div>

            <MudTable T="DeliveryDto"
                      Items="@_availableDeliveries"
                      Hover="true"
                      Striped="true"
                      Bordered="false"
                      FixedHeader="true"
                      MultiSelection="true"
                      min-height="250px"
                      SelectedItems="_selectedSet"
                      SelectOnRowClick="true"
                      SelectedItemsChanged="OnSelectionChanged"
                      Filter="@FilterDelivery"
                      RowClassFunc="@GetRowClass"
                      Breakpoint="Breakpoint.Sm">

                <HeaderContent>
                    <MudTh>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Justify="Justify.Center">
                            <MudIcon Icon="@Icons.Material.Filled.Tag" Size="Size.Small" />
                            <MudText Typo="Typo.caption">Référence</MudText>
                        </MudStack>
                    </MudTh>
                    <MudTh>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Justify="Justify.Center">
                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                            <MudText Typo="Typo.caption">Client</MudText>
                        </MudStack>
                    </MudTh>
                    <MudTh>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Justify="Justify.Center">
                            <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small" />
                            <MudText Typo="Typo.caption">Adresse</MudText>
                        </MudStack>
                    </MudTh>
                    <MudTh Style="text-align: center">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Justify="Justify.Center">
                            <MudIcon Icon="@Icons.Material.Filled.Notes" Size="Size.Small" />
                            <MudText Typo="Typo.caption">Notes</MudText>
                        </MudStack>
                    </MudTh>
                    <MudTh Style="text-align: center">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Justify="Justify.Center">
                            <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" />
                            <MudText Typo="Typo.caption">Durée</MudText>
                        </MudStack>
                    </MudTh>
                    <MudTh Style="text-align: center">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Justify="Justify.Center">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" />
                            <MudText Typo="Typo.caption">Statut</MudText>
                        </MudStack>
                    </MudTh>
                </HeaderContent>

                <RowTemplate>
                    <MudTd DataLabel="Référence">
                        <MudTooltip Text="Ouvrir l'édition (nouvel onglet)" Placement="Placement.Top">
                            <MudLink Href="@($"/livraisons/edit/{context.Id}")"
                                     Target="_blank"
                                     Typo="Typo.body2"
                                     Class="font-weight-medium"
                                     Color="Color.Primary">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    @context.Reference
                                    <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" />
                                </MudStack>
                            </MudLink>
                        </MudTooltip>
                    </MudTd>

                    <MudTd DataLabel="Client">
                        <MudText Typo="Typo.body2">@context.ClientName</MudText>
                    </MudTd>

                    <MudTd DataLabel="Adresse">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudText Typo="Typo.body2">@context.Address, @context.City</MudText>
                            @if (!HasValidCoordinates(context))
                            {
                                <MudTooltip Text="Adresse non géocodée — impossible à optimiser. Corrigez l'adresse dans la fiche livraison." Placement="Placement.Top">
                                    <MudIcon Icon="@Icons.Material.Filled.LocationOff" Size="Size.Small" Color="Color.Error" />
                                </MudTooltip>
                            }
                        </MudStack>
                    </MudTd>

                    <MudTd DataLabel="Notes" Style="text-align: center;">
                        @if (!string.IsNullOrWhiteSpace(context.DeliveryNotes))
                        {
                            <MudTooltip Text="@context.DeliveryNotes" Placement="Placement.Top">
                                <MudIcon Icon="@Icons.Material.Filled.StickyNote2" Size="Size.Small" Color="Color.Default" />
                            </MudTooltip>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">—</MudText>
                        }
                    </MudTd>

                    <MudTd DataLabel="Durée Prestation" Style="text-align: center;">
                        @if (context.EstimatedDurationMinutes is > 0)
                        {
                            <MudChip Size="Size.Small"
                                     T="string"
                                     Variant="Variant.Outlined"
                                     Color="Color.Info"
                                     Icon="@Icons.Material.Filled.Timer">
                                @context.EstimatedDurationMinutes min
                            </MudChip>
                        }
                        else
                        {
                            <MudTooltip Text="Durée de prestation non définie — corrigez la fiche livraison." Placement="Placement.Top">
                                <MudIcon Icon="@Icons.Material.Filled.TimerOff" Size="Size.Small" Color="Color.Error" />
                            </MudTooltip>
                        }
                    </MudTd>

                    <MudTd DataLabel="Statut" Style="text-align: center;">
                        @if (context.RouteId.HasValue && !string.IsNullOrEmpty(context.RouteReference))
                        {
                            <MudTooltip Text="@($"Déjà dans la tournée {context.RouteReference} (Draft)")">
                                <MudChip Size="Size.Small"
                                         T="string"
                                         Variant="Variant.Outlined"
                                         Color="Color.Warning"
                                         Icon="@Icons.Material.Filled.Warning">
                                    @context.RouteReference
                                </MudChip>
                            </MudTooltip>
                        }
                        else
                        {
                            <MudChip Size="Size.Small"
                                     T="string"
                                     Variant="Variant.Outlined"
                                     Color="Color.Success"
                                     Icon="@Icons.Material.Filled.CheckCircle">
                                Disponible
                            </MudChip>
                        }
                    </MudTd>
                </RowTemplate>
            </MudTable>

        </MudPaper>

        <!-- Invalid deliveries warning -->
        @if (InvalidSelectedDeliveries.Any())
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.body2">
                        <strong>@InvalidSelectedDeliveries.Count livraison@(InvalidSelectedDeliveries.Count > 1 ? "s" : "") incomplète@(InvalidSelectedDeliveries.Count > 1 ? "s" : "")</strong> — coordonnées GPS ou durée de prestation manquante. Corrigez chaque fiche avant de continuer.
                    </MudText>
                    <MudStack Spacing="1">
                        @foreach (var d in InvalidSelectedDeliveries)
                        {
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@(!HasValidCoordinates(d) ? Icons.Material.Filled.LocationOff : Icons.Material.Filled.TimerOff)"
                                         Size="Size.Small" Color="Color.Error" />
                                <MudText Typo="Typo.caption">
                                    @d.Reference — @d.ClientName
                                    @if (!HasValidCoordinates(d))
                                    {
                                        <text> (adresse non géocodée)</text>
                                    }
                                    @if (d.EstimatedDurationMinutes is not > 0)
                                    {
                                        <text> (durée non définie)</text>
                                    }
                                </MudText>
                                <MudSpacer />
                                <MudTooltip Text="Corriger dans la fiche livraison">
                                    <MudIconButton Size="Size.Small"
                                                   Icon="@Icons.Material.Filled.OpenInNew"
                                                   Href="@($"/livraisons/edit/{d.Id}")"
                                                   Target="_blank" />
                                </MudTooltip>
                            </MudStack>
                        }
                    </MudStack>
                </MudStack>
            </MudAlert>
        }

        <!-- Validation Status -->
        <MudAlert Severity="@(IsValid ? Severity.Success : Severity.Warning)" Variant="Variant.Outlined">
            @if (IsValid)
            {
                <strong>@State.SelectedDeliveries.Count livraison@(State.SelectedDeliveries.Count > 1 ? "s" : "") sélectionnée@(State.SelectedDeliveries.Count > 1 ? "s" : "")</strong>
                <text> — Vous pouvez continuer.</text>
            }
            else if (!State.SelectedDeliveries.Any())
            {
                <text>Veuillez sélectionner au moins une livraison pour continuer.</text>
            }
            else
            {
                <text>Corrigez les livraisons incomplètes pour continuer.</text>
            }
        </MudAlert>
    }
</MudStack>

@code {
    [Parameter] public RouteWizardState State { get; set; } = null!;
    [Parameter] public EventCallback<bool> OnValidationChanged { get; set; }
    [Parameter] public int? CurrentRouteId { get; set; }

    private List<DeliveryDto> _availableDeliveries = [];
    private HashSet<DeliveryDto> _selectedSet = [];
    private bool _loading = true;
    private string _searchText = string.Empty;
    private HashSet<int> _geocodingInProgress = [];

    private bool IsValid => State.SelectedDeliveries.Any() && !InvalidSelectedDeliveries.Any();

    // France mainland + Corsica bounding box
    private static bool HasValidCoordinates(DeliveryDto d) =>
        d.Latitude is >= 41.0 and <= 51.5 &&
        d.Longitude is >= -6.0 and <= 10.0;

    private static bool IsValidForOptimization(DeliveryDto d) =>
        HasValidCoordinates(d) && d.EstimatedDurationMinutes is > 0;

    private List<DeliveryDto> InvalidSelectedDeliveries =>
        State.SelectedDeliveries
            .Where(d => !IsValidForOptimization(d))
            .ToList();

    private bool FilterDelivery(DeliveryDto d)
    {
        if (string.IsNullOrWhiteSpace(_searchText)) return true;
        return (d.ClientName?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false)
            || (d.Address?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false)
            || (d.City?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false)
            || (d.Reference?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false);
    }

    private string GetRowClass(DeliveryDto item, int index)
    {
        if (!IsValidForOptimization(item))
            return "invalid-address-row";
        if (item.RouteId.HasValue)
            return "pre-assigned-row";
        return string.Empty;
    }

    protected override async Task OnInitializedAsync()
    {
        EventBus.OnDeliveryUpdated += HandleDeliveryUpdated;
        EventBus.OnDeliveryDeleted += HandleDeliveryDeleted;

        Logger.LogInformation("🔔 Subscribed to Event Bus");

        await LoadDeliveries();
    }

    public async Task OnStepEntered()
    {
        await LoadDeliveries();
        StateHasChanged();
    }

    public Task<bool> ValidateAsync()
    {
        if (!State.SelectedDeliveries.Any())
        {
            Snackbar.Add("Veuillez sélectionner au moins une livraison", Severity.Warning);
            return Task.FromResult(false);
        }

        var invalid = InvalidSelectedDeliveries;
        if (invalid.Any())
        {
            var refs = string.Join(", ", invalid.Select(d => d.Reference));
            Snackbar.Add($"{invalid.Count} livraison(s) incomplète(s) : {refs}. Corrigez les fiches avant de continuer.", Severity.Error);
            return Task.FromResult(false);
        }

        return Task.FromResult(true);
    }

    private async Task GeocodeDeliveryAsync(DeliveryDto delivery)
    {
        _geocodingInProgress.Add(delivery.Id);
        StateHasChanged();

        try
        {
            var result = await DeliveryService.GeocodeDeliveryAsync(delivery.Id);

            if (!result.Succeeded || result.Data == null)
            {
                var error = result.Errors.FirstOrDefault() ?? "Adresse introuvable";
                Snackbar.Add($"{delivery.Reference} : {error}", Severity.Error);
                return;
            }

            var updated = result.Data;

            var availableIndex = _availableDeliveries.FindIndex(d => d.Id == updated.Id);
            if (availableIndex >= 0)
                _availableDeliveries[availableIndex] = updated;

            var selectedItem = _selectedSet.FirstOrDefault(d => d.Id == updated.Id);
            if (selectedItem != null)
            {
                _selectedSet.Remove(selectedItem);
                _selectedSet.Add(updated);
                State.SelectedDeliveries = _selectedSet.ToList();
            }

            Snackbar.Add($"{updated.Reference} géocodé avec succès", Severity.Success);
            await OnValidationChanged.InvokeAsync(IsValid);
        }
        finally
        {
            _geocodingInProgress.Remove(delivery.Id);
            StateHasChanged();
        }
    }

    private async Task RefreshDeliveries()
    {
        Snackbar.Add("Rechargement de la liste...", Severity.Info);
        await LoadDeliveries();
        Snackbar.Add("Liste rechargée avec succès", Severity.Success);
        StateHasChanged();
    }

    private async Task LoadDeliveries()
    {
        _loading = true;

        try
        {
            var result = await DeliveryService.GetAvailableDeliveriesForRouteAsync(
                State.Date ?? DateTime.Today,
                CurrentRouteId);

            if (result.Succeeded && result.Data != null)
            {
                _availableDeliveries = result.Data;

                Logger.LogInformation("✅ Loaded {Count} available deliveries for date {Date}",
                    _availableDeliveries.Count, State.Date?.ToString("yyyy-MM-dd"));

                if (State.SelectedDeliveries.Any())
                {
                    _selectedSet = State.SelectedDeliveries
                        .Join(_availableDeliveries, s => s.Id, a => a.Id, (_, a) => a)
                        .ToHashSet();

                    // Sync State with fresh server data so coordinates are up to date
                    // (edit-mode load populates SelectedDeliveries without Latitude/Longitude)
                    State.SelectedDeliveries = _selectedSet.ToList();

                    Logger.LogInformation("✅ Restored {Count} selected deliveries", _selectedSet.Count);
                }
            }
            else
            {
                var error = result.Errors.FirstOrDefault() ?? "Erreur inconnue";
                Snackbar.Add($"Erreur: {error}", Severity.Error);
                _availableDeliveries = [];
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "❌ Error loading deliveries");
            Snackbar.Add($"Erreur lors du chargement des livraisons: {ex.Message}", Severity.Error);
            _availableDeliveries = [];
        }
        finally
        {
            _loading = false;
        }
    }

    // ════════════════════════════════════════════════════════════════
    // EVENT HANDLERS
    // ════════════════════════════════════════════════════════════════

    private async void HandleDeliveryUpdated(int deliveryId)
    {
        try
        {
            var isSelected = _selectedSet.Any(d => d.Id == deliveryId);
            var isAvailable = _availableDeliveries.Any(d => d.Id == deliveryId);

            if (!isSelected && !isAvailable)
            {
                Logger.LogInformation("📦 Delivery {Id} updated but not in our lists, ignoring", deliveryId);
                return;
            }

            Logger.LogInformation("🔄 Delivery {Id} was updated externally, reloading...", deliveryId);

            await ReloadDelivery(deliveryId);

            var deliveryLabel = _availableDeliveries.FirstOrDefault(d => d.Id == deliveryId)?.Reference
                ?? _selectedSet.FirstOrDefault(d => d.Id == deliveryId)?.Reference
                ?? $"#{deliveryId}";

            if (isSelected)
            {
                State.MarkAsChanged();
                Logger.LogInformation("⚠️ Selected delivery {Id} changed - optimization invalidated", deliveryId);
            }

            await InvokeAsync(() =>
            {
                Snackbar.Add(
                    $"La livraison {deliveryLabel} a été modifiée, réoptimisation nécessaire",
                    Severity.Warning);
                StateHasChanged();
            });
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "❌ Error handling delivery update event for delivery {Id}", deliveryId);
        }
    }

    private async void HandleDeliveryDeleted(int deliveryId)
    {
        try
        {
            var wasSelected = _selectedSet.Any(d => d.Id == deliveryId);
            var wasAvailable = _availableDeliveries.Any(d => d.Id == deliveryId);

            if (!wasSelected && !wasAvailable)
            {
                return;
            }

            var deliveryLabel = _selectedSet.FirstOrDefault(d => d.Id == deliveryId)?.Reference
                ?? _availableDeliveries.FirstOrDefault(d => d.Id == deliveryId)?.Reference
                ?? $"#{deliveryId}";

            Logger.LogWarning("⚠️ Delivery {Id} was deleted externally", deliveryId);

            if (wasSelected)
            {
                var toRemove = _selectedSet.FirstOrDefault(d => d.Id == deliveryId);
                if (toRemove != null)
                {
                    _selectedSet.Remove(toRemove);
                    State.SelectedDeliveries = _selectedSet.ToList();
                    State.MarkAsChanged();

                    Logger.LogInformation("🗑️ Removed deleted delivery {Id} from selection", deliveryId);
                }
            }

            _availableDeliveries.RemoveAll(d => d.Id == deliveryId);

            await InvokeAsync(() =>
            {
                Snackbar.Add($"La livraison {deliveryLabel} a été supprimée", Severity.Error);
                StateHasChanged();
            });
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "❌ Error handling delivery deletion event for delivery {Id}", deliveryId);
        }
    }

    private async Task ReloadDelivery(int deliveryId)
    {
        try
        {
            Logger.LogInformation("🔄 Reloading delivery {Id}...", deliveryId);

            var responseResult = await DeliveryService.GetDeliveryByIdAsync(deliveryId);
            var updated = responseResult.Data;

            if (updated == null)
            {
                Logger.LogWarning("⚠️ Failed to reload delivery {Id} - not found", deliveryId);
                return;
            }

            var availableIndex = _availableDeliveries.FindIndex(d => d.Id == deliveryId);
            if (availableIndex >= 0)
            {
                _availableDeliveries[availableIndex] = updated;
                Logger.LogInformation("✅ Updated delivery {Id} in available list", deliveryId);
            }

            var selectedItem = _selectedSet.FirstOrDefault(d => d.Id == deliveryId);
            if (selectedItem != null)
            {
                _selectedSet.Remove(selectedItem);
                _selectedSet.Add(updated);

                State.SelectedDeliveries = _selectedSet.ToList();

                Logger.LogInformation("✅ Updated delivery {Id} in selected list", deliveryId);
                Logger.LogInformation("   Address: {Address}", updated.Address);
                Logger.LogInformation("   Duration: {Duration}min", updated.EstimatedDurationMinutes);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "❌ Error reloading delivery {Id}", deliveryId);
        }
    }

    private void OnSelectionChanged()
    {
        var newIds = _selectedSet.Select(d => d.Id).Order().ToList();
        var previousIds = State.SelectedDeliveries.Select(d => d.Id).Order().ToList();
        var selectionActuallyChanged = !newIds.SequenceEqual(previousIds);

        State.SelectedDeliveries = _selectedSet.ToList();

        if (selectionActuallyChanged)
        {
            State.MarkAsChanged();
        }

        Logger.LogInformation("📊 Selection changed: {Count} deliveries selected", State.SelectedDeliveries.Count);
        OnValidationChanged.InvokeAsync(IsValid);
    }

    private void SelectAll()
    {
        _selectedSet = _availableDeliveries.ToHashSet();
        OnSelectionChanged();
    }

    private void DeselectAll()
    {
        _selectedSet.Clear();
        OnSelectionChanged();
    }

    // ════════════════════════════════════════════════════════════════
    // DISPOSE
    // ════════════════════════════════════════════════════════════════

    public void Dispose()
    {
        EventBus.OnDeliveryUpdated -= HandleDeliveryUpdated;
        EventBus.OnDeliveryDeleted -= HandleDeliveryDeleted;

        Logger.LogInformation("🔕 Unsubscribed from Event Bus");
    }
}

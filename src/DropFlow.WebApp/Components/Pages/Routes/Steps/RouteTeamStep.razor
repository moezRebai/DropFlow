@using DropFlow.Shared.Drivers
@using DropFlow.Domain.Enums
@using DropFlow.WebApp.Interfaces
@using DropFlow.WebApp.Models.Routes
@inject IDriverService DriverService
@inject ISnackbar Snackbar

<MudGrid>
    <MudItem xs="12">
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Sélectionnez le chauffeur principal et les Monteurs si nécessaire
        </MudText>
    </MudItem>

    <!-- Chauffeur Principal -->
    <MudItem xs="12">
        <MudAutocomplete T="DriverDto"
                         Label="Chauffeur Principal *"
                         Value="_mainDriver"
                         ValueChanged="OnMainDriverChanged"
                         SearchFunc="SearchDrivers"
                         ToStringFunc="@(d => d?.FullName ?? string.Empty)"
                         Required="true"
                         RequiredError="Le chauffeur principal est obligatoire"
                         Variant="Variant.Outlined"
                         Clearable="true"
                         AdornmentIcon="@Icons.Material.Filled.LocalShipping"
                         AdornmentColor="Color.Primary"
                         OnClearButtonClick="ClearMainDriver">


        <ItemTemplate>
                <MudText Typo="Typo.body2">
                    <strong>@context.FullName</strong>
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @context.Phone
                    @if (!string.IsNullOrEmpty(context.LicenseNumber))
                    {
                        <span> - Permis: @context.LicenseNumber</span>
                    }
                </MudText>
            </ItemTemplate>
        </MudAutocomplete>
    </MudItem>

    <!-- Monteurs supplémentaires -->
    <MudItem xs="12">
        <MudText Typo="Typo.subtitle2" Class="mb-2">Monteurs Supplémentaires (Optionnel)</MudText>

        @foreach (var helper in _helpers)
        {
            <MudCard Class="mb-2" @key="helper.Id">
                <MudCardContent>
                    <MudGrid>
                        <MudItem xs="11">
                            <MudAutocomplete T="DriverDto"
                                             Label="Monteur"
                                             Value="helper.Driver"
                                             ValueChanged="@(driver => OnHelperChanged(helper, driver))"
                                             SearchFunc="@( (text, token) => SearchDriversForHelper(helper, text, token) )"
                                             ToStringFunc="@(d => d?.FullName ?? string.Empty)"
                                             Variant="Variant.Outlined"
                                             AdornmentColor="Color.Secondary"
                                             Clearable="true"
                                             AdornmentIcon="@Icons.Material.Filled.Person" />
                        </MudItem>

                        <MudItem xs="1" Class="d-flex align-center">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Color="Color.Error"
                                           OnClick="@(() => RemoveHelper(helper))" />
                        </MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>
        }

        <MudButton Variant="Variant.Outlined"
                  Color="Color.Primary"
                  StartIcon="@Icons.Material.Filled.PersonAdd"
                  OnClick="AddHelper"
                  Disabled="@(_helpers.Count >= 2)"
                  Class="mt-2">
            Ajouter un Monteur
        </MudButton>
        
        @if (_helpers.Count >= 2)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
                Maximum 2 Monteurs supplémentaires
            </MudText>
        }
    </MudItem>

    <!-- Résumé Équipe -->
    @if (IsValid)
    {
        <MudItem xs="12">
            <MudAlert Severity="Severity.Success" Dense="true" Class="mt-4">
                <MudText Typo="Typo.body2">
                    ✅ Équipe: <strong>@State.TeamMembers.Count personne@(State.TeamMembers.Count > 1 ? "s" : "")</strong>
                    <ul class="mt-2 mb-0">
                        @foreach (var member in State.TeamMembers)
                        {
                            <li>@member.DriverName (@GetRoleDisplay(member.Role))</li>
                        }
                    </ul>
                </MudText>
            </MudAlert>
        </MudItem>
    }
</MudGrid>

@code {
    [Parameter] public RouteWizardState State { get; set; } = null!;
    [Parameter] public EventCallback<bool> OnValidationChanged { get; set; }

    private List<DriverDto> _drivers = new();
    private DriverDto? _mainDriver;
    private List<HelperState> _helpers = new();

    private bool IsValid => _mainDriver != null;

    protected override async Task OnInitializedAsync()
    {
        await LoadDrivers();
        InitializeFromState();
    }

    public void OnStepEntered()
    {
        // Appelé quand on revient sur ce step
    }

    public Task<bool> ValidateAsync()
    {
        var valid = IsValid;

        if (!valid)
        {
            Snackbar.Add("Veuillez sélectionner un chauffeur principal", Severity.Warning);
        }
        else
        {
            SyncStateWithSelection();
        }

        return Task.FromResult(valid);
    }

    private async Task LoadDrivers()
    {
        try
        {
            _drivers = await DriverService.GetAvailableDriversAsync(State.Date ?? DateTime.Today);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur lors du chargement des chauffeurs: {ex.Message}", Severity.Error);
        }
    }

    private void InitializeFromState()
    {
        if (!State.TeamMembers.Any()) return;
        
        var main = State.TeamMembers.FirstOrDefault(c => c.Role == TeamMemberRole.MainDriver);
       
        if (main != null)
        {
            _mainDriver = _drivers.FirstOrDefault(d => d.Id == main.DriverId);
        }

        var helpers = State.TeamMembers.Where(c => c.Role == TeamMemberRole.Helper).ToList();
        foreach (var helper in helpers)
        {
            var driver = _drivers.FirstOrDefault(d => d.Id == helper.DriverId);
            if (driver != null)
            {
                _helpers.Add(new HelperState { Driver = driver });
            }
        }
    }

    private void SyncStateWithSelection()
    {
        State.TeamMembers.Clear();

        // Chauffeur principal
        if (_mainDriver != null)
        {
            State.TeamMembers.Add(new TeamMemberState
            {
                DriverId = _mainDriver.Id,
                DriverName = _mainDriver.FullName,
                Role = TeamMemberRole.MainDriver
            });
        }

        // Équipiers
        foreach (var helper in _helpers.Where(h => h.Driver != null))
        {
            State.TeamMembers.Add(new TeamMemberState
            {
                DriverId = helper.Driver!.Id,
                DriverName = helper.Driver.FullName,
                Role = TeamMemberRole.Helper
            });
        }

        OnValidationChanged.InvokeAsync(IsValid);
    }

    private async Task<IEnumerable<DriverDto>> SearchDrivers(string value, CancellationToken token)
    {
        await Task.Delay(5, token);

        if (string.IsNullOrWhiteSpace(value))
            return _drivers.Where(d => d.IsActive && _mainDriver?.Id != d.Id);

        return _drivers.Where(d =>
            d.IsActive
            && _mainDriver?.Id != d.Id
            && _helpers.All(h => h.Driver?.Id != d.Id) && d.FullName.Contains(value, StringComparison.OrdinalIgnoreCase)
        );

    }

    private void OnMainDriverChanged(DriverDto? driver)
    {
        _mainDriver = driver;
        SyncStateWithSelection();
        StateHasChanged();
    }

    private void ClearMainDriver()
    {
        _mainDriver = null;
        SyncStateWithSelection();
    }

    private void AddHelper()
    {
        if (_helpers.Count < 2)
        {
            _helpers.Add(new HelperState());
        }
    }

    private void RemoveHelper(HelperState helper)
    {
        _helpers.Remove(helper);
        SyncStateWithSelection();
    }

    private void OnHelperChanged(HelperState helper, DriverDto? driver)
    {
        helper.Driver = driver;
        SyncStateWithSelection();
        StateHasChanged();
    }



    private string GetRoleDisplay(TeamMemberRole role)
    {
        return role switch
        {
            TeamMemberRole.MainDriver => "Chauffeur Principal",
            TeamMemberRole.Helper => "Monteur",
            _ => role.ToString()
        };
    }

    private async Task<IEnumerable<DriverDto>> SearchDriversForHelper(
        HelperState currentHelper,
        string value,
        CancellationToken token)
    {
        await Task.Delay(5, token);

        return _drivers
            .Where(d => d.IsActive)
            // exclut le chauffeur principal
            .Where(d => _mainDriver == null || d.Id != _mainDriver.Id)
            // exclut les autres helpers (mais PAS le courant)
            .Where(d => _helpers.Where(h => h != currentHelper).All(h => h.Driver?.Id != d.Id))
            // filtre texte
            .Where(d =>
                string.IsNullOrWhiteSpace(value)
                || d.FullName.Contains(value, StringComparison.OrdinalIgnoreCase)
            );
    }


    private class HelperState
    {
        public Guid Id { get; } = Guid.NewGuid();
        public DriverDto? Driver { get; set; }
    }
}

@page "/tournees"
@using DropFlow.Domain.Enums
@using DropFlow.WebApp.Models.Auth
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>Feuilles de Route</PageTitle>

<AuthorizeView Roles="@Roles.ManagerOrAdmin" Context="_">
    <Authorized>
        <MudContainer MaxWidth="MaxWidth.False" Class="mt-4">

            <!-- Page header -->
            <MudPaper Elevation="0" Class="pa-4 mb-4" Style="border-left: 4px solid #55E085; background: white;">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.h5" Style="font-weight: 600; color: #1F2937;">
                            <MudIcon Icon="@Icons.Material.Filled.Route" Class="mr-2" Style="color: #4FE081;"/>
                            Tournées
                        </MudText>
                        <MudText Typo="Typo.body2" Style="color: #6B7280;">
                            Visualisez et gérez vos feuilles de route.
                        </MudText>
                    </MudStack>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="@(() => NavigationManager.NavigateTo("/tournees/create"))">
                        Nouvelle tournée
                    </MudButton>
                </MudStack>
            </MudPaper>

            <!-- Filters toolbar -->
            <MudPaper Elevation="1" Class="mb-3 px-3 py-2 rounded-lg">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">

                    <MudTextField T="string"
                                  Value="_searchTerm"
                                  ValueChanged="@OnSearchChangedAsync"
                                  Placeholder="Rechercher par référence..."
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  Clearable="true"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Style="flex: 1 1 30%;" />

                    <MudDatePicker Label="Date"
                                   Date="_filterDate"
                                   DateChanged="@OnDateChangedAsync"
                                   Clearable="true"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Placeholder="Toutes les dates"
                                   Style="flex: 1 1 25%;" />

                    <MudSelect T="RouteStatus?"
                               Label="Statut"
                               Value="_filterStatus"
                               ValueChanged="@OnStatusChangedAsync"
                               Clearable="true"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Placeholder="Tous les statuts"
                               Style="flex: 1 1 25%;">
                        @foreach (var status in Enum.GetValues<RouteStatus>())
                        {
                            <MudSelectItem Value="@((RouteStatus?)status)">
                                @GetStatusDisplay(status)
                            </MudSelectItem>
                        }
                    </MudSelect>

                </MudStack>
            </MudPaper>

            <!-- Active filters -->
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-3 px-1" Wrap="Wrap.Wrap">
                @if (!HasActiveFilters)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default"
                             Icon="@Icons.Material.Filled.FilterList">
                        Aucun filtre actif — toutes les tournées
                    </MudChip>
                }
                else
                {
                    <MudText Typo="Typo.caption" Style="color: #6B7280; margin-right: 4px;">Filtres actifs :</MudText>

                    @if (!string.IsNullOrWhiteSpace(_searchTerm))
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                                 OnClose="@ClearSearchAsync">
                            Ref : @_searchTerm
                        </MudChip>
                    }

                    @if (_filterDate.HasValue)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                                 OnClose="@ClearDateAsync">
                            Date : @_filterDate.Value.ToString("dd/MM/yyyy")
                        </MudChip>
                    }

                    @if (_filterStatus.HasValue)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                                 OnClose="@ClearStatusAsync">
                            Statut : @GetStatusDisplay(_filterStatus.Value)
                        </MudChip>
                    }

                    <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Default"
                               OnClick="ResetFilters">
                        Réinitialiser
                    </MudButton>
                }
            </MudStack>

            <!-- Data card -->
            <MudCard Elevation="2" Class="rounded-lg">
                <MudCardContent Class="p-0">
                    <MudTable Items="@_routes"
                              Hover="true"
                              Dense="true"
                              Striped="false"
                              Bordered="false"
                              Breakpoint="Breakpoint.Sm"
                              Loading="@_loading"
                              FixedHeader="true"
                              Height="60vh"
                              LoadingProgressColor="Color.Primary"
                              RowStyleFunc="@((item, i) => GetRowStyle(item))">

                        <HeaderContent>
                            <MudTh>Référence</MudTh>
                            <MudTh>Date</MudTh>
                            <MudTh Style="text-align: center;">Équipe</MudTh>
                            <MudTh Style="text-align: center;">Livraisons</MudTh>
                            <MudTh>Dist · Durée</MudTh>
                            <MudTh>Statut</MudTh>
                            <MudTh Style="width: 60px;"></MudTh>
                        </HeaderContent>

                        <RowTemplate>
                            <MudTd DataLabel="Référence">
                                <MudText Typo="Typo.body2" Class="font-weight-medium">
                                    @context.Reference
                                </MudText>
                            </MudTd>

                            <MudTd DataLabel="Date">
                                <MudText Typo="Typo.body2">
                                    @context.Date.ToString("dd/MM/yyyy")
                                </MudText>
                            </MudTd>

                            <MudTd DataLabel="Équipe" Style="text-align: center;">
                                <MudStack Spacing="0" AlignItems="AlignItems.Center">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudText Typo="Typo.body2" Class="font-weight-medium">@context.MainDriverName</MudText>
                                        @if (context.TeamCount > 1)
                                        {
                                            <MudText Typo="Typo.caption" Style="color: #6B7280;">+@(context.TeamCount - 1)</MudText>
                                        }
                                    </MudStack>
                                    <MudText Typo="Typo.caption" Style="color: #9CA3AF;">@context.VehicleName</MudText>
                                </MudStack>
                            </MudTd>

                            <MudTd DataLabel="Livraisons" Style="text-align: center;">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="0">
                                    <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Small" Style="color: #0ea5e9;" Class="mr-1"/>
                                    <MudText Typo="Typo.body2">@context.TotalDeliveries</MudText>
                                </MudStack>
                            </MudTd>

                            <MudTd DataLabel="Dist · Durée">
                                <MudText Typo="Typo.body2" Style="color: #6B7280;">
                                    @context.TotalDistance.ToString("F1") km · @FormatDuration(context.TotalDuration)
                                </MudText>
                            </MudTd>

                            <MudTd DataLabel="Statut">
                                <MudChip T="string" Size="Size.Small"
                                         Color="@GetRouteStatusColor(context.Status)"
                                         Variant="Variant.Filled"
                                         Class="df-status-chip">
                                    @context.StatusDisplay
                                </MudChip>
                            </MudTd>

                            <MudTd DataLabel="Actions">
                                <span @onclick:stopPropagation="true">
                                    <RouteStatusActions Route="@context"
                                                        ShowStatusChip="false"
                                                        OnStatusChanged="LoadRoutes"
                                                        OnEdit="@(() => Edit(context.Id))"
                                                        OnView="@(() => ViewDetails(context.Id))"
                                                        OnDelete="@(() => Delete(context.Id, context.Reference))"/>
                                </span>
                            </MudTd>
                        </RowTemplate>

                        <NoRecordsContent>
                            <MudStack AlignItems="AlignItems.Center" Class="py-8">
                                <MudIcon Icon="@Icons.Material.Filled.Route" Style="font-size: 3rem; color: #D1D5DB;"/>
                                <MudText Typo="Typo.body1" Style="color: #9CA3AF;">Aucune tournée trouvée</MudText>
                                @if (HasActiveFilters)
                                {
                                    <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="ResetFilters">
                                        Réinitialiser les filtres
                                    </MudButton>
                                }
                            </MudStack>
                        </NoRecordsContent>

                        <PagerContent>
                            <MudTablePager PageSizeOptions="new[] { 10, 25, 50, 100 }"
                                           RowsPerPageString="Lignes par page:" />
                        </PagerContent>
                    </MudTable>
                </MudCardContent>
            </MudCard>
        </MudContainer>
    </Authorized>
    <NotAuthorized>
        <RedirectToAccessDenied />
    </NotAuthorized>
</AuthorizeView>

<style>
    .df-status-chip { min-width: 90px; }
</style>

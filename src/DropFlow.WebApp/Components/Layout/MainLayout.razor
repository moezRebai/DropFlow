@inherits LayoutComponentBase
@using System.Security.Claims
@using DropFlow.WebApp.Interfaces
@using DropFlow.WebApp.Models.Auth
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject IAuthService AuthService
@implements IAsyncDisposable

<MudThemeProvider Theme="@_theme"/>
<MudPopoverProvider/>
<MudDialogProvider/>
<MudSnackbarProvider/>

<style>
    /* === GLOBAL === */
    .df-layout {
        min-height: 100vh;
    }

    /* === APPBAR === */
    .df-appbar {
        background: rgba(14, 165, 233, 0.08) !important;
        backdrop-filter: blur(20px) saturate(180%);
        -webkit-backdrop-filter: blur(20px) saturate(180%);
        border-bottom: 1px solid rgba(14, 165, 233, 0.2);
        color: #0f172a;
    }

    .df-appbar .mud-icon-button {
        color: #0284c7 !important;
    }

    .df-search {
        max-width: 300px;
    }

    .df-search .mud-input-outlined {
        border-radius: 8px;
        background: #f8fafc;
        height: 40px;
    }

    .df-user-menu {
        cursor: pointer;
        padding: 6px 12px;
        border-radius: 8px;
        transition: background 0.2s ease;
    }

    .df-user-menu:hover {
        background: #e0f2fe;
    }

    .df-user-avatar {
        background: linear-gradient(135deg, #06b6d4 0%, #14b8a6 100%);
    }

    .df-user-name {
        color: #0f172a;
        font-weight: 600;
    }

    .df-logout {
        color: #ef4444;
    }

    /* === SIDEBAR === */
    .df-sidebar {
        background: linear-gradient(180deg, #0ea5e9 0%, #0284c7 50%, #0369a1 100%) !important;
        border-right: none !important;
    }

    .df-sidebar .mud-drawer-content {
        background: transparent;
    }

    .df-sidebar-content {
        display: flex;
        flex-direction: column;
        height: 100%;
        padding: 16px 8px;
    }

    .df-divider {
        opacity: 0.15;
        flex-grow: 0;
    }

    /* Logo */
    .df-logo-section {
        padding: 8px 0 16px 0;
    }

    .df-logo-button {
        min-width: 0;
        padding: 0;
    }

    .df-logo-icon {
        width: 48px;
        height: 48px;
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(10px);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        transition: all 0.3s ease;
    }

    .df-logo-icon:hover {
        background: rgba(255, 255, 255, 0.25);
        transform: scale(1.05);
    }

    .df-logo-text {
        color: white;
        font-weight: 600;
        margin-top: 8px;
    }

    /* Navigation */
    .df-nav-menu {
        flex: 1;
        padding: 0;
        margin-top: 0 !important;
    }

    .df-nav-menu .mud-nav-link {
        color: white !important;
        margin: 1px;
        padding: 12px 12px 12px 16px !important;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        min-height: 48px;
        border-left: 3px solid transparent;
    }

    .df-nav-menu .mud-nav-link:hover {
        background: rgba(255, 255, 255, 0.12) !important;
        border-left-color: rgba(255, 255, 255, 0.3);
    }

    .df-nav-link-active {
        background: linear-gradient(90deg, rgba(255, 255, 255, 0.25) 0%, rgba(255, 255, 255, 0.15) 100%) !important;
        font-weight: 600;
        border-left: 3px solid white !important;
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
    }

    .df-nav-menu .mud-nav-link .mud-icon-root {
        color: inherit !important;
        transition: transform 0.2s ease;
    }

    .df-nav-link-active .mud-icon-root {
        transform: scale(1.15);
    }

    .df-badge {
        background: #0ea5e9;
        color: white;
        height: 20px;
        font-size: 0.7rem;
    }

    /* Footer */
    .df-sidebar-footer {
        display: flex;
        gap: 8px;
        justify-content: center;
        padding: 16px 0 8px 0;
        border-top: 1px solid rgba(255, 255, 255, 0.15);
        margin-top: auto;
    }

    .df-footer-icon {
        color: rgba(255, 255, 255, 0.8) !important;
    }

    .df-footer-icon:hover {
        background: rgba(255, 255, 255, 0.1) !important;
        color: white !important;
    }

    /* === RESPONSIVE === */
    @@media (max-width: 960px) {
        .df-search {
            display: none !important;
        }
    }

    /* === USER MENU POPOVER === */
    .df-user-menu-popover {
        border-radius: 12px !important;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04) !important;
        overflow: hidden;
        min-width: 280px;
    }

    /* Header */
    .df-user-menu-header {
        padding: 20px;
        background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
        border-bottom: 1px solid #e2e8f0;
    }

    /* Menu Items Container */
    .df-user-menu-items {
        padding: 8px 0;
    }

    /* Menu Item */
    .df-menu-item {
        padding: 12px 20px !important;
        min-height: 64px !important;
        transition: all 0.2s ease !important;
    }

    .df-menu-item:hover {
        background: #f8fafc !important;
        padding-left: 24px !important;
    }

    .df-menu-item .mud-icon-root {
        color: #64748b !important;
        font-size: 1.25rem !important;
    }

    .df-menu-item:hover .mud-icon-root {
        color: #0284c7 !important;
    }

    /* Footer */
    .df-user-menu-footer {
        padding: 8px 0;
        background: #fef2f2;
    }

    .df-menu-item-logout {
        padding: 12px 20px !important;
        transition: all 0.2s ease !important;
    }

    .df-menu-item-logout:hover {
        background: #fee2e2 !important;
        padding-left: 24px !important;
    }

    .df-menu-item-logout .mud-icon-root {
        color: #ef4444 !important;
    }
</style>

<MudLayout Class="df-layout">
    <!-- Top AppBar -->
    <MudAppBar Elevation="0" Fixed="true" Class="df-appbar">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       OnClick="DrawerToggle"
                       Edge="Edge.Start"/>
        <MudSpacer/>

        <AuthorizeView>
            <Authorized>
                <!-- Search + Actions -->
                <MudTextField Placeholder="Rechercher..."
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Outlined.Search"
                              Class="df-search"
                              Margin="Margin.Dense"
                              T="string"/>

                <MudTooltip Text="Notifications" Color="Color.Info">
                    <MudBadge Content="@_notificationCount"
                              Color="Color.Secondary"
                              Overlap="true"
                              Dot="true"
                              Visible="@(_notificationCount > 0)"
                              Class="mx-2">
                        <MudIconButton Icon="@Icons.Material.Outlined.Notifications"/>
                    </MudBadge>
                </MudTooltip>

                <MudDivider Vertical="true" FlexItem="true" Class="mx-2"/>

                <MudMenu AnchorOrigin="Origin.BottomRight"
                         TransformOrigin="Origin.TopRight"
                         PopoverClass="df-user-menu-popover">
                    <ActivatorContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="df-user-menu">
                            <MudAvatar Size="Size.Medium" Class="df-user-avatar">
                                @GetUserInitials()
                            </MudAvatar>
                            <MudHidden Breakpoint="Breakpoint.SmAndDown">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.body2" Class="df-user-name">
                                        @_userName
                                    </MudText>
                                    <MudText Typo="Typo.caption" Style="color: #64748b;">
                                        @_userRole
                                    </MudText>
                                </MudStack>
                            </MudHidden>
                            <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowDown" Size="Size.Small"/>
                        </MudStack>
                    </ActivatorContent>
                    <ChildContent>
                        <!-- Header avec infos utilisateur -->
                        <div class="df-user-menu-header">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                <MudAvatar Size="Size.Large" Class="df-user-avatar" Style="width: 48px; height: 48px;">
                                    @GetUserInitials()
                                </MudAvatar>
                                <MudStack Spacing="0" Style="flex: 1;">
                                    <MudText Typo="Typo.body1" Style="font-weight: 600; color: #0f172a;">
                                        @_userName
                                    </MudText>
                                    <MudChip T="string"
                                             Size="Size.Small"
                                             Color="Color.Primary"
                                             Variant="Variant.Filled"
                                             Style="height: 20px; font-size: 0.7rem; margin-top: 4px;">
                                        @_userRole
                                    </MudChip>
                                </MudStack>
                            </MudStack>
                        </div>

                        <MudDivider />

                        <!-- Menu Items -->
                        <div class="df-user-menu-items">
                            <MudMenuItem Icon="@Icons.Material.Outlined.Person"
                                         Href="/profile"
                                         Class="df-menu-item">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.body2" Style="font-weight: 500;">Mon profil</MudText>
                                    <MudText Typo="Typo.caption" Style="color: #64748b;">
                                        Gérer vos informations
                                    </MudText>
                                </MudStack>
                            </MudMenuItem>

                            <MudMenuItem Icon="@Icons.Material.Outlined.Settings"
                                         Href="/settings"
                                         Class="df-menu-item">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.body2" Style="font-weight: 500;">Paramètres</MudText>
                                    <MudText Typo="Typo.caption" Style="color: #64748b;">
                                        Configuration du compte
                                    </MudText>
                                </MudStack>
                            </MudMenuItem>

                            <MudMenuItem Icon="@Icons.Material.Outlined.Help"
                                         Href="/help"
                                         Class="df-menu-item">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.body2" Style="font-weight: 500;">Aide & Support</MudText>
                                    <MudText Typo="Typo.caption" Style="color: #64748b;">
                                        Centre d'assistance
                                    </MudText>
                                </MudStack>
                            </MudMenuItem>
                        </div>

                        <MudDivider />

                        <!-- Logout -->
                        <div class="df-user-menu-footer">
                            <MudMenuItem Icon="@Icons.Material.Outlined.Logout"
                                         OnClick="Logout"
                                         Class="df-menu-item-logout">
                                <MudText Typo="Typo.body2" Style="font-weight: 500; color: #ef4444;">
                                    Déconnexion
                                </MudText>
                            </MudMenuItem>
                        </div>
                    </ChildContent>
                </MudMenu>

            </Authorized>
            <NotAuthorized>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    @if (_isAuthenticated)
    {
        <!-- Sidebar -->
        <MudDrawer @bind-Open="_drawerOpen"
                   Variant="@DrawerVariant.Mini"
                   MiniWidth="68px"
                   Elevation="0"
                   ClipMode="DrawerClipMode.Never"
                   Breakpoint="Breakpoint.Md"
                   Class="df-sidebar">

            <div class="df-sidebar-content">
                <!-- Logo -->
                <MudStack AlignItems="AlignItems.Center" Class="df-logo-section">
                    <MudButton Href="/" Variant="Variant.Text" Class="df-logo-button">
                        <MudStack AlignItems="AlignItems.Center" Spacing="1">
                            <div class="df-logo-icon">
                                <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Large"/>
                            </div>
                            @if (_drawerOpen)
                            {
                                <MudText Typo="Typo.h6" Class="df-logo-text">DropFlow</MudText>
                            }
                        </MudStack>
                    </MudButton>
                </MudStack>

                <MudDivider Class="mb-2 df-divider"/>

                <!-- Navigation dynamique selon le rôle -->
                <MudNavMenu Class="df-nav-menu">

                    @* Navigation ADMIN (TenantId = 0) *@
                    @if (_user?.IsInRole(Roles.Admin) == true)
                    {
                        <MudNavLink Href="/admin/dashboard"
                                    Icon="@Icons.Material.Filled.Dashboard"
                                    Match="NavLinkMatch.All">
                            Dashboard Admin
                        </MudNavLink>

                        <MudNavLink Href="/admin/tenants"
                                    Icon="@Icons.Material.Filled.Business">
                            Gestion des Entreprises
                        </MudNavLink>

                        <MudNavLink Href="/admin/users" 
                                    Icon="@Icons.Material.Filled.People"
                                    match="NavLinkMatch.All">
                            Utilisateurs Globaux
                        </MudNavLink>
            
                        <MudNavLink Href="/admin/audit" 
                                    Icon="@Icons.Material.Filled.History">
                            Logs d'Audit
                        </MudNavLink>
                        
                        <MudDivider Class="my-2" />

                        <MudNavLink Href="/profile"
                                    Icon="@Icons.Material.Filled.Person">
                            Mon Profil
                        </MudNavLink>
                    }

                    @* Navigation MANAGER *@
                    @if (_user?.IsInRole(Roles.Manager) == true)
                    {
                        <MudNavLink Href="/dashboard"
                                    Icon="@Icons.Material.Filled.Home"
                                    Match="NavLinkMatch.All"
                                    Class="@GetNavClass("/dashboard")">
                            @if (_drawerOpen)
                            {
                                <span>Tableau de bord</span>
                            }
                        </MudNavLink>

                        <MudNavLink Href="/livraisons"
                                    Icon="@Icons.Material.Filled.LocalShipping"
                                    Class="@GetNavClass("/livraisons")">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-grow-1">
                                <span>Livraisons</span>
                                @if (_pendingDeliveries > 0)
                                {
                                    <MudChip T="int" Size="Size.Small" Class="df-badge">@_pendingDeliveries</MudChip>
                                }
                            </MudStack>
                        </MudNavLink>

                        <MudNavLink Href="/tournees"
                                    Icon="@Icons.Material.Filled.Route"
                                    Class="@GetNavClass("/tournees")">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-grow-1">
                               @if (_drawerOpen)
                               {
                                   <span>Tournées</span>
                               }
                            </MudStack>
                        </MudNavLink>
   
                        <MudNavLink Href="/clients"
                                    Icon="@Icons.Material.Filled.People"
                                    Class="@GetNavClass("/clients")">
                            @if (_drawerOpen)
                            {
                                <span>Clients</span>
                            }
                        </MudNavLink>

                        <MudNavLink Href="/invoices"  Disabled="true"
                                    Icon="@Icons.Material.Filled.Receipt"
                                    Class="@GetNavClass("/invoices")">
                            @if (_drawerOpen)
                            {
                                <span>Factures</span>
                            }
                        </MudNavLink>

                        <MudDivider Class="my-3 df-divider"/>

                        <MudNavLink Href="/profile"
                                    Icon="@Icons.Material.Filled.Person"
                                    Class="@GetNavClass("/profile")">
                            @if (_drawerOpen)
                            {
                                <span>Mon Profil</span>
                            }
                        </MudNavLink>
                        
                        <MudNavLink Href="/settings"
                                    Icon="@Icons.Material.Filled.Settings"
                                    Class="@GetNavClass("/settings")">
                            @if (_drawerOpen)
                            {
                                <span>Paramètres</span>
                            }
                        </MudNavLink>
                    }

                    @* Navigation LIVREUR *@
                    @if (_user?.IsInRole(Roles.Livreur) == true)
                    {
                        <MudNavLink Href="/personal-deliveries"
                                    Icon="@Icons.Material.Filled.LocalShipping"
                                    Match="NavLinkMatch.All"
                                    Class="@GetNavClass("/personal-deliveries")">
                            @if (_drawerOpen)
                            {
                                <span>Mes Livraisons</span>
                            }
                        </MudNavLink>

                        <MudNavLink Href="/profile"
                                    Icon="@Icons.Material.Filled.Person"
                                    Class="@GetNavClass("/profile")">
                            @if (_drawerOpen)
                            {
                                <span>Mon Profil</span>
                            }
                        </MudNavLink>
                    }

                    <MudNavLink Href="/help"
                                Icon="@Icons.Material.Filled.HelpCenter"
                                Class="@GetNavClass("/help")">
                        @if (_drawerOpen)
                        {
                            <span>Aide & Support</span>
                        }
                    </MudNavLink>
                    
                </MudNavMenu>

                <!-- Footer -->
                <div class="df-sidebar-footer">
                    <MudTooltip Text="Déconnexion" Placement="Placement.Right" Color="Color.Info">
                        <MudIconButton Icon="@Icons.Material.Outlined.Logout"
                                       Color="Color.Surface"
                                       Class="df-footer-icon"
                                       OnClick="Logout"/>
                    </MudTooltip>
                </div>
            </div>
        </MudDrawer>
    }
    <!-- Main Content -->
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-8">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = false;
    private bool _isAuthenticated;
    private ClaimsPrincipal? _user;
    private MudTheme? _theme;
    private readonly int _notificationCount = 3;
    private readonly int _pendingDeliveries = 0;

    private string _userName = string.Empty;
    private string _userRole = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _theme = new MudTheme
        {
            PaletteLight = new PaletteLight
            {
                // Brand
                Primary   = "#3D8ACE",
                Secondary = "#64748B",
                Tertiary  = "#38BDF8",

                // Semantics
                Success = "#22C55E",
                Warning = "#F59E0B",
                Error   = "#EF4444",
                Info    = "#48A0E5",

                // Neutrals / layout
                Background   = "#F8FAFC",
                Surface      = "#FFFFFF",
                Divider      = "#E2E8F0",

                // Text
                TextPrimary   = "#0F172A",
                TextSecondary = "#475569"
            },
            
            Typography = new Typography
            {
                Default = new DefaultTypography()
                {
                    FontFamily = ["Inter", "Segoe UI", "Roboto", "Arial"]
                }
            }
        };

        await LoadUserInfoAsync();
        AuthStateProvider.AuthenticationStateChanged += OnAuthStateChanged;
    }

    private void DrawerToggle() => _drawerOpen = !_drawerOpen;

    private string GetUserInitials()
    {
        if (string.IsNullOrWhiteSpace(_userName) || string.IsNullOrEmpty(_userName))
        {
            return "??";
        }

        var names = _userName.Split(' ');
        return names.Length >= 2 ? $"{names[0][0]}{names[1][0]}" : _userName[0].ToString();
    }

    private bool IsActive(string href) => new Uri(NavigationManager.Uri).AbsolutePath.Equals(href);

    private string GetNavClass(string href) => IsActive(href) ? "df-nav-link-active" : "";

    private static string GetUserRole(ClaimsPrincipal user)
    {
        if (user.IsInRole(Roles.Admin)) return "Administrateur";
        if (user.IsInRole(Roles.Manager)) return "Manager";
        return user.IsInRole(Roles.Livreur) ? "Livreur" : "Utilisateur";
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        NavigationManager.NavigateTo("/login", true);
    }

    private async Task LoadUserInfoAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _user = authState.User;
        _isAuthenticated = _user.Identity?.IsAuthenticated == true;

        if (_isAuthenticated)
        {
            _userName = _user.FindFirst(ClaimTypes.Name)?.Value
                        ?? _user.FindFirst("name")?.Value
                        ?? _user.Identity?.Name
                        ?? "Utilisateur";

            _userRole = GetUserRole(_user);
        }
        else
        {
            _userName = string.Empty;
            _userRole = string.Empty;
        }
    }

    private async void OnAuthStateChanged(Task<AuthenticationState> task)
    {
        try
        {
            await LoadUserInfoAsync();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception e)
        {
            //ignore
        }
    }

    public ValueTask DisposeAsync()
    {
        AuthStateProvider.AuthenticationStateChanged -= OnAuthStateChanged;
        return ValueTask.CompletedTask;
    }
}

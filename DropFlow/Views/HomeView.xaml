<UserControl x:Class="DropFlow.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d"
             Background="#F8FAFC">

    <UserControl.Resources>
        <!-- Modern Card Style avec shadow -->
        <Style x:Key="ModernCard" TargetType="materialDesign:Card">
            <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp2" />
            <Setter Property="Margin" Value="8" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="White" />
            <Setter Property="UniformCornerRadius" Value="12" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp6" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- KPI Card Button Style - CORRIGÉ -->
        <Style x:Key="KpiCardButton" TargetType="Button">
            <Setter Property="Padding" Value="16" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#00000008" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#00000010" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Quick Action Card Style -->
        <Style x:Key="QuickActionButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Height" Value="80" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="12" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FAFC" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- HEADER SECTION avec greeting -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Tableau de bord"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Margin="0,0,0,2" />
                    <TextBlock Text="{Binding LastSyncTime, StringFormat='Dernière mise à jour: {0:HH:mm}'}"
                               FontSize="13"
                               Opacity="0.7" />
                </StackPanel>

                <!-- KPI CARDS - Grid 4 colonnes avec animations -->
                <Grid Grid.Row="1" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Non Planned Deliveries -->
                    <materialDesign:Card Grid.Column="0" Style="{StaticResource ModernCard}">
                        <Button Style="{StaticResource KpiCardButton}"
                                Command="{Binding OpenNonPlannedDeliveriesCommand}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <materialDesign:PackIcon Kind="AlertCircle"
                                                         Height="36" Width="36"
                                                         Foreground="#EF4444"
                                                         HorizontalAlignment="Left" />

                                <TextBlock Grid.Row="1"
                                           Text="{Binding NonPlannedDeliveries}"
                                           FontSize="32"
                                           FontWeight="Bold"
                                           Foreground="#1E293B"
                                           Margin="0,8,0,0" />

                                <TextBlock Grid.Row="2"
                                           Text="Non planifiées"
                                           FontSize="13"
                                           Foreground="#64748B"
                                           Margin="0,2,0,0" />

                                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,6,0,0">
                                    <materialDesign:PackIcon Kind="TrendingUp"
                                                             Width="14" Height="14"
                                                             Foreground="#EF4444" />
                                    <TextBlock Text="{Binding NonPlannedTrend}"
                                               FontSize="11"
                                               Foreground="#EF4444"
                                               Margin="4,0,0,0" />
                                </StackPanel>
                            </Grid>
                        </Button>
                    </materialDesign:Card>

                    <!-- Deliveries Today -->
                    <materialDesign:Card Grid.Column="1" Style="{StaticResource ModernCard}">
                        <Button Style="{StaticResource KpiCardButton}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <materialDesign:PackIcon Kind="TruckDelivery"
                                                         Height="36" Width="36"
                                                         Foreground="#3B82F6"
                                                         HorizontalAlignment="Left" />

                                <TextBlock Grid.Row="1"
                                           Text="{Binding DeliveriesToday}"
                                           FontSize="32"
                                           FontWeight="Bold"
                                           Foreground="#1E293B"
                                           Margin="0,8,0,0" />

                                <TextBlock Grid.Row="2"
                                           Text="Livraisons du jour"
                                           FontSize="13"
                                           Foreground="#64748B"
                                           Margin="0,2,0,0" />

                                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,6,0,0">
                                    <materialDesign:PackIcon Kind="TrendingUp"
                                                             Width="14" Height="14"
                                                             Foreground="#10B981" />
                                    <TextBlock Text="{Binding DeliveriesTodayTrend}"
                                               FontSize="11"
                                               Foreground="#10B981"
                                               Margin="4,0,0,0" />
                                </StackPanel>
                            </Grid>
                        </Button>
                    </materialDesign:Card>

                    <!-- Pending Invoices -->
                    <materialDesign:Card Grid.Column="2" Style="{StaticResource ModernCard}">
                        <Button Style="{StaticResource KpiCardButton}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <materialDesign:PackIcon Kind="FileDocumentEdit"
                                                         Height="36" Width="36"
                                                         Foreground="#F59E0B"
                                                         HorizontalAlignment="Left" />

                                <TextBlock Grid.Row="1"
                                           Text="{Binding PendingInvoices}"
                                           FontSize="32"
                                           FontWeight="Bold"
                                           Foreground="#1E293B"
                                           Margin="0,8,0,0" />

                                <TextBlock Grid.Row="2"
                                           Text="Factures en attente"
                                           FontSize="13"
                                           Foreground="#64748B"
                                           Margin="0,2,0,0" />

                                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,6,0,0">
                                    <materialDesign:PackIcon Kind="TrendingDown"
                                                             Width="14" Height="14"
                                                             Foreground="#10B981" />
                                    <TextBlock Text="{Binding PendingInvoicesTrend}"
                                               FontSize="11"
                                               Foreground="#10B981"
                                               Margin="4,0,0,0" />
                                </StackPanel>
                            </Grid>
                        </Button>
                    </materialDesign:Card>

                    <!-- Revenue Summary -->
                    <materialDesign:Card Grid.Column="3" Style="{StaticResource ModernCard}">
                        <Button Style="{StaticResource KpiCardButton}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <materialDesign:PackIcon Kind="CashMultiple"
                                                         Height="36" Width="36"
                                                         Foreground="#10B981"
                                                         HorizontalAlignment="Left" />

                                <TextBlock Grid.Row="1"
                                           Text="{Binding RevenueSummary, StringFormat='{}{0:C}'}"
                                           FontSize="32"
                                           FontWeight="Bold"
                                           Foreground="#1E293B"
                                           Margin="0,8,0,0" />

                                <TextBlock Grid.Row="2"
                                           Text="Revenus mensuels"
                                           FontSize="13"
                                           Foreground="#64748B"
                                           Margin="0,2,0,0" />

                                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,6,0,0">
                                    <materialDesign:PackIcon Kind="TrendingUp"
                                                             Width="14" Height="14"
                                                             Foreground="#10B981" />
                                    <TextBlock Text="{Binding RevenueTrend}"
                                               FontSize="11"
                                               Foreground="#10B981"
                                               Margin="4,0,0,0" />
                                </StackPanel>
                            </Grid>
                        </Button>
                    </materialDesign:Card>
                </Grid>

                <!-- MIDDLE SECTION - Quick Actions + Notifications -->
                <Grid Grid.Row="2" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.25*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Quick Actions -->
                    <materialDesign:Card Grid.Column="0" Style="{StaticResource ModernCard}" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Actions rapides"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#1E293B"
                                       Margin="0,0,0,12" />

                            <ItemsControl ItemsSource="{Binding QuickActions}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="2" Columns="2" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource QuickActionButton}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Border Width="48" Height="48"
                                                        Background="{Binding Color}"
                                                        CornerRadius="10"
                                                        Opacity="0.1" />

                                                <materialDesign:PackIcon Kind="{Binding Icon}"
                                                                         Width="28" Height="28"
                                                                         Foreground="{Binding Color}"
                                                                         HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center" />

                                                <StackPanel Grid.Column="1"
                                                            VerticalAlignment="Center"
                                                            Margin="12,0,0,0">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="#1E293B" />
                                                    <TextBlock Text="{Binding Description}"
                                                               FontSize="11"
                                                               Foreground="#94A3B8"
                                                               Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Notifications avec badge -->
                    <materialDesign:Card Grid.Column="1" Style="{StaticResource ModernCard}" Padding="16">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="Notifications"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#1E293B"
                                           HorizontalAlignment="Left" />

                                <materialDesign:Badged Badge="{Binding UnreadNotifications}"
                                                       BadgeColorZoneMode="PrimaryMid"
                                                       HorizontalAlignment="Right">
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            Width="28" Height="28"
                                            Command="{Binding ViewAllNotificationsCommand}">
                                        <materialDesign:PackIcon Kind="DotsHorizontal" Width="20" Height="20" />
                                    </Button>
                                </materialDesign:Badged>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding Alerts}" MaxHeight="320">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding BackgroundColor}"
                                                CornerRadius="8"
                                                Padding="10"
                                                Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <materialDesign:PackIcon Kind="{Binding Icon}"
                                                                         Width="20" Height="20"
                                                                         Foreground="{Binding Color}"
                                                                         VerticalAlignment="Top"
                                                                         Margin="0,0,10,0" />

                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Message}"
                                                               FontSize="12"
                                                               FontWeight="Medium"
                                                               Foreground="#1E293B"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock
                                                        Text="{Binding Timestamp, StringFormat='Il y a {0:mm} min'}"
                                                        FontSize="10"
                                                        Foreground="#94A3B8"
                                                        Margin="0,2,0,0" />
                                                </StackPanel>

                                                <Button Grid.Column="2"
                                                        Style="{StaticResource MaterialDesignIconButton}"
                                                        Width="20" Height="20"
                                                        Command="{Binding DataContext.DismissAlertCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <materialDesign:PackIcon Kind="Close" Width="14" Height="14" />
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </materialDesign:Card>
                </Grid>

                <!-- BOTTOM SECTION - Deliveries + Chart -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Today's Deliveries -->
                    <materialDesign:Card Grid.Column="0" Style="{StaticResource ModernCard}" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Livraisons du jour"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#1E293B"
                                       Margin="0,0,0,12" />

                            <DataGrid ItemsSource="{Binding UpcomingDeliveries}"
                                      AutoGenerateColumns="False"
                                      HeadersVisibility="Column"
                                      CanUserAddRows="False"
                                      BorderThickness="0"
                                      GridLinesVisibility="Horizontal"
                                      Background="Transparent"
                                      RowBackground="Transparent"
                                      AlternatingRowBackground="#F8FAFC"
                                      RowHeight="36"
                                      materialDesign:DataGridAssist.CellPadding="10,6">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Client"
                                                        Binding="{Binding ClientName}"
                                                        Width="*"
                                                        IsReadOnly="True"
                                                        FontWeight="Medium" />
                                    <DataGridTextColumn Header="Adresse"
                                                        Binding="{Binding Address}"
                                                        IsReadOnly="True"
                                                        Width="1.5*" />
                                    <DataGridTextColumn Header="Heure"
                                                        IsReadOnly="True"
                                                        Binding="{Binding ScheduledTime, StringFormat='HH:mm'}"
                                                        Width="70" />
                                    <DataGridTemplateColumn Header="Statut" Width="90"                                                         
                                                            IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border
                                                    Background="{Binding StatusColor, Converter={StaticResource BrushToGradientConverter}}"
                                                    CornerRadius="10"
                                                    Padding="6,3"
                                                    HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding Status}"
                                                               Foreground="{Binding StatusColor}"
                                                               FontWeight="SemiBold"
                                                               FontSize="10"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Revenue Chart avec filtres -->
                    <materialDesign:Card Grid.Column="1" Style="{StaticResource ModernCard}" Padding="16">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="Revenus + Livraisons"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#1E293B"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center" />

                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right">
                                    <RadioButton Content="Semaine"
                                                 FontSize="11"
                                                 GroupName="ChartPeriod"
                                                 Style="{StaticResource MaterialDesignTabRadioButton}"
                                                 Margin="3,0"
                                                 Command="{Binding ChangePeriodCommand}"
                                                 CommandParameter="Semaine" />
                                    <RadioButton Content="Mois"
                                                 FontSize="11"
                                                 GroupName="ChartPeriod"
                                                 Style="{StaticResource MaterialDesignTabRadioButton}"
                                                 Margin="3,0"
                                                 Command="{Binding ChangePeriodCommand}"
                                                 CommandParameter="Mois" />
                                    <RadioButton Content="Année"
                                                 FontSize="11"
                                                 GroupName="ChartPeriod"
                                                 Style="{StaticResource MaterialDesignTabRadioButton}"
                                                 Margin="3,0"
                                                 IsChecked="True"
                                                 Command="{Binding ChangePeriodCommand}"
                                                 CommandParameter="Année" />
                                </StackPanel>
                            </Grid>

                            <Border Background="#F8FAFC"
                                    CornerRadius="10"
                                    Padding="12">
                                <lvc:CartesianChart Series="{Binding Series}"
                                                    XAxes="{Binding XAxes}"
                                                    YAxes="{Binding YAxes}"
                                                    Height="220"
                                                    LegendPosition="Bottom"
                                                    TooltipPosition="Top" />
                            </Border>

                            <!-- Chart Summary -->
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="10" Height="10" Fill="#10B981" Margin="0,0,6,0" />
                                        <TextBlock Text="Revenue total"
                                                   FontSize="11"
                                                   Foreground="#64748B" />
                                    </StackPanel>
                                    <TextBlock Text="1,680k €"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#1E293B"
                                               Margin="0,3,0,0" />
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="10" Height="10" Fill="#3B82F6" Margin="0,0,6,0" />
                                        <TextBlock Text="Livraisons total"
                                                   FontSize="11"
                                                   Foreground="#64748B" />
                                    </StackPanel>
                                    <TextBlock Text="444"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#1E293B"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </materialDesign:Card>
                </Grid>
            </Grid>
        </ScrollViewer>
    <!-- Floating Action Button pour nouvelle livraison -->
    <Button Style="{StaticResource MaterialDesignFloatingActionButton}"
            Command="{Binding NewDeliveryCommand}"
            ToolTip="Nouvelle livraison"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="0,0,32,32"
            Width="64"
            Height="64"
            Background="#10B981">
        <materialDesign:PackIcon Kind="Plus"
                                 Width="32"
                                 Height="32" />
    </Button>
    </Grid>
</UserControl>
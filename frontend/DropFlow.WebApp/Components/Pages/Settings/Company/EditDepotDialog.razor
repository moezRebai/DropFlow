@using DropFlow.Shared.Tenants.Depots
@using DropFlow.WebApp.Interfaces
@inject ITenantManagementService TenantService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        @if (_loading)
        {
            <div class="d-flex justify-center align-center pa-8">
                <MudProgressCircular Indeterminate="true" />
            </div>
        }
        else if (_depot == null)
        {
            <MudAlert Severity="Severity.Error">
                Impossible de charger le dépôt.
            </MudAlert>
        }
        else
        {
            <MudForm @ref="_form" @bind-IsValid="@_formValid">
                <MudGrid>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_model.Name" 
                                    Label="Nom du dépôt"
                                    Variant="Variant.Outlined"
                                    Margin="Margin.Dense"
                                    Required="true"
                                    MaxLength="100" />
                    </MudItem>
                    
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_model.FullAddress" 
                                    Label="Adresse complète"
                                    Variant="Variant.Outlined"
                                    Margin="Margin.Dense"
                                    Required="true"
                                    MaxLength="500" />
                    </MudItem>
                    
                    <MudItem xs="12" md="4">
                        <MudTextField @bind-Value="_model.ZipCode" 
                                    Label="Code postal"
                                    Variant="Variant.Outlined"
                                    Margin="Margin.Dense"
                                    MaxLength="10" />
                    </MudItem>
                    
                    <MudItem xs="12" md="8">
                        <MudTextField @bind-Value="_model.City" 
                                    Label="Ville"
                                    Variant="Variant.Outlined"
                                    Margin="Margin.Dense"
                                    MaxLength="100" />
                    </MudItem>
                    
                    <MudItem xs="12">
                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.subtitle2" Class="mb-2">
                            Coordonnées GPS
                        </MudText>
                    </MudItem>
                    
                    <MudItem xs="12" md="6">
                        <MudNumericField @bind-Value="_model.Latitude" 
                                        Label="Latitude"
                                        Variant="Variant.Outlined"
                                        Margin="Margin.Dense"
                                        Min="-90"
                                        Max="90"
                                        Format="F8" />
                    </MudItem>
                    
                    <MudItem xs="12" md="6">
                        <MudNumericField @bind-Value="_model.Longitude" 
                                        Label="Longitude"
                                        Variant="Variant.Outlined"
                                        Margin="Margin.Dense"
                                        Min="-180"
                                        Max="180"
                                        Format="F8" />
                    </MudItem>
                    
                    @if (_depot.IsDefault)
                    {
                        <MudItem xs="12">
                            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                                <MudText Typo="Typo.body2">
                                    Ce dépôt est actuellement défini comme dépôt par défaut.
                                </MudText>
                            </MudAlert>
                        </MudItem>
                    }
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Annuler</MudButton>
        <MudButton Variant="Variant.Filled" 
                  Color="Color.Primary"
                  OnClick="Submit"
                  Disabled="@(!_formValid || _saving || _loading || _depot == null)">
            @if (_saving)
            {
                <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2" />
                <span>Enregistrement...</span>
            }
            else
            {
                <span>Enregistrer</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = null!;
    
    [Parameter, EditorRequired]
    public int DepotId { get; set; }

    private MudForm _form = null!;
    private bool _formValid;
    private bool _saving;
    private bool _loading = true;
    
    private TenantDepotDto? _depot;
    private UpdateTenantDepotDto _model = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDepot();
    }

    private async Task LoadDepot()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            _depot = await TenantService.GetDepotByIdAsync(DepotId);

            if (_depot != null)
            {
                _model = new UpdateTenantDepotDto
                {
                    Name = _depot.Name,
                    FullAddress = _depot.FullAddress,
                    City = _depot.City,
                    ZipCode = _depot.ZipCode,
                    Latitude = _depot.Latitude,
                    Longitude = _depot.Longitude
                };
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur lors du chargement : {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task Submit()
    {
        if (_depot == null) return;

        _saving = true;
        StateHasChanged();

        try
        {
            var result = await TenantService.UpdateDepotAsync(DepotId, _model);

            if (result.Succeeded)
            {
                Snackbar.Add("Dépôt mis à jour avec succès", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add($"Erreur : {result.Message}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur : {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}

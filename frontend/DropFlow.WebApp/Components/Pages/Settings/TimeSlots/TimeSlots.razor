@page "/settings/crenaux"
@using DropFlow.Shared.TimeSlots
@using DropFlow.WebApp.Components.Shared
@using DropFlow.WebApp.Interfaces
@using DropFlow.WebApp.Models.Auth
@using Microsoft.AspNetCore.Components.Authorization
@inject ITimeSlotService TimeSlotService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Créneaux horaires - DropFlow</PageTitle>

<AuthorizeView Roles="@Roles.ManagerOrAdmin" Context="auth">
    <Authorized>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mb-8">

            <!-- Header -->
            <MudPaper Elevation="0" Class="pa-4 mb-4" Style="border-left: 4px solid var(--mud-palette-tertiary);">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <MudStack Spacing="1">
                        <MudBreadcrumbs Items="_breadcrumbs">
                            <ItemTemplate Context="item">
                                <MudLink Href="@item.Href" Style="color: #6B7280;">
                                    @item.Text
                                </MudLink>
                            </ItemTemplate>
                        </MudBreadcrumbs>
                        <MudText Typo="Typo.h5" Style="font-weight: 600;">
                            <MudIcon Icon="@Icons.Material.Filled.Schedule" Class="mr-2" Style="color: var(--mud-palette-tertiary);"/>
                            Créneaux horaires
                        </MudText>
                        <MudText Typo="Typo.body2" Style="color: #64748b;">
                            Configurez les plages horaires de livraison pour informer vos clients
                        </MudText>
                    </MudStack>

                    <MudFab StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialog"
                            Size="Size.Large"
                            Color="Color.Tertiary"/>
                </MudStack>
            </MudPaper>

            <!-- Liste des créneaux -->
            <MudPaper Elevation="2" Class="pa-4">
                @if (_loading)
                {
                    <MudStack AlignItems="AlignItems.Center" Class="py-8">
                        <MudProgressCircular Indeterminate="true" Color="Color.Tertiary"/>
                        <MudText Typo="Typo.body2" Style="color: #64748b;">Chargement...</MudText>
                    </MudStack>
                }
                else if (!_timeSlots.Any())
                {
                    <MudStack AlignItems="AlignItems.Center" Class="py-8" Spacing="3">
                        <MudIcon Icon="@Icons.Material.Filled.Schedule" 
                                 Size="Size.Large" 
                                 Style="font-size: 4rem; color: #CBD5E1;"/>
                        <MudText Typo="Typo.h6" Style="color: #64748b;">
                            Aucun créneau configuré
                        </MudText>
                        <MudText Typo="Typo.body2" Style="color: #94A3B8; text-align: center;">
                            Créez votre premier créneau horaire pour informer vos clients<br/>
                            du moment d'arrivée du livreur (Matin, Après-midi, etc.)
                        </MudText>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Tertiary"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="OpenCreateDialog"
                                   Class="mt-2">
                            Créer le premier créneau
                        </MudButton>
                    </MudStack>
                }
                else
                {
                    <MudTable Items="@_timeSlots.OrderBy(t => t.DisplayOrder).ThenBy(t => t.StartTime)"
                              Hover="true"
                              Dense="true"
                              Striped="true"
                              Elevation="0">
                        <HeaderContent>
                            <MudTh>Nom</MudTh>
                            <MudTh>Heure début</MudTh>
                            <MudTh>Heure fin</MudTh>
                            <MudTh>Durée</MudTh>
                            <MudTh Style="text-align: center;">Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Nom">
                                <MudText Style="font-weight: 500;">
                                    @context.Name
                                </MudText>
                            </MudTd>
                            <MudTd DataLabel="Heure début">
                                <MudChip T="string" Size="Size.Medium" Variant="Variant.Text" Color="Color.Success">
                                    🕐 @context.StartTime.ToString(@"hh\:mm")
                                </MudChip>
                            </MudTd>
                            <MudTd DataLabel="Heure fin">
                                <MudChip T="string" Size="Size.Medium" Variant="Variant.Text" Color="Color.Error">
                                    🕐 @context.EndTime.ToString(@"hh\:mm")
                                </MudChip>
                            </MudTd>
                            <MudTd DataLabel="Durée">
                                <MudText Style="color: #64748b;">
                                    @context.DurationText
                                </MudText>
                            </MudTd>
                            <MudTd DataLabel="Actions" Style="text-align: center;">
                                <MudStack Row="true" Justify="Justify.Center" Spacing="1">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                   Size="Size.Small"
                                                   Color="Color.Primary"
                                                   Title="Modifier"
                                                   OnClick="@(() => OpenEditDialog(context.Id))"/>
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Size="Size.Small"
                                                   Color="Color.Error"
                                                   Title="Supprimer"
                                                   OnClick="@(() => DeleteTimeSlot(context.Id, context.Name))"/>
                                </MudStack>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudPaper>

        </MudContainer>
    </Authorized>
    <NotAuthorized>
        <RedirectToAccessDenied/>
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<TimeSlotDto> _timeSlots = [];
    private bool _loading = true;

    private List<BreadcrumbItem> _breadcrumbs = [];

    protected override async Task OnInitializedAsync()
    {
        InitializeBreadcrumbs();
        await LoadTimeSlots();
    }

    private void InitializeBreadcrumbs()
    {
        _breadcrumbs =
        [
            new BreadcrumbItem("Paramètres", href: "/settings"),
            new BreadcrumbItem("Créneaux horaires", href: "/settings/timeslots", disabled: true)
        ];
    }

    private async Task LoadTimeSlots()
    {
        _loading = true;
        try
        {
            _timeSlots = await TimeSlotService.GetAllAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur lors du chargement : {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OpenCreateDialog()
    {
        var dialog = await DialogService.ShowAsync<TimeSlotDialog>("Nouveau créneau" , new DialogOptions()
        {
            Position   = DialogPosition.Center,
            MaxWidth = MaxWidth.ExtraLarge,
        });
        
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            await LoadTimeSlots();
        }
    }

    private async Task OpenEditDialog(int id)
    {
        var parameters = new DialogParameters<TimeSlotDialog>
        {
            { x => x.TimeSlotId, id }
        };

        var dialog = await DialogService.ShowAsync<TimeSlotDialog>("Modifier créneau", parameters,  new DialogOptions()
        {
            Position   = DialogPosition.Center,
            MaxWidth = MaxWidth.Large
        });
        
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            await LoadTimeSlots();
        }
    }

    private async Task DeleteTimeSlot(int id, string name)
    {
        var parameters = new DialogParameters<ConfirmationDialog>
        {
            { x => x.ContentText, $"Êtes-vous sûr de vouloir supprimer le créneau \"{name}\" ?" },
            { x => x.ButtonText, "Supprimer" },
            { x => x.Color, Color.Error }
        };

        var dialog = await DialogService.ShowAsync<ConfirmationDialog>("Confirmation", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            try
            {
                var deleteResult = await TimeSlotService.DeleteAsync(id);

                if (deleteResult.Succeeded)
                {
                    Snackbar.Add("Créneau supprimé avec succès", Severity.Success);
                    await LoadTimeSlots();
                }
                else
                {
                    var errorMessage = deleteResult.Errors?.FirstOrDefault() ?? "Erreur lors de la suppression";
                    Snackbar.Add(errorMessage, Severity.Warning);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Erreur : {ex.Message}", Severity.Error);
            }
        }
    }
}

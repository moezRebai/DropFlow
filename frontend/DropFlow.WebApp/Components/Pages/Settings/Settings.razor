@page "/settings"
@using DropFlow.WebApp.Interfaces
@using DropFlow.WebApp.Models.Auth
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation
@inject ITimeSlotService TimeSlotService
@inject IUserManagementService UserManagementService
@inject ISnackbar Snackbar
@inject IVehicleService VehicleService
@inject IDriverService DriverService

<PageTitle>Paramètres - DropFlow</PageTitle>

<AuthorizeView Roles="@Roles.ManagerOrAdmin">
    <Authorized>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mb-8">

            <!-- Header -->
            <MudPaper Elevation="0" Class="pa-4 mb-4" Style="border-left: 4px solid var(--mud-palette-primary);">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.h5" Style="font-weight: 600;">
                        <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-2"/>
                        Paramètres
                    </MudText>
                    <MudText Typo="Typo.body2" Style="color: #64748b;">
                        Configurez votre entreprise et gérez vos préférences
                    </MudText>
                </MudStack>
            </MudPaper>

            <!-- Grille de cartes -->
            <MudGrid>

                <!-- Utilisateurs -->
                <MudItem xs="12" md="6">
                    <MudCard Elevation="2"
                             Style="cursor: pointer; transition: all 0.3s;"
                             Class="hover-card"
                             @onclick="@(() => Navigation.NavigateTo("/settings/equipe"))">
                        <MudCardContent>
                            <MudStack Spacing="3">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                    <MudAvatar Color="Color.Primary" Size="Size.Large"
                                               Style="width: 60px; height: 60px;">
                                        <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Large"/>
                                    </MudAvatar>
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.h6" Style="font-weight: 600;">
                                            Mon équipe
                                        </MudText>
                                        <MudText Typo="Typo.body2" Style="color: #64748b;">
                                            Invitez et gérez vos collaborateurs
                                        </MudText>
                                    </MudStack>
                                </MudStack>

                                <MudText Typo="Typo.body2" Style="color: #64748b;">
                                    • Inviter de nouveaux utilisateurs<br/>
                                    • Gérer les rôles (Manager, Livreur)<br/>
                                    • Activer ou désactiver des comptes
                                </MudText>
                            </MudStack>
                        </MudCardContent>
                        <MudCardActions>
                            <MudStack Row="true" Justify="Justify.SpaceBetween" Style="width: 100%;" Class="px-4 pb-2">
                                <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Outlined">
                                    @_userCount utilisateur(s)
                                </MudChip>
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Color="Color.Primary"/>
                            </MudStack>
                        </MudCardActions>
                    </MudCard>
                </MudItem>


                <!-- Entreprise -->
                <MudItem xs="12" md="6">
                    <MudCard Elevation="2"
                             Style="cursor: pointer; transition: all 0.3s;"
                             @onclick="@(() => Navigation.NavigateTo("/settings/company"))"
                             Class="hover-card">
                        <MudCardContent>
                            <MudStack Spacing="3">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                    <MudAvatar Color="Color.Success" Size="Size.Large"
                                               Style="width: 60px; height: 60px;">
                                        <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Large"/>
                                    </MudAvatar>
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.h6" Style="font-weight: 600;">
                                            Entreprise
                                        </MudText>
                                        <MudText Typo="Typo.body2" Style="color: #64748b;">
                                            Informations de votre société
                                        </MudText>
                                    </MudStack>
                                </MudStack>

                                <MudText Typo="Typo.body2" Style="color: #64748b;">
                                    • Raison sociale et coordonnées<br/>
                                    • Logo et branding<br/>
                                    • Informations légales et dépôts
                                </MudText>
                            </MudStack>
                        </MudCardContent>
                        <MudCardActions>
                            <MudStack Row="true" Justify="Justify.SpaceBetween" Style="width: 100%;" Class="px-4 pb-2">
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Color="Color.Default"/>
                            </MudStack>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
                
                <!-- ✅ NOUVEAU : Créneaux horaires -->
                <MudItem xs="12" md="6">
                    <MudCard Elevation="2"
                             Style="cursor: pointer; transition: all 0.3s;"
                             Class="hover-card"
                             @onclick="@(() => Navigation.NavigateTo("/settings/crenaux"))">
                        <MudCardContent>
                            <MudStack Spacing="3">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                    <MudAvatar Color="Color.Tertiary" Size="Size.Large"
                                               Style="width: 60px; height: 60px;">
                                        <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Large"/>
                                    </MudAvatar>
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.h6" Style="font-weight: 600;">
                                            Créneaux horaires
                                        </MudText>
                                        <MudText Typo="Typo.body2" Style="color: #64748b;">
                                            Configurez les plages horaires de livraison
                                        </MudText>
                                    </MudStack>
                                </MudStack>

                                <MudText Typo="Typo.body2" Style="color: #64748b;">
                                    • Créer des créneaux personnalisés<br/>
                                    • Gérer les plages horaires (Matin, Après-midi...)<br/>
                                    • Informer vos clients du créneau d'arrivée
                                </MudText>
                            </MudStack>
                        </MudCardContent>
                        <MudCardActions>
                            <MudStack Row="true" Justify="Justify.SpaceBetween" Style="width: 100%;" Class="px-4 pb-2">
                                <MudChip T="string" Color="Color.Tertiary" Size="Size.Small" Variant="Variant.Outlined">
                                    @_timeSlotCount créneau(x)
                                </MudChip>
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Color="Color.Tertiary"/>
                            </MudStack>
                        </MudCardActions>
                    </MudCard>
                </MudItem>

                <!-- Véhicules -->
                <MudItem xs="12" md="6">
                    <MudCard Elevation="2"
                             Style="cursor: pointer; transition: all 0.3s;"
                             Class="hover-card"
                             @onclick="@(() => Navigation.NavigateTo("/settings/vehicules"))">
                        <MudCardContent>
                            <MudStack Spacing="3">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                    <MudAvatar Color="Color.Warning" Size="Size.Large"
                                               Style="width: 60px; height: 60px;">
                                        <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Large"/>
                                    </MudAvatar>
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.h6" Style="font-weight: 600;">
                                            Véhicules
                                        </MudText>
                                        <MudText Typo="Typo.body2" Style="color: #64748b;">
                                            Gérez votre flotte de véhicules
                                        </MudText>
                                    </MudStack>
                                </MudStack>

                                <MudText Typo="Typo.body2" Style="color: #64748b;">
                                    • Ajouter des véhicules<br/>
                                    • Gérer les immatriculations et capacités<br/>
                                    • Suivre la disponibilité
                                </MudText>
                            </MudStack>
                        </MudCardContent>
                        <MudCardActions>
                            <MudStack Row="true" Justify="Justify.SpaceBetween" Style="width: 100%;" Class="px-4 pb-2">
                                <MudChip T="string" Color="Color.Warning" Size="Size.Small" Variant="Variant.Outlined">
                                    @_vehicleCount véhicule(s)
                                </MudChip>
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Color="Color.Secondary"/>
                            </MudStack>
                        </MudCardActions>
                    </MudCard>
                </MudItem>

                <!-- Livreurs -->
                <MudItem xs="12" md="6">
                    <MudCard Elevation="2"
                             Style="cursor: pointer; transition: all 0.3s;"
                             Class="hover-card"
                             @onclick="@(() => Navigation.NavigateTo("/settings/livreurs"))">
                        <MudCardContent>
                            <MudStack Spacing="3">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                    <MudAvatar Color="Color.Success" Size="Size.Large"
                                               Style="width: 60px; height: 60px;">
                                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Large"/>
                                    </MudAvatar>
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.h6" Style="font-weight: 600;">
                                            Livreurs
                                        </MudText>
                                        <MudText Typo="Typo.body2" Style="color: #64748b;">
                                            Gérez vos chauffeurs livreurs
                                        </MudText>
                                    </MudStack>
                                </MudStack>

                                <MudText Typo="Typo.body2" Style="color: #64748b;">
                                    • Lier livreurs aux utilisateurs<br/>
                                    • Gérer les permis et véhicules<br/>
                                    • Suivre la disponibilité
                                </MudText>
                            </MudStack>
                        </MudCardContent>
                        <MudCardActions>
                            <MudStack Row="true" Justify="Justify.SpaceBetween" Style="width: 100%;" Class="px-4 pb-2">
                                <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Outlined">
                                    @_driverCount livreur(s)
                                </MudChip>
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Color="Color.Info"/>
                            </MudStack>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
                
                <!-- Enseignes -->
                <MudItem xs="12" md="6">
                    <MudCard Elevation="2"
                             Style="cursor: pointer; transition: all 0.3s;"
                             @onclick="@(() => Navigation.NavigateTo("/settings/enseignes"))"
                    Class="hover-card">
                        <MudCardContent>
                            <MudStack Spacing="3">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                    <MudAvatar Color="Color.Info" Size="Size.Large" Style="width: 60px; height: 60px;">
                                        <MudIcon Icon="@Icons.Material.Filled.Storefront" Size="Size.Large"/>
                                    </MudAvatar>
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.h6" Style="font-weight: 600;">
                                            Enseignes
                                        </MudText>
                                        <MudText Typo="Typo.body2" Style="color: #64748b;">
                                            Configurez vos enseignes
                                        </MudText>
                                    </MudStack>
                                </MudStack>

                                <MudText Typo="Typo.body2" Style="color: #64748b;">
                                    • Ajouter/supprimer des enseignes<br/>
                                    • Activer/ désactiver des enseignes<br/>
                                    • Suivre l activité d une enseigne<br/>
                                </MudText>
                            </MudStack>
                        </MudCardContent>
                        <MudCardActions>
                            <MudStack Row="true" Justify="Justify.SpaceBetween" Style="width: 100%;" Class="px-4 pb-2">
                                <MudChip T="string" Color="Color.Default" Size="Size.Small" Variant="Variant.Outlined">
                                    @_driverCount enseigne(s)
                                </MudChip>
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Color="Color.Default"/>
                            </MudStack>
                        </MudCardActions>
                    </MudCard>
                </MudItem>

                <!-- Facturation -->
                <MudItem xs="12" md="6">
                    <MudCard Elevation="2"
                             Style="cursor: pointer; transition: all 0.3s; opacity: 0.6;"
                             Class="hover-card">
                        <MudCardContent>
                            <MudStack Spacing="3">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                    <MudAvatar Color="Color.Warning" Size="Size.Large"
                                               Style="width: 60px; height: 60px;">
                                        <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Large"/>
                                    </MudAvatar>
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.h6" Style="font-weight: 600;">
                                            Facturation
                                        </MudText>
                                        <MudText Typo="Typo.body2" Style="color: #64748b;">
                                            Paramètres de facturation
                                        </MudText>
                                    </MudStack>
                                </MudStack>

                                <MudText Typo="Typo.body2" Style="color: #64748b;">
                                    • Templates de factures<br/>
                                    • Numérotation automatique<br/>
                                    • Conditions de paiement
                                </MudText>
                            </MudStack>
                        </MudCardContent>
                        <MudCardActions>
                            <MudStack Row="true" Justify="Justify.SpaceBetween" Style="width: 100%;" Class="px-4 pb-2">
                                <MudChip T="string" Color="Color.Default" Size="Size.Small" Variant="Variant.Outlined">
                                    Bientôt disponible
                                </MudChip>
                                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Color="Color.Default"/>
                            </MudStack>
                        </MudCardActions>
                    </MudCard>
                </MudItem>

            </MudGrid>
        </MudContainer>

        <style>
            .hover-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1) !important;
            }
        </style>


    </Authorized>
    <NotAuthorized>
        <RedirectToAccessDenied/>
    </NotAuthorized>
</AuthorizeView>

@code {
    private int _userCount;
    private int _timeSlotCount; // ✅ NOUVEAU
    private int _vehicleCount;
    private int _driverCount;
    protected override async Task OnInitializedAsync()
    {
        await LoadStats();
        await LoadUsers();
    }

    private async Task LoadStats()
    {
        try
        {
            // TimeSlots
            var timeSlots = await TimeSlotService.GetAllAsync();
            _timeSlotCount = timeSlots.Count;

            // Véhicules
            var vehicles = await VehicleService.GetAllVehiclesAsync();
            _vehicleCount = vehicles.Count;

            // Livreurs
            var drivers = await DriverService.GetAllAsync();
            _driverCount = drivers.Count;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur LoadStats: {ex.Message}", Severity.Error);
        }
    }

    private async Task LoadUsers()
    {
        try
        {
            var users = await UserManagementService.GetUsersAsync(
                includeDeactivated: true,
                includeDeleted: false);

            _userCount = users.Count;
        }
        catch (Exception ex)
        {
            Snackbar.Add("Erreur lors du chargement des utilisateurs", Severity.Error);
        }
    }

}

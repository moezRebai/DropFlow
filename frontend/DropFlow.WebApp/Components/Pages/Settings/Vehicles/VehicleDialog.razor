@using DropFlow.Shared.Vehicles
@using DropFlow.WebApp.Interfaces
@inject IVehicleService VehicleService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="@_isValid">
            <MudStack Spacing="3">

                <!-- Marque -->
                <MudTextField @bind-Value="_model.Brand"
                              Label="Marque"
                              Variant="Variant.Outlined"
                              Required="true"
                              RequiredError="La marque est obligatoire"
                              Placeholder="Ex: Renault, Peugeot, Mercedes..."
                              MaxLength="50"
                              Counter="50"
                              Immediate="true"
                              AdornmentIcon="@Icons.Material.Filled.DirectionsCar"
                              Adornment="Adornment.Start"
                              HelperText="Marque du véhicule"/>

                <!-- Modèle -->
                <MudTextField @bind-Value="_model.Model"
                              Label="Modèle"
                              Variant="Variant.Outlined"
                              Required="true"
                              RequiredError="Le modèle est obligatoire"
                              Placeholder="Ex: Master, Boxer, Sprinter..."
                              MaxLength="50"
                              Counter="50"
                              Immediate="true"
                              AdornmentIcon="@Icons.Material.Filled.LocalShipping"
                              Adornment="Adornment.Start"
                              HelperText="Modèle du véhicule"/>

                <!-- Plaque d'immatriculation -->
                <MudTextField @bind-Value="_model.PlateNumber"
                              Label="Immatriculation"
                              Variant="Variant.Outlined"
                              Required="true"
                              RequiredError="L'immatriculation est obligatoire"
                              Placeholder="Ex: AB-123-CD"
                              MaxLength="20"
                              Counter="20"
                              Immediate="true"
                              AdornmentIcon="@Icons.Material.Filled.Pin"
                              Adornment="Adornment.Start"
                              HelperText="Numéro de plaque d'immatriculation"/>

                <MudDivider Class="my-2"/>

                <MudText Typo="Typo.subtitle2" Style="color: #64748b;">
                    <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Small" Class="mr-1"/>
                    Capacités
                </MudText>

                <!-- Nombre maximum de livraisons -->
                <MudNumericField @bind-Value="_model.MaxDeliveries"
                                 Label="Nombre maximum de livraisons"
                                 Variant="Variant.Outlined"
                                 Required="true"
                                 RequiredError="Le nombre maximum de livraisons est obligatoire"
                                 Min="1"
                                 Step="1"
                                 Immediate="true"
                                 AdornmentIcon="@Icons.Material.Filled.Inbox"
                                 Adornment="Adornment.Start"
                                 HelperText="Nombre de livraisons que peut transporter le véhicule"/>

                <!-- Volume maximum -->
                <MudNumericField @bind-Value="_model.MaxVolume"
                                 Label="Volume maximum (m³)"
                                 Variant="Variant.Outlined"
                                 Required="true"
                                 RequiredError="Le volume maximum est obligatoire"
                                 Min="1"
                                 Step="1"
                                 Immediate="true"
                                 AdornmentIcon="@Icons.Material.Filled.Straighten"
                                 Adornment="Adornment.Start"
                                 HelperText="Capacité volumétrique en mètres cubes"/>

                <!-- IsActive (visible en mode Edit) -->
                @if (_isEditMode)
                {
                    <MudSwitch @bind-Value="_isActive"
                               Color="Color.Success"
                               Label="Véhicule actif"/>
                }

                <!-- Aperçu -->
                @if (!string.IsNullOrWhiteSpace(_model.Brand) && !string.IsNullOrWhiteSpace(_model.Model))
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                        <MudText Typo="Typo.body2">
                            <strong>Aperçu :</strong> @_model.Brand @_model.Model
                            @if (!string.IsNullOrWhiteSpace(_model.PlateNumber))
                            {
                                <span> (@_model.PlateNumber)</span>
                            }
                            @if (_model.MaxDeliveries > 0)
                            {
                                <br/>
                                <span Style="color: #64748b;">📦 Max @_model.MaxDeliveries livraisons • 📏 @_model.MaxVolume m³</span>
                            }
                        </MudText>
                    </MudAlert>
                }

            </MudStack>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel"
                   Disabled="_saving">
            Annuler
        </MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Secondary"
                   OnClick="Save"
                   Disabled="@(!_isValid || _saving)">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2"/>
                <span>Enregistrement...</span>
            }
            else
            {
                <span>Enregistrer</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public int? VehicleId { get; set; }
    [Parameter] public VehicleDto? ExistingVehicle { get; set; }

    private MudForm _form = default!;
    private bool _isValid;
    private bool _saving;
    private bool _isEditMode;
    private bool _isActive = true;

    private VehicleModel _model = new();

    protected override void OnInitialized()
    {
        _isEditMode = VehicleId.HasValue;

        if (_isEditMode && ExistingVehicle != null)
        {
            _model = new VehicleModel
            {
                Brand = ExistingVehicle.Brand,
                Model = ExistingVehicle.Model,
                PlateNumber = ExistingVehicle.PlateNumber,
                MaxDeliveries = ExistingVehicle.MaxDeliveries,
                MaxVolume = ExistingVehicle.MaxVolume
            };
            _isActive = ExistingVehicle.IsActive;
        }
        else
        {
            // Valeurs par défaut pour création
            _model.MaxDeliveries = 10;
            _model.MaxVolume = 15;
        }
    }

    private async Task Save()
    {
        await _form.Validate();
        if (!_isValid) return;

        // Validation : MaxDeliveries et MaxVolume > 0
        if (_model.MaxDeliveries <= 0)
        {
            Snackbar.Add("Le nombre maximum de livraisons doit être supérieur à 0", Severity.Error);
            return;
        }

        if (_model.MaxVolume <= 0)
        {
            Snackbar.Add("Le volume maximum doit être supérieur à 0", Severity.Error);
            return;
        }

        _saving = true;

        try
        {
            if (_isEditMode && VehicleId.HasValue)
            {
                // Modification
                var dto = new UpdateVehicleDto
                {
                    Brand = _model.Brand,
                    Model = _model.Model,
                    PlateNumber = _model.PlateNumber,
                    MaxDeliveries = _model.MaxDeliveries,
                    MaxVolume = _model.MaxVolume,
                    IsActive = _isActive
                };

                var result = await VehicleService.UpdateVehicleAsync(VehicleId.Value, dto);

                if (result.Succeeded)
                {
                    Snackbar.Add("Véhicule modifié avec succès", Severity.Success);
                    MudDialog.Close(DialogResult.Ok(true));
                }
                else
                {
                    var errorMessage = result.Errors?.FirstOrDefault() ?? "Erreur lors de la modification";
                    Snackbar.Add(errorMessage, Severity.Error);
                }
            }
            else
            {
                // Création
                var dto = new CreateVehicleDto
                {
                    Brand = _model.Brand,
                    Model = _model.Model,
                    PlateNumber = _model.PlateNumber,
                    MaxDeliveries = _model.MaxDeliveries,
                    MaxVolume = _model.MaxVolume
                };

                var result = await VehicleService.CreateVehicleAsync(dto);

                if (result.Succeeded)
                {
                    Snackbar.Add("Véhicule créé avec succès", Severity.Success);
                    MudDialog.Close(DialogResult.Ok(true));
                }
                else
                {
                    var errorMessage = result.Errors?.FirstOrDefault() ?? "Erreur lors de la création";
                    Snackbar.Add(errorMessage, Severity.Error);
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur : {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    // Model interne
    private class VehicleModel
    {
        public string Brand { get; set; } = string.Empty;
        public string Model { get; set; } = string.Empty;
        public string PlateNumber { get; set; } = string.Empty;
        public int MaxDeliveries { get; set; }
        public int MaxVolume { get; set; }
    }
}

@page "/help"

<PageTitle>Aide & Support - DropFlow</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mb-8">
    <!-- Header -->
    <MudStack Spacing="2" Class="mb-6">
        <MudText Typo="Typo.h4" Style="font-weight: 600; color: #0f172a;">
            Centre d'Aide & Support
        </MudText>
        <MudText Typo="Typo.body1" Style="color: #64748b;">
            Trouvez rapidement des réponses à vos questions et accédez à nos ressources d'assistance
        </MudText>
    </MudStack>

    <!-- Barre de recherche -->
    <MudCard Class="mb-6" Elevation="0" Style="border: 1px solid #e2e8f0; ">
        <MudCardContent>
            <MudTextField @bind-Value="searchQuery"
                          Placeholder="Rechercher dans l'aide..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Variant="Variant.Outlined"
                          FullWidth="true"
                          Immediate="true"
                          OnKeyUp="HandleSearch"
                          Style="background: white;" />
        </MudCardContent>
    </MudCard>

    <MudGrid>
        <!-- Colonne gauche - Catégories -->
        <MudItem xs="12" md="3">
            <MudPaper Elevation="0" Class="pa-4" Style="border: 1px solid #e2e8f0;  position: sticky; top: 20px;">
                <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600; color: #0f172a;">
                    Catégories
                </MudText>
                
                <MudNavMenu>
                    @foreach (var category in categories)
                    {
                        <MudNavLink OnClick="@(() => SelectCategory(category.Id))"
                                    Style="@GetCategoryStyle(category.Id)"
                                    Icon="@category.Icon">
                            @category.Name
                        </MudNavLink>
                    }
                </MudNavMenu>

                <MudDivider Class="my-4" />

                <!-- Contact rapide -->
                <MudText Typo="Typo.subtitle2" Class="mb-2" Style="font-weight: 600; color: #0f172a;">
                    Besoin d'aide ?
                </MudText>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Email"
                           FullWidth="true"
                           OnClick="OpenContactSupport"
                           Style="border-radius: 8px; text-transform: none;">
                    Contacter le support
                </MudButton>
            </MudPaper>
        </MudItem>

        <!-- Colonne droite - Contenu -->
        <MudItem xs="12" md="9">
            <!-- Quick Links -->
            @if (selectedCategory == null)
            {
                <MudGrid Class="mb-6">
                    @foreach (var quickLink in quickLinks)
                    {
                        <MudItem xs="12" sm="6" md="4">
                            <MudCard Class="df-help-card" 
                                     Style="cursor: pointer; border: 1px solid #e2e8f0;  height: 100%;"
                                     @onclick="@(() => SelectCategory(quickLink.CategoryId))">
                                <MudCardContent>
                                    <MudStack Spacing="2" AlignItems="AlignItems.Center" Class="text-center">
                                        <MudIcon Icon="@quickLink.Icon" 
                                                 Size="Size.Large" 
                                                 Style="@($"color: {quickLink.Color};")" />
                                        <MudText Typo="Typo.h6" Style="font-weight: 600;">
                                            @quickLink.Title
                                        </MudText>
                                        <MudText Typo="Typo.body2" Style="color: #64748b;">
                                            @quickLink.Description
                                        </MudText>
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                    }
                </MudGrid>

                <!-- Articles populaires -->
                <MudCard Elevation="0" Class="mb-4" Style="border: 1px solid #e2e8f0; ">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6" Style="font-weight: 600;">
                                📚 Articles populaires
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudList T="string">
                            @foreach (var article in popularArticles)
                            {
                                <MudListItem T="string" Icon="@Icons.Material.Outlined.Article"
                                             OnClick="@(() => ShowArticle(article))"
                                             Class="rounded-lg hover-highlight">
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.body1" Style="font-weight: 500;">
                                            @article.Title
                                        </MudText>
                                        <MudText Typo="Typo.caption" Style="color: #64748b;">
                                            @article.ViewCount vues • @article.Category
                                        </MudText>
                                    </MudStack>
                                </MudListItem>
                                @if (article != popularArticles.Last())
                                {
                                    <MudDivider />
                                }
                            }
                        </MudList>
                    </MudCardContent>
                </MudCard>
            }
            else
            {
                <!-- Contenu de la catégorie -->
                <MudCard Elevation="0" Style="border: 1px solid #e2e8f0; ">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                                               OnClick="@(() => selectedCategory = null)"
                                               Size="Size.Small" />
                                <MudText Typo="Typo.h6" Style="font-weight: 600;">
                                    @GetSelectedCategoryName()
                                </MudText>
                            </MudStack>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (selectedCategory == "getting-started")
                        {
                            <GettingStartedContent />
                        }
                        else if (selectedCategory == "deliveries")
                        {
                            <DeliveriesHelpContent />
                        }
                        else if (selectedCategory == "invoicing")
                        {
                            <InvoicingHelpContent />
                        }
                        else if (selectedCategory == "clients")
                        {
                            <ClientsHelpContent />
                        }
                        else if (selectedCategory == "stock")
                        {
                            <StockHelpContent />
                        }
                        else if (selectedCategory == "settings")
                        {
                            <SettingsHelpContent />
                        }
                    </MudCardContent>
                </MudCard>
            }

            <!-- Ressources supplémentaires -->
            <MudGrid Class="mt-6">
                <MudItem xs="12" sm="6">
                    <MudCard Elevation="0" Style="border: 1px solid #e2e8f0;  height: 100%;">
                        <MudCardContent>
                            <MudStack Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.VideoLibrary" 
                                         Size="Size.Large" 
                                         Style="color: #3b82f6;" />
                                <MudText Typo="Typo.h6" Style="font-weight: 600;">
                                    Tutoriels vidéo
                                </MudText>
                                <MudText Typo="Typo.body2" Style="color: #64748b;">
                                    Apprenez à utiliser DropFlow avec nos tutoriels vidéo détaillés
                                </MudText>
                                <MudButton Variant="Variant.Text" 
                                           Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.PlayArrow"
                                           OnClick="OpenVideoTutorials">
                                    Voir les tutoriels
                                </MudButton>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudCard Elevation="0" Style="border: 1px solid #e2e8f0;  height: 100%;">
                        <MudCardContent>
                            <MudStack Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.MenuBook" 
                                         Size="Size.Large" 
                                         Style="color: #10b981;" />
                                <MudText Typo="Typo.h6" Style="font-weight: 600;">
                                    Documentation API
                                </MudText>
                                <MudText Typo="Typo.body2" Style="color: #64748b;">
                                    Documentation technique complète pour les développeurs
                                </MudText>
                                <MudButton Variant="Variant.Text" 
                                           Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.Code"
                                           OnClick="OpenApiDocs">
                                    Documentation API
                                </MudButton>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudItem>
    </MudGrid>
</MudContainer>

<!-- Dialog Contact Support -->
<MudDialog @bind-IsVisible="showContactDialog" Options="dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6" Style="font-weight: 600;">
            <MudIcon Icon="@Icons.Material.Filled.Email" Class="mr-2" />
            Contacter le support
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="supportRequest.Subject"
                          Label="Sujet"
                          Variant="Variant.Outlined"
                          Required="true" />
            
            <MudSelect @bind-Value="supportRequest.Category"
                       Label="Catégorie"
                       Variant="Variant.Outlined"
                       Required="true">
                <MudSelectItem Value="@("Problème technique")">Problème technique</MudSelectItem>
                <MudSelectItem Value="@("Question facturation")">Question facturation</MudSelectItem>
                <MudSelectItem Value="@("Demande de fonctionnalité")">Demande de fonctionnalité</MudSelectItem>
                <MudSelectItem Value="@("Autre")">Autre</MudSelectItem>
            </MudSelect>

            <MudTextField @bind-Value="supportRequest.Message"
                          Label="Message"
                          Variant="Variant.Outlined"
                          Lines="6"
                          Required="true" />

            <MudAlert Severity="Severity.Info" Dense="true">
                Notre équipe vous répondra dans les 24h ouvrées
            </MudAlert>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseContactDialog" Variant="Variant.Text">
            Annuler
        </MudButton>
        <MudButton OnClick="SubmitSupportRequest" 
                   Variant="Variant.Filled" 
                   Color="Color.Primary"
                   Disabled="@(!IsValidSupportRequest())">
            Envoyer
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- Dialog Article -->
<MudDialog @bind-IsVisible="showArticleDialog" Options="articleDialogOptions">
    <TitleContent>
        @if (selectedArticle != null)
        {
            <MudText Typo="Typo.h6" Style="font-weight: 600;">
                @selectedArticle.Title
            </MudText>
        }
    </TitleContent>
    <DialogContent>
        @if (selectedArticle != null)
        {
            <MudStack Spacing="3">
                <MudChip T="string" Size="Size.Small" Color="Color.Info">
                    @selectedArticle.Category
                </MudChip>
                
                <MudText Typo="Typo.body1" Style="white-space: pre-line;">
                    @selectedArticle.Content
                </MudText>

                <MudDivider />

                <MudStack Row="true" Spacing="2">
                    <MudText Typo="Typo.caption" Style="color: #64748b;">
                        Cet article vous a-t-il été utile ?
                    </MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.ThumbUp" 
                                   Size="Size.Small" 
                                   Color="Color.Success" />
                    <MudIconButton Icon="@Icons.Material.Filled.ThumbDown" 
                                   Size="Size.Small" 
                                   Color="Color.Error" />
                </MudStack>
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseArticleDialog" Variant="Variant.Text">
            Fermer
        </MudButton>
    </DialogActions>
</MudDialog>


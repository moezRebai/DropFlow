@using DropFlow.Shared.Vehicles

<MudPaper Class="pa-4" Elevation="0">

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true"/>
    }
    else
    {
        <MudGrid>

            <!-- Date -->
            <MudItem xs="12" md="6">
                <MudDatePicker
                    Date="State.Date"
                    Label="Date *"
                    Variant="Variant.Outlined"
                    MinDate="DateTime.Today"
                    Required="true"
                    RequiredError="La date est obligatoire"
                    DateChanged="OnDateChanged"
                    Editable="true"
                    AdornmentIcon="@Icons.Material.Filled.CalendarMonth"
                    AdornmentColor="Color.Primary"/>

                @if (_checkingDeliveries)
                {
                    <MudText Typo="Typo.caption" Color="Color.Info" Class="mt-1">
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1"/>
                        Vérification...
                    </MudText>
                }
                else if (_availableDeliveriesCount.HasValue)
                {
                    @if (_availableDeliveriesCount.Value > 0)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Success" Class="mt-1">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Class="mr-1"/>
                            @_availableDeliveriesCount livraison@(_availableDeliveriesCount > 1 ? "s" : "") disponible@(_availableDeliveriesCount > 1 ? "s" : "")
                        </MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Color="Color.Warning" Class="mt-1">
                            <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" Class="mr-1"/>
                            Aucune livraison disponible pour cette date
                        </MudText>
                    }
                }
            </MudItem>

            <!-- Heure de départ -->
            <MudItem xs="12" md="6">
                <MudTimePicker
                    Time="State.StartTime"
                    Label="Heure de départ"
                    Variant="Variant.Outlined"
                    TimeChanged="@(t => OnFieldChanged(timeSpan: t))"
                    Editable="true"
                    AdornmentIcon="@Icons.Material.Filled.Schedule"
                    AdornmentColor="Color.Primary"/>
            </MudItem>

            <!-- Sélection véhicule -->
            <MudItem xs="12">
                <MudAutocomplete
                    T="VehicleDto"
                    Value="_selectedVehicle"
                    Label="Véhicule *"
                    SearchFunc="SearchVehicles"
                    ToStringFunc="@(v => v?.DisplayName ?? string.Empty)"
                    Variant="Variant.Outlined"
                    Clearable="true"
                    ResetValueOnEmptyText="true"
                    CoerceText="true"
                    OnClearButtonClick="ClearVehicle"
                    Required="true"
                    RequiredError="Veuillez sélectionner un véhicule"
                    ValueChanged="OnVehicleChanged"
                    AdornmentIcon="@Icons.Material.Filled.LocalShipping"
                    AdornmentColor="Color.Primary">
                    <ItemTemplate Context="vehicle">
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                            <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Small" Color="Color.Primary"/>
                            <div>
                                <MudText Typo="Typo.body2">@vehicle.DisplayName</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @vehicle.PlateNumber
                                </MudText>
                            </div>
                        </MudStack>
                    </ItemTemplate>
                    <NoItemsTemplate>
                        <MudText Typo="Typo.body2" Color="Color.Warning">
                            Aucun véhicule disponible
                        </MudText>
                    </NoItemsTemplate>
                </MudAutocomplete>
            </MudItem>
            <!-- Sélection dépôt -->
            <MudItem xs="12">
                <MudAutocomplete
                    T="DepotOption"
                    Value="_selectedDepot"
                    Label="Dépôt de départ *"
                    SearchFunc="SearchDepots"
                    ToStringFunc="@(d => d?.DisplayText ?? string.Empty)"
                    Variant="Variant.Outlined"
                    Clearable="true"
                    ResetValueOnEmptyText="false"
                    CoerceText="true"
                    Required="true"
                    RequiredError="Veuillez sélectionner un dépôt ou une autre adresse"
                    ValueChanged="OnDepotChanged"
                    AdornmentIcon="@Icons.Material.Filled.Warehouse"
                    AdornmentColor="Color.Primary">
                    <ItemTemplate Context="depot">
                        @if (depot.IsCustomAddress)
                        {
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.EditLocation" Size="Size.Small" Color="Color.Info"/>
                                <MudText Typo="Typo.body2" Color="Color.Info">
                                    📍 Autre adresse (saisie manuelle)
                                </MudText>
                            </MudStack>
                        }
                        else
                        {
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.Warehouse" Size="Size.Small" Color="@(depot.IsDefault ? Color.Primary : Color.Default)"/>
                                <div>
                                    <MudText Typo="Typo.body2">
                                        @depot.DisplayText
                                        @if (depot.IsDefault)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text" Class="ml-1">Par défaut</MudChip>
                                        }
                                    </MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @depot.Address
                                    </MudText>
                                </div>
                            </MudStack>
                        }
                    </ItemTemplate>
                </MudAutocomplete>
            </MudItem>

            <!-- Adresse (readonly pour dépôt, éditable pour autre adresse) -->
            <MudItem xs="12">
                @if (_isCustomAddress)
                {
                    <!-- Mode saisie manuelle avec autocomplete Google -->
                    <MudTextField
                        T="string"
                        @ref="_addressField"
                        Value="State.DepartureAddress"
                        Label="Adresse personnalisée *"
                        Variant="Variant.Outlined"
                        Required="true"
                        RequiredError="L'adresse est obligatoire"
                        ValueChanged="@(_ => OnFieldChanged())"
                        Adornment="Adornment.End"
                        AdornmentIcon="@Icons.Material.Filled.MyLocation"
                        AdornmentColor="Color.Primary"
                        id="address-field"
                        Class="custom-address-field"/>
                    <MudText Typo="Typo.caption" Color="Color.Info" Class="mt-1">
                        💡 Commencez à saisir pour obtenir des suggestions d'adresses
                    </MudText>
                }
                else if (_selectedDepot?.Depot != null)
                {
                    <!-- Mode lecture seule (dépôt sélectionné) -->
                    <MudTextField
                        T="string?"
                        Value="@_selectedDepot.Depot.FormattedAddress"
                        Label="Adresse du dépôt"
                        Variant="Variant.Outlined"
                        ReadOnly="true"
                        Adornment="Adornment.End"
                        AdornmentIcon="@Icons.Material.Filled.Place"
                        AdornmentColor="Color.Success"/>

                    @if (_selectedDepot.Depot.HasGpsCoordinates)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Success" Class="mt-1">
                            <MudIcon Icon="@Icons.Material.Filled.GpsFixed" Size="Size.Small" Class="mr-1"/>
                            Coordonnées GPS disponibles
                        </MudText>
                    }
                }
            </MudItem>
        </MudGrid>
    }
</MudPaper>

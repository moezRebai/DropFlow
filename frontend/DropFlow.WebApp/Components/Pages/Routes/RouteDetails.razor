@page "/tournees/{Id:int}"
@using DropFlow.Shared.Enums
@using DropFlow.Shared.Routes
@using DropFlow.WebApp.Interfaces
@inject IRouteService RouteService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JsRuntime

<PageTitle>Tournée — @_route?.Reference</PageTitle>

@if (_loading)
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="d-flex flex-column align-center justify-center mt-16">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-4">Chargement...</MudText>
    </MudContainer>
}
else if (_route == null)
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
        <MudAlert Severity="Severity.Error">Tournée introuvable</MudAlert>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/tournees" Class="mt-4"
                   StartIcon="@Icons.Material.Filled.ArrowBack">
            Retour à la liste
        </MudButton>
    </MudContainer>
}
else
{
    <MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4">

        <!-- Header -->
        <MudPaper Elevation="1" Class="pa-4 mb-4 rounded-lg">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                    <MudAvatar Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Large">
                        <MudIcon Icon="@Icons.Material.Filled.Route" />
                    </MudAvatar>
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.h5" Class="font-weight-bold">@_route.Reference</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Créée le @_route.CreatedDate.ToString("dd/MM/yyyy à HH:mm") par @_route.CreatedBy
                        </MudText>
                    </MudStack>
                    @GetStatusChip(_route.Status)
                </MudStack>
                <MudStack Row="true" Spacing="2">
                    @if (_route.Status == RouteStatus.Draft)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Edit"
                                   Href="@($"/tournees/edit/{_route.Id}")">
                            Modifier
                        </MudButton>
                    }
                    @if (_route.Status == RouteStatus.Confirmed)
                    {
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Success"
                                   StartIcon="@Icons.Material.Filled.PlayArrow"
                                   OnClick="StartRoute">
                            Démarrer
                        </MudButton>
                    }
                    @if (_route.Status == RouteStatus.InProgress)
                    {
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Success"
                                   StartIcon="@Icons.Material.Filled.CheckCircle"
                                   OnClick="CompleteRoute">
                            Terminer
                        </MudButton>
                    }
                    @if (_route.Status != RouteStatus.Completed && _route.Status != RouteStatus.Cancelled)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Error"
                                   StartIcon="@Icons.Material.Filled.Cancel"
                                   OnClick="CancelRoute">
                            Annuler
                        </MudButton>
                    }
                    @if (_route.Status != RouteStatus.Draft && _route.TotalDeliveries > 0)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Info"
                                   StartIcon="@Icons.Material.Filled.PictureAsPdf"
                                   Disabled="@_downloading"
                                   OnClick="DownloadRouteSheet">
                            @if (_downloading)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                                <text>Génération...</text>
                            }
                            else
                            {
                                <text>PDF</text>
                            }
                        </MudButton>
                    }
                    <MudButton Variant="Variant.Text"
                               StartIcon="@Icons.Material.Filled.ArrowBack"
                               Href="/tournees">
                        Retour
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>

        <!-- Stats banner -->
        <MudPaper Elevation="2" Class="pa-4 mb-4 rounded-lg" Style="background: var(--mud-palette-primary); color: white;">
            <MudGrid>
                <MudItem xs="6" sm="3" Class="text-center">
                    <MudText Typo="Typo.h3" Class="font-weight-bold">@_route.TotalDeliveries</MudText>
                    <MudText Typo="Typo.body2">Livraisons</MudText>
                </MudItem>
                <MudItem xs="6" sm="3" Class="text-center">
                    <MudText Typo="Typo.h3" Class="font-weight-bold">@_route.TotalDistance.ToString("F1")</MudText>
                    <MudText Typo="Typo.body2">Kilomètres</MudText>
                </MudItem>
                <MudItem xs="6" sm="3" Class="text-center">
                    <MudText Typo="Typo.h3" Class="font-weight-bold">@FormatDuration(_route.TotalDuration)</MudText>
                    <MudText Typo="Typo.body2">Durée Totale</MudText>
                </MudItem>
                <MudItem xs="6" sm="3" Class="text-center">
                    <MudText Typo="Typo.h3" Class="font-weight-bold">@_route.Deliveries.Sum(d => d.ItemCount)</MudText>
                    <MudText Typo="Typo.body2">Articles</MudText>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudGrid>
            <!-- Informations Générales -->
            <MudItem xs="12" md="6">
                <MudCard Outlined="true">
                    <MudCardHeader>
                        <CardHeaderAvatar>
                            <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Primary" />
                        </CardHeaderAvatar>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Informations Générales</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudList T="RouteDto" Dense="true">
                            <MudListItem T="RouteDto" Icon="@Icons.Material.Filled.CalendarToday">
                                <MudText Typo="Typo.body2">
                                    <strong>Date :</strong> @_route.Date.ToString("dddd dd MMMM yyyy")
                                </MudText>
                            </MudListItem>
                            <MudListItem T="RouteDto" Icon="@Icons.Material.Filled.AccessTime">
                                <MudText Typo="Typo.body2">
                                    <strong>Heure départ :</strong> @_route.StartTime.ToString(@"hh\:mm")
                                </MudText>
                            </MudListItem>
                            @if (_route.EstimatedEndTime.HasValue)
                            {
                                <MudListItem T="RouteDto" Icon="@Icons.Material.Filled.Schedule">
                                    <MudText Typo="Typo.body2">
                                        <strong>Fin estimée :</strong> @_route.EstimatedEndTime.Value.ToString(@"hh\:mm")
                                    </MudText>
                                </MudListItem>
                            }
                            <MudListItem T="RouteDto" Icon="@Icons.Material.Filled.DirectionsCar">
                                <MudText Typo="Typo.body2">
                                    <strong>Véhicule :</strong> @_route.VehicleName
                                </MudText>
                            </MudListItem>
                            <MudListItem T="RouteDto" Icon="@Icons.Material.Filled.Place">
                                <MudText Typo="Typo.body2">
                                    <strong>Adresse départ :</strong> @_route.DepartureAddress
                                </MudText>
                            </MudListItem>
                        </MudList>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- Équipe -->
            <MudItem xs="12" md="6">
                <MudCard Outlined="true">
                    <MudCardHeader>
                        <CardHeaderAvatar>
                            <MudIcon Icon="@Icons.Material.Filled.Group" Color="Color.Primary" />
                        </CardHeaderAvatar>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Équipe (@_route.TeamMembers.Count)</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudList T="RouteTeamDto" Dense="true">
                            @foreach (var crew in _route.TeamMembers)
                            {
                                <MudListItem T="RouteTeamDto" Icon="@GetTeamIcon(crew.Role)">
                                    <MudText Typo="Typo.body2">
                                        <strong>@crew.DriverName</strong> — @crew.RoleDisplay
                                    </MudText>
                                </MudListItem>
                            }
                        </MudList>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- Livraisons -->
            <MudItem xs="12">
                <MudCard Outlined="true">
                    <MudCardHeader>
                        <CardHeaderAvatar>
                            <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Color="Color.Primary" />
                        </CardHeaderAvatar>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Livraisons (@_route.Deliveries.Count)</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudTable Items="@_route.Deliveries.OrderBy(d => d.SequenceOrder)"
                                  Hover="true"
                                  Dense="true"
                                  Breakpoint="Breakpoint.Sm">
                            <HeaderContent>
                                <MudTh>#</MudTh>
                                <MudTh>Référence</MudTh>
                                <MudTh>Client</MudTh>
                                <MudTh>Adresse</MudTh>
                                <MudTh>Départ</MudTh>
                                <MudTh>Arrivée</MudTh>
                                <MudTh>Trajet</MudTh>
                                <MudTh>Prestation</MudTh>
                                <MudTh>Créneau</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="#">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary">@context.SequenceOrder</MudChip>
                                </MudTd>
                                <MudTd DataLabel="Référence">
                                    <MudText Typo="Typo.body2" Class="font-weight-bold">@context.Reference</MudText>
                                </MudTd>
                                <MudTd DataLabel="Client">
                                    <MudText Typo="Typo.body2">@context.ClientName</MudText>
                                </MudTd>
                                <MudTd DataLabel="Adresse">
                                    <MudText Typo="Typo.body2">@context.Address</MudText>
                                </MudTd>
                                <MudTd DataLabel="Départ">
                                    @if (context.DepartureTime.HasValue)
                                    {
                                        <MudText Typo="Typo.body2">@context.DepartureTime.Value.ToString(@"hh\:mm")</MudText>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">—</MudText>
                                    }
                                </MudTd>
                                <MudTd DataLabel="Arrivée">
                                    @if (context.EstimatedArrivalTime.HasValue)
                                    {
                                        <MudText Typo="Typo.body2" Class="font-weight-bold">
                                            @context.EstimatedArrivalTime.Value.ToString(@"hh\:mm")
                                        </MudText>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">—</MudText>
                                    }
                                </MudTd>
                                <MudTd DataLabel="Trajet">
                                    @if (context.TravelDurationMinutes is > 0)
                                    {
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudText Typo="Typo.body2">@FormatDuration(context.TravelDurationMinutes.Value)</MudText>
                                            @if (context.DistanceToNextMeters is > 0)
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                    (@((context.DistanceToNextMeters.Value / 1000.0m).ToString("F1")) km)
                                                </MudText>
                                            }
                                        </MudStack>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">—</MudText>
                                    }
                                </MudTd>
                                <MudTd DataLabel="Prestation">
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info" Icon="@Icons.Material.Filled.Timer">
                                        @context.EstimatedDurationMinutes min
                                    </MudChip>
                                </MudTd>
                                <MudTd DataLabel="Créneau">
                                    @if (!string.IsNullOrEmpty(context.TimeSlotName))
                                    {
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default" Icon="@Icons.Material.Filled.Schedule">
                                            @context.TimeSlotName
                                        </MudChip>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">—</MudText>
                                    }
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>
    </MudContainer>
}

@code {
    [Parameter] public int Id { get; set; }

    private RouteDto? _route;
    private bool _loading = true;
    private bool _downloading = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadRoute();
    }

    private async Task LoadRoute()
    {
        _loading = true;

        var result = await RouteService.GetRouteByIdAsync(Id);

        if (result != null)
        {
            _route = result;
        }
        else
        {
            Snackbar.Add("Tournée introuvable", Severity.Error);
        }

        _loading = false;
    }

    private async Task DownloadRouteSheet()
    {
        if (_route == null) return;

        _downloading = true;
        StateHasChanged();

        try
        {
            Snackbar.Add("Génération de la feuille de route en cours...", Severity.Info);

            var (success, pdfBytes, errorMessage) = await RouteService.DownloadRouteSheetAsync(_route.Id);

            if (!success || pdfBytes == null)
            {
                Snackbar.Add(errorMessage ?? "Erreur lors du téléchargement", Severity.Error);
                return;
            }

            var fileName = $"Feuille-Route-{_route.Reference}-{DateTime.Now:yyyyMMdd-HHmmss}.pdf";

            await EnsureDownloadFunctionExists();
            await JsRuntime.InvokeVoidAsync("downloadFileFromBytes", fileName, "application/pdf", pdfBytes);

            Snackbar.Add($"Feuille de route {_route.Reference} téléchargée avec succès", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur lors du téléchargement : {ex.Message}", Severity.Error);
        }
        finally
        {
            _downloading = false;
            StateHasChanged();
        }
    }

    private async Task EnsureDownloadFunctionExists()
    {
        var functionExists = await JsRuntime.InvokeAsync<bool>("eval",
            "typeof window.downloadFileFromBytes !== 'undefined'");

        if (!functionExists)
        {
            await JsRuntime.InvokeVoidAsync("eval", @"
                window.downloadFileFromBytes = (fileName, contentType, byteArray) => {
                    const blob = new Blob([new Uint8Array(byteArray)], { type: contentType });
                    const url = window.URL.createObjectURL(blob);
                    const link = document.createElement('a');
                    link.href = url;
                    link.download = fileName;
                    document.body.appendChild(link);
                    link.click();
                    document.body.removeChild(link);
                    window.URL.revokeObjectURL(url);
                };
            ");
        }
    }

    private async Task StartRoute()
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Démarrer la tournée",
            $"Voulez-vous démarrer la tournée {_route?.Reference} ?",
            yesText: "Démarrer",
            cancelText: "Annuler");

        if (confirmed == true && _route != null)
        {
            var result = await RouteService.StartAsync(_route.Id);
            if (result.Succeeded)
            {
                Snackbar.Add("Tournée démarrée", Severity.Success);
                await LoadRoute();
            }
            else
            {
                Snackbar.Add(result.Errors.FirstOrDefault() ?? "Erreur", Severity.Error);
            }
        }
    }

    private async Task CompleteRoute()
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Terminer la tournée",
            $"Voulez-vous terminer la tournée {_route?.Reference} ?",
            yesText: "Terminer",
            cancelText: "Annuler");

        if (confirmed == true && _route != null)
        {
            var result = await RouteService.CompleteAsync(_route.Id);
            if (result.Succeeded)
            {
                Snackbar.Add("Tournée terminée", Severity.Success);
                await LoadRoute();
            }
            else
            {
                Snackbar.Add(result.Errors.FirstOrDefault() ?? "Erreur", Severity.Error);
            }
        }
    }

    private async Task CancelRoute()
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Annuler la tournée",
            $"Voulez-vous annuler la tournée {_route?.Reference} ?",
            yesText: "Annuler la tournée",
            cancelText: "Retour");

        if (confirmed == true && _route != null)
        {
            var result = await RouteService.CancelAsync(_route.Id);
            if (result.Succeeded)
            {
                Snackbar.Add("Tournée annulée", Severity.Warning);
                await LoadRoute();
            }
            else
            {
                Snackbar.Add(result.Errors.FirstOrDefault() ?? "Erreur", Severity.Error);
            }
        }
    }

    private RenderFragment GetStatusChip(RouteStatus status)
    {
        var (color, icon, text) = status switch
        {
            RouteStatus.Draft      => (Color.Default, Icons.Material.Filled.Edit,        "Brouillon"),
            RouteStatus.Confirmed  => (Color.Info,    Icons.Material.Filled.CheckCircle, "Confirmée"),
            RouteStatus.InProgress => (Color.Warning, Icons.Material.Filled.PlayArrow,   "En cours"),
            RouteStatus.Completed  => (Color.Success, Icons.Material.Filled.Flag,        "Terminée"),
            RouteStatus.Cancelled  => (Color.Error,   Icons.Material.Filled.Cancel,      "Annulée"),
            _                      => (Color.Default, Icons.Material.Filled.Help,        status.ToString())
        };

        return @<MudChip T="string" Size="Size.Medium" Color="@color" Icon="@icon">@text</MudChip>;
    }

    private static string GetTeamIcon(TeamMemberRole role) => role switch
    {
        TeamMemberRole.MainDriver => Icons.Material.Filled.DriveEta,
        _ => Icons.Material.Filled.Person
    };

    private static string FormatDuration(int minutes)
    {
        var hours = minutes / 60;
        var mins = minutes % 60;
        return hours > 0 ? $"{hours}h{mins:D2}" : $"{mins}min";
    }
}

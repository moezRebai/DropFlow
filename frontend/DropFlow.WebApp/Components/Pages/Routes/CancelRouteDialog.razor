@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudAlert Severity="Severity.Warning" Dense="true">
                <MudText Typo="Typo.body2">
                    <strong>Attention :</strong> L'annulation d'une tournée libérera les livraisons et le véhicule.
                </MudText>
            </MudAlert>

            <MudText Typo="Typo.body1">
                Tournée : <strong>@RouteName</strong>
            </MudText>

            <MudTextField @bind-Value="_reason"
                         Label="Raison de l'annulation *"
                         Variant="Variant.Outlined"
                         Lines="4"
                         MaxLength="500"
                         Counter="500"
                         Required="true"
                         RequiredError="La raison est obligatoire"
                         Placeholder="Exemple : Client a reporté, problème véhicule, conditions météo..."
                         HelperText="Cette information sera conservée dans l'historique"/>

            @if (_showPredefinedReasons)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Raisons fréquentes :
                </MudText>
                
                <MudStack Row="true" Spacing="1" Class="flex-wrap">
                    @foreach (var reason in _predefinedReasons)
                    {
                        <MudChip 
                            T="string"
                            Size="Size.Small" 
                                Color="Color.Default" 
                                Variant="Variant.Outlined"
                                OnClick="@(() => SelectPredefinedReason(reason))">
                            @reason
                        </MudChip>
                    }
                </MudStack>
            }
        </MudStack>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel" Color="Color.Default">
            Annuler
        </MudButton>
        <MudButton OnClick="Submit" 
                  Color="Color.Error" 
                  Variant="Variant.Filled"
                  Disabled="@(string.IsNullOrWhiteSpace(_reason))">
            Confirmer l'annulation
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    
    [Parameter] public int RouteId { get; set; }
    [Parameter] public string RouteName { get; set; } = string.Empty;

    private string _reason = string.Empty;
    private bool _showPredefinedReasons = true;

    private readonly List<string> _predefinedReasons = new()
    {
        "Client a reporté",
        "Problème véhicule",
        "Chauffeur indisponible",
        "Conditions météo",
        "Erreur de planification",
        "Demande urgente d'un autre client",
        "Changement de priorités"
    };

    private void SelectPredefinedReason(string reason)
    {
        if (string.IsNullOrWhiteSpace(_reason))
        {
            _reason = reason;
        }
        else
        {
            _reason += $" - {reason}";
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private void Submit()
    {
        if (string.IsNullOrWhiteSpace(_reason))
        {
            Snackbar.Add("Veuillez indiquer la raison de l'annulation", Severity.Warning);
            return;
        }

        // Retourner la raison dans les données du dialog
        MudDialog.Close(DialogResult.Ok(new CancelRouteResult
        {
            RouteId = RouteId,
            Reason = _reason.Trim()
        }));
    }

    public class CancelRouteResult
    {
        public int RouteId { get; set; }
        public string Reason { get; set; } = string.Empty;
    }
}

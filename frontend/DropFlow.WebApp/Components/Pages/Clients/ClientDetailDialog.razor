@using DropFlow.Shared.Enums
@using DropFlow.Shared.Clients
@using DropFlow.Shared.Deliveries

<MudDialog>
    <DialogContent>
        @if (_loading)
        {
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            <MudText Typo="Typo.body1" Class="ml-2">Chargement...</MudText>
        }
        else if (_client != null)
        {
            <MudStack Spacing="3">
                <!-- En-tête avec nom et badge VIP -->
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudText Typo="Typo.h5">@_client.DisplayName</MudText>
                        @if (IsVip())
                        {
                            <MudChip T="string" Color="Color.Warning" Size="Size.Small" Icon="@Icons.Material.Filled.Star">VIP</MudChip>
                        }
                    </MudStack>
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   Title="Modifier"
                                   OnClick="OpenEditDialog" />
                </MudStack>

                <MudDivider />

                <!-- Statistiques (4 KPI Cards) -->
                <MudText Typo="Typo.h6">
                    <MudIcon Icon="@Icons.Material.Filled.BarChart" Class="mr-1" />
                    Statistiques
                </MudText>
                <MudGrid>
                    <MudItem xs="6" md="3">
                        <MudPaper Elevation="2" Class="pa-3">
                            <MudStack AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Color="Color.Info" Size="Size.Large" />
                                <MudText Typo="Typo.h5">@_client.TotalDeliveries</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Livraisons</MudText>
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6" md="3">
                        <MudPaper Elevation="2" Class="pa-3">
                            <MudStack AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.Euro" Color="Color.Success" Size="Size.Large" />
                                <MudText Typo="Typo.h5">@_client.TotalRevenue.ToString("N0") €</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">CA Total</MudText>
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6" md="3">
                        <MudPaper Elevation="2" Class="pa-3">
                            <MudStack AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.Calculate" Color="Color.Warning" Size="Size.Large" />
                                <MudText Typo="Typo.h5">@GetAverageBasket() €</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Panier moyen</MudText>
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6" md="3">
                        <MudPaper Elevation="2" Class="pa-3">
                            <MudStack AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.Home" Color="Color.Primary" Size="Size.Large" />
                                <MudText Typo="Typo.h5">@_client.Addresses.Count</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Adresses</MudText>
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                </MudGrid>

                <MudDivider />

                <!-- Informations -->
                <MudText Typo="Typo.h6">
                    <MudIcon Icon="@Icons.Material.Filled.Person" Class="mr-1" />
                    Informations
                </MudText>
                <MudSimpleTable Dense="true" Hover="true">
                    <tbody>
                    <tr>
                        <td><strong>Email</strong></td>
                        <td>
                            @if (!string.IsNullOrEmpty(_client.Email))
                            {
                                <MudLink Href="@($"mailto:{_client.Email}")">@_client.Email</MudLink>
                            }
                            else
                            {
                                <MudText Color="Color.Secondary">-</MudText>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td><strong>Téléphone</strong></td>
                        <td><MudLink Href="@($"tel:{_client.Phone}")">@_client.Phone</MudLink></td>
                    </tr>
                    <tr>
                        <td><strong>Client depuis</strong></td>
                        <td>@_client.CreatedDate.ToString("dd/MM/yyyy")</td>
                    </tr>
                    </tbody>
                </MudSimpleTable>

                <MudDivider />

                <!-- Adresses -->
                <MudText Typo="Typo.h6">
                    <MudIcon Icon="@Icons.Material.Filled.LocationOn" Class="mr-1" />
                    Adresses (@_client.Addresses.Count)
                </MudText>
                @if (_client.Addresses.Any())
                {
                    <MudList T="ClientAddressDto" Dense="true" >
                        @foreach (var address in _client.Addresses.OrderByDescending(a => a.IsDefault))
                        {
                            <MudListItem T="ClientAddressDto">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    @if (address.IsDefault)
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                                    }
                                    <div>
                                        @if (!string.IsNullOrEmpty(address.Label))
                                        {
                                            <MudText Typo="Typo.body2"><strong>@address.Label</strong></MudText>
                                        }
                                        <MudText Typo="Typo.body2">@address.FullAddress</MudText>
                                    </div>
                                </MudStack>
                            </MudListItem>
                        }
                    </MudList>
                }
                else
                {
                    <MudAlert Severity="Severity.Info">Aucune adresse enregistrée</MudAlert>
                }

                <MudDivider />

                <!-- Historique des livraisons avec colonne Actions -->
                <MudText Typo="Typo.h6">
                    <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Class="mr-1" />
                    Historique des livraisons (@_deliveries.Count)
                </MudText>

                @if (_deliveries.Any())
                {
                    <MudTable Items="@_deliveries"
                              Dense="true"
                              Hover="true"
                              Striped="true"
                              Outlined="true"
                              FixedHeader="true">
                        <HeaderContent>
                            <MudTh>Date</MudTh>
                            <MudTh>Référence</MudTh>
                            <MudTh>Enseigne</MudTh>
                            <MudTh Style="text-align: right;">Montant</MudTh>
                            <MudTh Style="text-align: center;">Statut</MudTh>
                            <MudTh Style="text-align: center;">Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Date">
                                @if (context.ScheduledDate.HasValue)
                                {
                                    @context.ScheduledDate.Value.ToString("dd/MM/yyyy")
                                }
                                else
                                {
                                    <MudText Color="Color.Secondary">Non planifiée</MudText>
                                }
                            </MudTd>
                            <MudTd DataLabel="Référence">
                                <MudText Typo="Typo.body2"><strong>@context.Reference</strong></MudText>
                            </MudTd>
                            <MudTd DataLabel="Enseigne">@context.StoreName</MudTd>
                            <MudTd DataLabel="Montant" Style="text-align: right;">@context.Price.ToString("N2") €</MudTd>
                            <MudTd DataLabel="Statut" Style="text-align: center;">
                                <MudChip T="DeliveryStatus"
                                         Size="Size.Small"
                                         Variant="Variant.Filled">
                                    @GetStatusEmoji(context.Status)
                                </MudChip>
                            </MudTd>
                            <MudTd DataLabel="Actions" Style="text-align: center;">
                                <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                                               Color="Color.Primary"
                                               Size="Size.Small"
                                               Href="@($"/livraisons/edit/{context.Id}")"
                                               Title="Voir ou Modifier la livraison"/>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>

                    <!-- Notes des livraisons -->
                    @if (_deliveries.Any(d => !string.IsNullOrEmpty(d.Notes)))
                    {
                        <MudDivider Class="my-4" />
                        <MudText Typo="Typo.h6">
                            <MudIcon Icon="@Icons.Material.Filled.Notes" Class="mr-1" />
                            Notes des livraisons
                        </MudText>
                        <MudList T="DeliveryDto" Dense="true">
                            @foreach (var delivery in _deliveries.Where(d => !string.IsNullOrEmpty(d.Notes)))
                            {
                                <MudListItem>
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @if (delivery.ScheduledDate.HasValue)
                                            {
                                                @delivery.ScheduledDate.Value.ToString("dd/MM/yyyy")
                                            }
                                            else
                                            {
                                                <text>Non planifiée</text>
                                            }
                                            - @delivery.Reference - @delivery.StoreName
                                        </MudText>
                                        <MudText Typo="Typo.body2">
                                            <MudIcon Icon="@Icons.Material.Filled.FormatQuote" Size="Size.Small" />
                                            @delivery.Notes
                                        </MudText>
                                    </MudStack>
                                </MudListItem>
                            }
                        </MudList>
                    }
                }
                else
                {
                    <MudAlert Severity="Severity.Info">Aucune livraison pour ce client</MudAlert>
                }

                <MudDivider />

                <!-- Graphique : Livraisons par mois (LINE CHART) -->
                @if (_chartSeries.Any() && _chartLabels.Any())
                {
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.ShowChart" Class="mr-1" />
                        Évolution des livraisons
                    </MudText>
                    <MudPaper Elevation="2" Class="pa-4" Outlined="true">
                        <MudChart ChartType="ChartType.Line"
                                  ChartSeries="@_chartSeries"
                                  XAxisLabels="@_chartLabels"
                                  Width="100%"
                                  Height="400px"
                                  ChartOptions="@_chartOptions" />
                    </MudPaper>

                    <MudDivider Class="my-4" />
                }
                
            </MudStack>
        }
        else
        {
            <MudAlert Severity="Severity.Error">Client introuvable</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">Fermer</MudButton>
    </DialogActions>
</MudDialog>

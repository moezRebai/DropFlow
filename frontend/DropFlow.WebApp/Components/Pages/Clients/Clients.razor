@page "/clients"
@using DropFlow.Shared.Clients
@using DropFlow.WebApp.Models.Auth

<PageTitle>Clients - DropFlow</PageTitle>

<AuthorizeView Roles="@Roles.ManagerOrAdmin" Context="auth">
    <Authorized>
        <MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4">

            <!-- En-tête -->
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                <div>
                    <MudText Typo="Typo.h5" Class="font-weight-bold" Style="color: #1F2937;">Clients</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@_totalClients client(s) enregistré(s)</MudText>
                </div>
            </MudStack>

            <!-- Statistiques -->
            <MudGrid Class="mb-4">
                <MudItem xs="12" sm="4">
                    <MudPaper Elevation="0" Class="pa-4 rounded-lg"
                              Style="border: 1px solid #E5E7EB; border-left: 4px solid #2196F3;">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <div>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">TOTAL CLIENTS</MudText>
                                <MudText Typo="Typo.h4" Class="font-weight-bold">@_totalClients</MudText>
                            </div>
                            <MudAvatar Style="background: #EFF6FF;" Variant="Variant.Filled">
                                <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Primary"/>
                            </MudAvatar>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" sm="4">
                    <MudPaper Elevation="0" Class="pa-4 rounded-lg"
                              Style="border: 1px solid #E5E7EB; border-left: 4px solid #F59E0B;">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <div>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">CLIENTS VIP</MudText>
                                <MudText Typo="Typo.h4" Class="font-weight-bold">@_vipClients</MudText>
                            </div>
                            <MudAvatar Style="background: #FFFBEB;" Variant="Variant.Filled">
                                <MudIcon Icon="@Icons.Material.Filled.Star" Style="color: #F59E0B;"/>
                            </MudAvatar>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" sm="4">
                    <MudPaper Elevation="0" Class="pa-4 rounded-lg"
                              Style="border: 1px solid #E5E7EB; border-left: 4px solid #10B981;">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <div>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">CA TOTAL</MudText>
                                <MudText Typo="Typo.h4" Class="font-weight-bold">@_totalRevenue.ToString("N0") €</MudText>
                            </div>
                            <MudAvatar Style="background: #ECFDF5;" Variant="Variant.Filled">
                                <MudIcon Icon="@Icons.Material.Filled.Euro" Style="color: #10B981;"/>
                            </MudAvatar>
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <!-- Barre de recherche -->
            <MudPaper Elevation="0" Class="pa-3 mb-4 rounded-lg" Style="border: 1px solid #E5E7EB;">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudTextField @bind-Value="_searchTerm"
                                  Placeholder="Rechercher par nom, email, téléphone..."
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Immediate="true"
                                  DebounceInterval="300"
                                  OnDebounceIntervalElapsed="OnSearchChanged"
                                  Class="flex-grow-1"
                                  Style="flex: 1;"/>
                    <MudTooltip Text="Actualiser">
                        <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                       Variant="Variant.Outlined"
                                       Color="Color.Default"
                                       OnClick="LoadClients"/>
                    </MudTooltip>
                </MudStack>
            </MudPaper>

            <!-- Table -->
            <MudPaper Elevation="0" Class="rounded-lg" Style="border: 1px solid #E5E7EB; overflow: hidden;">
                <MudTable @ref="_table"
                          ServerData="LoadServerData"
                          Hover="true"
                          Striped="false"
                          Loading="@_loading"
                          RowsPerPage="20"
                          LoadingProgressColor="Color.Primary"
                          Elevation="0"
                          OnRowClick="@(async (TableRowClickEventArgs<ClientDto> args) => await OpenDetailDialog(args.Item.Id))"
                          RowStyle="cursor: pointer;">
                    <HeaderContent>
                        <MudTh Style="text-align: center;">Client</MudTh>
                        <MudTh>Contact</MudTh>
                        <MudTh>Ville</MudTh>
                        <MudTh Style="text-align: center;">Livraisons</MudTh>
                        <MudTh Style="text-align: right;">CA Total</MudTh>
                        <MudTh Style="text-align: center;">Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <!-- Client -->
                        <MudTd DataLabel="Client" Style="text-align: center;">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="2">
                                <MudAvatar Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                                           Style="font-size: 13px; font-weight: 600;">
                                    @context.DisplayName.FirstOrDefault()
                                </MudAvatar>
                                <div>
                                    <MudText Typo="Typo.body2" Style="font-weight: 600; line-height: 1.2;">
                                        @context.DisplayName
                                    </MudText>
                                    @if (IsVip(context))
                                    {
                                        <MudText Typo="Typo.caption" Style="color: #F59E0B; font-weight: 500;">
                                            <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small"
                                                     Style="font-size: 11px; margin-right: 2px; vertical-align: middle;"/>VIP
                                        </MudText>
                                    }
                                </div>
                            </MudStack>
                        </MudTd>

                        <!-- Contact (email + téléphone regroupés) -->
                        <MudTd DataLabel="Contact">
                            <div>
                                @if (!string.IsNullOrEmpty(context.Email))
                                {
                                    <MudText Typo="Typo.body2">@context.Email</MudText>
                                }
                                else
                                {
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">—</MudText>
                                }
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @(string.IsNullOrEmpty(context.Phone) ? "Pas de téléphone" : context.Phone)
                                </MudText>
                            </div>
                        </MudTd>

                        <!-- Ville -->
                        <MudTd DataLabel="Ville">
                            @{
                                var defaultAddress = context.Addresses?.FirstOrDefault(a => a.IsDefault);
                            }
                            <MudText Typo="Typo.body2">
                                @(defaultAddress?.City ?? "—")
                            </MudText>
                        </MudTd>

                        <!-- Livraisons -->
                        <MudTd DataLabel="Livraisons" Style="text-align: center;">
                            <MudChip T="string"
                                     Size="Size.Small"
                                     Color="@(context.TotalDeliveries >= 3 ? Color.Warning : context.TotalDeliveries > 0 ? Color.Primary : Color.Default)"
                                     Variant="@(context.TotalDeliveries > 0 ? Variant.Filled : Variant.Outlined)">
                                @context.TotalDeliveries
                            </MudChip>
                        </MudTd>

                        <!-- CA Total -->
                        <MudTd DataLabel="CA Total" Style="text-align: right;">
                            <MudText Typo="Typo.body2"
                                     Style="@(context.TotalRevenue > 0 ? "color: #10B981; font-weight: 600;" : "color: #9CA3AF;")">
                                @context.TotalRevenue.ToString("N0") €
                            </MudText>
                        </MudTd>

                        <!-- Actions -->
                        <MudTd DataLabel="Actions" Style="text-align: center;" @onclick:stopPropagation="true">
                            <MudStack Row="true" Justify="Justify.Center" Spacing="0">
                                <MudTooltip Text="Voir le détail">
                                    <MudIconButton Icon="@Icons.Material.Outlined.Visibility"
                                                   Color="Color.Info"
                                                   Size="Size.Small"
                                                   OnClick="@(() => OpenDetailDialog(context.Id))"/>
                                </MudTooltip>
                                <MudTooltip Text="Modifier">
                                    <MudIconButton Icon="@Icons.Material.Outlined.Edit"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   OnClick="@(() => OpenEditDialog(context.Id))"/>
                                </MudTooltip>
                                <MudTooltip Text="Supprimer">
                                    <MudIconButton Icon="@Icons.Material.Outlined.Delete"
                                                   Color="Color.Error"
                                                   Size="Size.Small"
                                                   OnClick="@(() => DeleteClient(context.Id, context.DisplayName))"/>
                                </MudTooltip>
                            </MudStack>
                        </MudTd>
                    </RowTemplate>

                    <NoRecordsContent>
                        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="py-12" Spacing="3">
                            <MudIcon Icon="@Icons.Material.Outlined.PeopleAlt"
                                     Style="font-size: 48px; color: #D1D5DB;"/>
                            <div style="text-align: center;">
                                <MudText Typo="Typo.body1" Color="Color.Secondary">
                                    @if (string.IsNullOrWhiteSpace(_searchTerm))
                                    {
                                        <text>Aucun client pour le moment</text>
                                    }
                                    else
                                    {
                                        <text>Aucun résultat pour « @_searchTerm »</text>
                                    }
                                </MudText>
                                @if (!string.IsNullOrWhiteSpace(_searchTerm))
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        Essayez avec un autre nom, email ou téléphone
                                    </MudText>
                                }
                            </div>
                        </MudStack>
                    </NoRecordsContent>

                    <LoadingContent>
                        <MudStack AlignItems="AlignItems.Center" Class="py-8">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Chargement des clients...</MudText>
                        </MudStack>
                    </LoadingContent>

                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }"/>
                    </PagerContent>
                </MudTable>
            </MudPaper>

        </MudContainer>
    </Authorized>
    <NotAuthorized>
        <RedirectToAccessDenied/>
    </NotAuthorized>
</AuthorizeView>

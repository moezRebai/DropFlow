@using DropFlow.Shared.Profil
@using DropFlow.WebApp.Models.Auth


<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <!-- Informations Utilisateur -->
            <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                <MudText Typo="Typo.h6" Class="mb-2">Utilisateur</MudText>
                <MudStack Spacing="1">
                    <MudText Typo="Typo.body1"><strong>@User.FullName</strong></MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@User.Email</MudText>
                </MudStack>
            </MudPaper>

            <!-- Sélection Nouveau Rôle -->
            <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                <MudText Typo="Typo.h6" Class="mb-3">Changement de Rôle</MudText>
                
                <!-- Rôle Actuel -->
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                    <MudText Typo="Typo.body2" Style="min-width: 100px;">Rôle actuel :</MudText>
                    <MudChip T="string" Size="Size.Small" Color="@GetRoleColor(User.Role)">
                        @User.Role
                    </MudChip>
                </MudStack>

                <!-- Nouveau Rôle -->
                <MudStack Row="true" AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.body2" Style="min-width: 100px;">Nouveau rôle :</MudText>
                    <MudSelect @bind-Value="_selectedRole"
                              Variant="Variant.Outlined"
                              Dense="true"
                              Required="true"
                              RequiredError="Veuillez sélectionner un rôle"
                              AdornmentIcon="@Icons.Material.Filled.Badge"
                              AdornmentColor="Color.Primary"
                              Style="flex-grow: 1;">
                        <MudSelectItem T="string" Value="@Roles.Admin">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Color="Color.Error" Size="Size.Small" />
                                <div>
                                    <MudText Typo="Typo.body2">Admin</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Accès complet à la plateforme</MudText>
                                </div>
                            </MudStack>
                        </MudSelectItem>
                        
                        <MudSelectItem T="string" Value="@Roles.Manager">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.ManageAccounts" Color="Color.Info" Size="Size.Small" />
                                <div>
                                    <MudText Typo="Typo.body2">Manager</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Gestion complète du tenant</MudText>
                                </div>
                            </MudStack>
                        </MudSelectItem>
                        
                        <MudSelectItem T="string" Value="@Roles.Livreur">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Color="Color.Success" Size="Size.Small" />
                                <div>
                                    <MudText Typo="Typo.body2">Livreur</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Accès aux livraisons uniquement</MudText>
                                </div>
                            </MudStack>
                        </MudSelectItem>
                    </MudSelect>
                </MudStack>
            </MudPaper>

            <!-- Avertissement si changement vers Admin -->
            @if (_selectedRole == Roles.Admin && User.Role != Roles.Admin)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                    <MudText Typo="Typo.body2">
                        <strong>Attention :</strong> Le rôle Admin donne un accès complet à la plateforme DropFlow.
                        Cet utilisateur pourra gérer tous les tenants.
                    </MudText>
                </MudAlert>
            }

            <!-- Avertissement si retrait Admin -->
            @if (_selectedRole != Roles.Admin && User.Role == Roles.Admin)
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
                    <MudText Typo="Typo.body2">
                        <strong>Attention :</strong> Vous retirez les privilèges Admin de cet utilisateur.
                        Il n'aura plus accès à la gestion globale de la plateforme.
                    </MudText>
                </MudAlert>
            }
        </MudStack>
    </DialogContent>
    
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Outlined">Annuler</MudButton>
        <MudButton OnClick="Submit" 
                  Variant="Variant.Filled" 
                  Color="Color.Primary"
                  Disabled="@(string.IsNullOrEmpty(_selectedRole) || _selectedRole == User.Role)">
            Confirmer le Changement
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public UserProfileDto User { get; set; } = null!;

    private string _selectedRole = string.Empty;

    protected override void OnInitialized()
    {
        _selectedRole = User.Role; // Initialiser avec le rôle actuel
    }

    private static Color GetRoleColor(string role) => role switch
    {
        "Admin" => Color.Error,
        "Manager" => Color.Info,
        "Livreur" => Color.Success,
        _ => Color.Default
    };

    private void Cancel() => MudDialog.Cancel();

    private void Submit()
    {
        if (!string.IsNullOrEmpty(_selectedRole) && _selectedRole != User.Role)
        {
            MudDialog.Close(DialogResult.Ok(_selectedRole));
        }
    }
}

@using DropFlow.Shared.Admin
@using DropFlow.WebApp.Models.Audit

<MudCard Elevation="0" Outlined="true" Class="mb-4">
    <MudCardContent>
        <MudGrid Spacing="2">
            <!-- Filtre Tenant -->
            <MudItem xs="12" sm="6" md="2">
                <MudAutocomplete T="TenantDto"
                                 Value="_selectedTenant"
                                 Label="Filtrer par Tenant"
                                 SearchFunc="SearchTenants"
                                 ToStringFunc="@(t => t?.Name ?? "")"
                                 Variant="Variant.Outlined"
                                 Dense="true"
                                 Clearable="true"
                                 AdornmentIcon="@Icons.Material.Filled.Business"
                                 AdornmentColor="Color.Primary"
                                 ResetValueOnEmptyText="true"
                                 CoerceText="false"
                                 ValueChanged="OnTenantChanged"/>
            </MudItem>

            <!-- Filtre Rôle -->
            <MudItem xs="12" sm="6" md="2">
                <MudSelect T="string"
                           Value="_selectedRole"
                           Label="Filtrer par Rôle"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Clearable="true"
                           AdornmentIcon="@Icons.Material.Filled.Badge"
                           AdornmentColor="Color.Primary"
                           ValueChanged="OnRoleChanged" >
                    <MudSelectItem T="string" Value="@("Admin")">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Color="Color.Error" Size="Size.Small" />
                            <span>Admin</span>
                        </MudStack>
                    </MudSelectItem>
                    <MudSelectItem T="string" Value="@("Manager")">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.ManageAccounts" Color="Color.Info" Size="Size.Small" />
                            <span>Manager</span>
                        </MudStack>
                    </MudSelectItem>
                    <MudSelectItem T="string" Value="@("Livreur")">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Color="Color.Success" Size="Size.Small" />
                            <span>Livreur</span>
                        </MudStack>
                    </MudSelectItem>
                </MudSelect>
            </MudItem>

            <!-- Filtre Statut -->
            <MudItem xs="12" sm="6" md="2">
                <MudSelect T="bool?"
                           Value="_selectedStatus"
                           Label="Filtrer par Statut"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Clearable="true"
                           AdornmentIcon="@Icons.Material.Filled.ToggleOn"
                           AdornmentColor="Color.Primary"
                           ValueChanged="OnStatusChanged">
                    <MudSelectItem T="bool?" Value="@((bool?)true)">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                            <span>Actif</span>
                        </MudStack>
                    </MudSelectItem>
                    <MudSelectItem T="bool?" Value="@((bool?)false)">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.Block" Color="Color.Error" Size="Size.Small" />
                            <span>Inactif</span>
                        </MudStack>
                    </MudSelectItem>
                </MudSelect>
            </MudItem>

            <!-- NOUVEAU: Checkbox Afficher Désactivés -->
            <MudItem xs="12" sm="6" md="2">
                <MudCheckBox Value="_showDeactivated"
                             Label="Afficher désactivés"
                             Color="Color.Warning"
                             T="bool"
                             Dense="true"
                             ValueChanged="ShowDeactivatedChanged" />
            </MudItem>

            <!-- NOUVEAU: Checkbox Afficher Archivés -->
            <MudItem xs="12" sm="6" md="2">
                <MudCheckBox Value="_showDeleted"
                             Label="Afficher archivés"
                             Color="Color.Error"
                             T="bool"
                             Dense="true"
                             ValueChanged="ShowDeletedChanged" />
            </MudItem>

            <!-- Actions -->
            <MudItem xs="12" Class="d-flex justify-end gap-2">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.Clear"
                           OnClick="ResetFilters">
                    Réinitialiser
                </MudButton>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Refresh"
                           OnClick="ApplyFilters">
                    Actualiser
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudCardContent>
</MudCard>

@code {
    [Parameter] public List<TenantDto> Tenants { get; set; } = [];
    [Parameter] public EventCallback<UserFilters> OnFiltersChanged { get; set; }
    [Parameter] public EventCallback<bool> OnShowDeactivatedChanged { get; set; }
    [Parameter] public EventCallback<bool> OnShowDeletedChanged { get; set; }

    private string? _searchTerm;
    private TenantDto? _selectedTenant;
    private string? _selectedRole;
    private bool? _selectedStatus;
    private bool _showDeactivated = false;
    private bool _showDeleted = false;

    private async Task OnRoleChanged(string? role)
    {
        _selectedRole = role;
        await ApplyFilters();
    }

    private async Task ApplyFilters()
    {
        var filters = new UserFilters
        {
            TenantId = _selectedTenant?.Id,
            Role = _selectedRole,
            IsActive = _selectedStatus,
            SearchTerm = _searchTerm
        };

        await OnFiltersChanged.InvokeAsync(filters);
    }

    private async Task OnStatusChanged(bool? status)
    {
        _selectedStatus = status;
        await ApplyFilters();
    }

    private async Task OnTenantChanged(TenantDto? tenant)
    {
        _selectedTenant = tenant;
        await ApplyFilters();
    }

    private async Task ShowDeactivatedChanged(bool value)
    {
        _showDeactivated = value;
        await OnShowDeactivatedChanged.InvokeAsync(value);
    }

    private async Task ShowDeletedChanged(bool value)
    {
        _showDeleted = value;
        await OnShowDeletedChanged.InvokeAsync(value);
    }

    private Task<IEnumerable<TenantDto>> SearchTenants(string value, CancellationToken token)
    {
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult<IEnumerable<TenantDto>>(Tenants);

        return Task.FromResult(Tenants.Where(t => t.Name.Contains(value, StringComparison.OrdinalIgnoreCase)));
    }

    private async Task ResetFilters()
    {
        _searchTerm = null;
        _selectedTenant = null;
        _selectedRole = null;
        _selectedStatus = null;
        _showDeactivated = false;
        _showDeleted = false;

        var filters = new UserFilters();
        await OnFiltersChanged.InvokeAsync(filters);
        await OnShowDeactivatedChanged.InvokeAsync(false);
        await OnShowDeletedChanged.InvokeAsync(false);
    }
}

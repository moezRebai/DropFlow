@using DropFlow.Shared.Profil
@using DropFlow.WebApp.Interfaces
@using DropFlow.WebApp.Models.Profile
@inject IProfileService ProfileService
@inject ISnackbar Snackbar
@inject ILogger<ProfileGeneralTab> Logger

<MudText Typo="Typo.h6" Class="mb-4">Informations personnelles</MudText>

@if (_isLoading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
}
else if (_profile == null)
{
    <MudAlert Severity="Severity.Error">
        Impossible de charger les informations du profil
    </MudAlert>
}
else
{
    <MudForm @ref="_form">
        <MudGrid>
            <!-- Prénom -->
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_profile.FirstName"
                              Label="Prénom"
                              Variant="Variant.Outlined"
                              Required="true"
                              RequiredError="Le prénom est requis"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Person"
                              Class="mb-4" />
            </MudItem>

            <!-- Nom -->
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_profile.LastName"
                              Label="Nom"
                              Variant="Variant.Outlined"
                              Required="true"
                              RequiredError="Le nom est requis"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Person"
                              Class="mb-4" />
            </MudItem>

            <!-- Email (lecture seule) -->
            <MudItem xs="12" md="6">
                <MudTextField Value="@_profile.Email"
                              Label="Email"
                              Variant="Variant.Outlined"
                              Disabled="true"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Email"
                              HelperText="L'email ne peut pas être modifié"
                              Class="mb-4" />
            </MudItem>

            <!-- Téléphone -->
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_profile.PhoneNumber"
                              Label="Téléphone"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Phone"
                              HelperText="Format: +33 6 12 34 56 78"
                              Class="mb-4" />
            </MudItem>

            <!-- Adresse -->
            <MudItem xs="12">
                <MudTextField @bind-Value="_profile.Address"
                              Label="Adresse"
                              Variant="Variant.Outlined"
                              Lines="2"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.LocationOn"
                              HelperText="Adresse complète"
                              Class="mb-4" />
            </MudItem>

            <!-- Divider -->
            <MudItem xs="12">
                <MudDivider Class="my-2" />
                <MudText Typo="Typo.subtitle2" Class="mt-4 mb-2" Style="color: #64748b;">
                    Informations entreprise (lecture seule)
                </MudText>
            </MudItem>

            <!-- Nom entreprise (lecture seule) -->
            <MudItem xs="12" md="6">
                <MudTextField Value="@_profile.TenantName"
                              Label="Entreprise"
                              Variant="Variant.Outlined"
                              Disabled="true"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Business"
                              Class="mb-4" />
            </MudItem>

            <!-- Rôle (lecture seule) -->
            <MudItem xs="12" md="6">
                <MudTextField Value="@GetRoleDisplayName(_profile.Role)"
                              Label="Rôle"
                              Variant="Variant.Outlined"
                              Disabled="true"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Badge"
                              Class="mb-4" />
            </MudItem>

            <!-- Statut Actif (lecture seule) -->
            <MudItem xs="12">
                <MudAlert Severity="@(_profile.IsActive ? Severity.Success : Severity.Warning)" 
                          Dense="true">
                    @if (_profile.IsActive)
                    {
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" />
                            <span>Votre compte est actif</span>
                        </MudStack>
                    }
                    else
                    {
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" />
                            <span>Votre compte est désactivé</span>
                        </MudStack>
                    }
                </MudAlert>
            </MudItem>

            <!-- Informations supplémentaires -->
            <MudItem xs="12">
                <MudDivider Class="my-2" />
                <MudText Typo="Typo.caption" Style="color: #94a3b8;" Class="mt-2">
                    <strong>Membre depuis:</strong> @_profile.CreatedDate.ToString("dd/MM/yyyy")
                </MudText>
                @if (_profile.LastLoginDate.HasValue)
                {
                    <MudText Typo="Typo.caption" Style="color: #94a3b8;">
                        <strong>Dernière connexion:</strong> @_profile.LastLoginDate.Value.ToString("dd/MM/yyyy HH:mm")
                    </MudText>
                }
            </MudItem>
        </MudGrid>

        <!-- Boutons actions -->
        <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-6">
            <MudButton Variant="Variant.Text" 
                       OnClick="ResetForm"
                       Disabled="@_isSaving">
                Annuler
            </MudButton>
            <MudButton Variant="Variant.Filled" 
                       Color="Color.Primary"
                       OnClick="SaveProfile"
                       Disabled="@(_isSaving || !HasChanges())">
                @if (_isSaving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Enregistrement...</span>
                }
                else
                {
                    <span>Enregistrer les modifications</span>
                }
            </MudButton>
        </MudStack>
    </MudForm>
}

@code {
    [Parameter] public EventCallback OnProfileUpdated { get; set; }

    private MudForm? _form;
    private bool _isLoading = true;
    private bool _isSaving = false;
    private UserProfileDto? _profile;
    private UserProfileDto? _originalProfile;

    protected override async Task OnInitializedAsync()
    {
        await LoadProfileData();
    }

    private async Task LoadProfileData()
    {
        _isLoading = true;
        try
        {
            _profile = await ProfileService.GetProfileAsync();
            
            if (_profile != null)
            {
                // Copie pour détecter les changements
                _originalProfile = new UserProfileDto
                {
                    Id = _profile.Id,
                    Email = _profile.Email,
                    FirstName = _profile.FirstName,
                    LastName = _profile.LastName,
                    PhoneNumber = _profile.PhoneNumber,
                    Address = _profile.Address,
                    Role = _profile.Role,
                    TenantId = _profile.TenantId,
                    TenantName = _profile.TenantName,
                    IsActive = _profile.IsActive,
                    CreatedDate = _profile.CreatedDate,
                    LastLoginDate = _profile.LastLoginDate
                };
            }
            else
            {
                Snackbar.Add("Erreur lors du chargement du profil", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Logger.LogInformation($"Erreur LoadProfileData: {ex.Message}");
            Snackbar.Add("Erreur lors du chargement du profil", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private bool HasChanges()
    {
        if (_profile == null || _originalProfile == null)
            return false;

        return _profile.FirstName != _originalProfile.FirstName ||
               _profile.LastName != _originalProfile.LastName ||
               _profile.PhoneNumber != _originalProfile.PhoneNumber ||
               _profile.Address != _originalProfile.Address;
    }

    private void ResetForm()
    {
        if (_profile == null || _originalProfile == null)
            return;

        // Restaurer les valeurs originales
        _profile.FirstName = _originalProfile.FirstName;
        _profile.LastName = _originalProfile.LastName;
        _profile.PhoneNumber = _originalProfile.PhoneNumber;
        _profile.Address = _originalProfile.Address;

        Snackbar.Add("Modifications annulées", Severity.Info);
    }

    private async Task SaveProfile()
    {
        if (_profile == null)
            return;

        // Validation du formulaire
        await _form!.Validate();
        if (!_form.IsValid)
        {
            Snackbar.Add("Veuillez corriger les erreurs", Severity.Warning);
            return;
        }

        _isSaving = true;

        try
        {
            var request = new UpdateProfileRequest
            {
                FirstName = _profile.FirstName,
                LastName = _profile.LastName,
                PhoneNumber = _profile.PhoneNumber ?? string.Empty,
                Address = _profile.Address ?? string.Empty
            };

            var success = await ProfileService.UpdateProfileAsync(request);

            if (success.Succeeded)
            {
                // Mettre à jour la copie originale
                _originalProfile = new UserProfileDto
                {
                    Id = _profile.Id,
                    Email = _profile.Email,
                    FirstName = _profile.FirstName,
                    LastName = _profile.LastName,
                    PhoneNumber = _profile.PhoneNumber,
                    Address = _profile.Address,
                    Role = _profile.Role,
                    TenantId = _profile.TenantId,
                    TenantName = _profile.TenantName,
                    IsActive = _profile.IsActive,
                    CreatedDate = _profile.CreatedDate,
                    LastLoginDate = _profile.LastLoginDate
                };

                Snackbar.Add("Profil mis à jour avec succès", Severity.Success);
                
                // Notifier le parent pour recharger les infos
                await OnProfileUpdated.InvokeAsync();
            }
            else
            {
                Snackbar.Add("Erreur lors de la sauvegarde du profil", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Logger.LogInformation($"Erreur SaveProfile: {ex.Message}");
            Snackbar.Add("Erreur lors de la sauvegarde du profil", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private string GetRoleDisplayName(string role)
    {
        return role switch
        {
            "Admin" => "Administrateur",
            "Manager" => "Manager",
            "Livreur" => "Livreur",
            _ => role
        };
    }
}
